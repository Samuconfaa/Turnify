<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Colori principali forniti dal prompt -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryDarkColor">#1D4ED8</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="DangerColor">#DC2626</Color>

    <!-- Default MAUI Colors (necessari per Styles.xaml) -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="Secondary">#10B981</Color>
    <Color x:Key="SecondaryDarkText">#C8C8C8</Color>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>


    <!-- Colori sfondo e superficie -->
    <Color x:Key="Background">#F9FAFB</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Surface2">#F3F4F6</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>

    <!-- Colori testo -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>

    <!-- Mapping the keys to my previously used StaticResources for compatibility with the HTML converted ones, if necessary. 
         But since the prompt gave the explicit file, I'll keep the ones from the prompt and map the ones I used earlier.
         Actually, the user gave exactly what to paste, I will just paste it. But wait, I'll add aliases to match what I wrote in XAML.
         The prompt says: "incolla questo contenuto completo", so I'll follow that exactly. -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryContainer">#DBEAFE</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>
    <Color x:Key="OnPrimaryContainer">#1E40AF</Color>
    <Color x:Key="Error">#DC2626</Color>
    <Color x:Key="Success">#16A34A</Color>
    <Color x:Key="Tertiary">#D97706</Color>
    <Color x:Key="SurfaceContainerLowest">#FFFFFF</Color>
    <Color x:Key="SurfaceContainer">#F3F4F6</Color>
    <Color x:Key="SurfaceContainerHigh">#E5E7EB</Color>
    <Color x:Key="Outline">#D1D5DB</Color>
    <Color x:Key="OutlineVariant">#E5E7EB</Color>
    <Color x:Key="OnBackground">#111827</Color>
    <Color x:Key="OnSurfaceVariant">#6B7280</Color>
</ResourceDictionary>