<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── MAUI default keys (required by Styles.xaml) ─────────── -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>
    <Color x:Key="PrimaryDark">#2348C0</Color>
    <Color x:Key="PrimaryDarkText">#C5CEF8</Color>
    <Color x:Key="Secondary">#5B8DEF</Color>

    <!-- ── Core palette ──────────────────────────────────────── -->
    <Color x:Key="Navy">#0F1629</Color>
    <Color x:Key="Primary">#3B5BDB</Color>
    <Color x:Key="PrimaryLight">#EEF1FE</Color>
    <Color x:Key="PrimaryMid">#C5CEF8</Color>

    <Color x:Key="Success">#0D7A4E</Color>
    <Color x:Key="SuccessLight">#E6F7EF</Color>
    <Color x:Key="SuccessText">#065F38</Color>

    <Color x:Key="Warning">#B45309</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>
    <Color x:Key="WarningText">#92400E</Color>

    <Color x:Key="Error">#C42B1C</Color>
    <Color x:Key="ErrorLight">#FDECEA</Color>
    <Color x:Key="ErrorText">#9B1E12</Color>

    <Color x:Key="Purple">#6D4ADB</Color>
    <Color x:Key="PurpleLight">#F0EDFF</Color>

    <!-- ── Neutral surfaces ───────────────────────────────────── -->
    <Color x:Key="Background">#EDEAE5</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceContainerLow">#F5F3EE</Color>
    <Color x:Key="SurfaceContainerHigh">#EDEAE5</Color>

    <!-- ── Text ───────────────────────────────────────────────── -->
    <Color x:Key="OnBackground">#0F1629</Color>
    <Color x:Key="OnSurfaceVariant">#5C6275</Color>
    <Color x:Key="Outline">#9BA3B5</Color>
    <Color x:Key="OutlineVariant">#E3E1DB</Color>

    <!-- ── Legacy aliases (backward compat) ──────────────────── -->
    <Color x:Key="OnPrimary">White</Color>
    <Color x:Key="PrimaryContainer">#EEF1FE</Color>
    <Color x:Key="PrimaryFixed">#EEF1FE</Color>
    <Color x:Key="SecondaryContainer">#EEF1FE</Color>
    <Color x:Key="OnSecondaryContainer">#3B5BDB</Color>
    <Color x:Key="ErrorContainer">#FDECEA</Color>
    <Color x:Key="OnErrorContainer">#9B1E12</Color>
    <Color x:Key="SuccessContainer">#E6F7EF</Color>

    <!-- ── Global styles ─────────────────────────────────────── -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource Background}"/>
    </Style>

    <Style x:Key="FieldBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLow}"/>
        <Setter Property="Stroke" Value="{StaticResource OutlineVariant}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 13"/>
    </Style>

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}"/>
        <Setter Property="Stroke" Value="{StaticResource OutlineVariant}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Navy}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="BorderColor" Value="{StaticResource OutlineVariant}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="TextColor" Value="{StaticResource OnBackground}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="BorderColor" Value="{StaticResource Error}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="TextColor" Value="{StaticResource Error}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="FieldEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{StaticResource OnBackground}"/>
        <Setter Property="PlaceholderColor" Value="{StaticResource Outline}"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="Margin" Value="16,0"/>
        <Setter Property="FontFamily" Value="PJSReg"/>
        <Setter Property="FontSize" Value="15"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource Outline}"/>
        <Setter Property="CharacterSpacing" Value="1.1"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="HeadingLabel" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource OnBackground}"/>
        <Setter Property="CharacterSpacing" Value="-0.5"/>
        <Setter Property="FontFamily" Value="PJSXBold"/>
    </Style>

</ResourceDictionary>
