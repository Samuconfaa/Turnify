<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.NotificationsPage"
             x:DataType="vm:NotificationsViewModel"
             Title="Notifiche"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ────────────────────────────────────────── -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Surface}"
                Stroke="#E2E8F0" StrokeThickness="0,0,0,1"
                Padding="16,14,16,10">
            <Border.StrokeShape><RoundRectangle CornerRadius="0"/></Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Label Text="Notifiche"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="{StaticResource OnBackground}"/>
                    <Border BackgroundColor="{StaticResource Primary}"
                            Stroke="Transparent" Padding="8,3"
                            IsVisible="{Binding UnreadCount, Converter={StaticResource IntIsZeroConverter}, ConverterParameter=invert}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="{Binding UnreadCount, StringFormat='{0} non lette'}"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="White"/>
                    </Border>
                </HorizontalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="Transparent"
                        Stroke="Transparent"
                        IsVisible="{Binding UnreadCount, Converter={StaticResource IntIsZeroConverter}, ConverterParameter=invert}"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MarkAllReadCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="Segna tutte lette"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Error ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding HasError}"
                BackgroundColor="#FEF2F2"
                Stroke="#FECACA" StrokeThickness="1"
                Padding="16" Margin="16,70,16,0"
                VerticalOptions="Start">
            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
            <HorizontalStackLayout Spacing="8">
                <Label Text="⚠️" FontSize="16" VerticalOptions="Center"/>
                <Label Text="{Binding ErrorMessage}"
                       FontSize="14" TextColor="#DC2626" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <!-- ── Notifications List ─────────────────────────────── -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Notifications}"
                            Margin="0,4,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,60,0,0" Spacing="14"
                                         IsVisible="{Binding HasError, Converter={StaticResource InverseBoolConverter}}">
                        <Label Text="🔔" FontSize="52" HorizontalOptions="Center"/>
                        <Label Text="Nessuna notifica"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="Le notifiche sui tuoi turni e ferie appariranno qui."
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="32,0"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:NotificationDto">
                        <Border BackgroundColor="{Binding BackgroundColor}"
                                Stroke="Transparent" StrokeThickness="0"
                                Padding="16,12" Margin="8,0,8,2">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=MarkReadCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                <!-- Icon circle -->
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource SecondaryContainer}"
                                        HeightRequest="44" WidthRequest="44"
                                        VerticalOptions="Start">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                                    <Label Text="{Binding Icon}"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>

                                <!-- Content -->
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{StaticResource OnBackground}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Body}"
                                           FontSize="13"
                                           TextColor="{StaticResource OnSurfaceVariant}"
                                           LineBreakMode="WordWrap"/>
                                    <Label Text="{Binding TimeAgo}"
                                           FontSize="11"
                                           TextColor="{StaticResource Outline}"
                                           Margin="0,2,0,0"/>
                                </VerticalStackLayout>

                                <!-- Unread dot -->
                                <Ellipse Grid.Column="2"
                                         Fill="{StaticResource Primary}"
                                         HeightRequest="9" WidthRequest="9"
                                         VerticalOptions="Start"
                                         Margin="0,6,0,0">
                                    <Ellipse.Triggers>
                                        <DataTrigger TargetType="Ellipse"
                                                     Binding="{Binding IsRead}" Value="True">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </DataTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="{StaticResource Primary}"/>
    </Grid>
</ContentPage>
