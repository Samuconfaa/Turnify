<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.RoleSelectionPage"
             x:DataType="vm:RoleSelectionViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <ScrollView>
        <VerticalStackLayout>

            <!-- Logo -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,32,0,0" Spacing="10">
                <Border WidthRequest="42" HeightRequest="42"
                        StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <Label Text="T" FontSize="22" FontFamily="PJSBold"
                           TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Turnify" FontSize="21" FontFamily="PJSBold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Title block -->
            <VerticalStackLayout Padding="24,40,24,16" Spacing="6">
                <Label Text="Bentornato"
                       FontSize="24" FontFamily="PJSBold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalTextAlignment="Center"
                       CharacterSpacing="-0.5"/>
                <Label Text="Scegli come vuoi accedere a Turnify."
                       FontSize="14" FontFamily="PJSReg"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       HorizontalTextAlignment="Center"
                       LineHeight="1.45"/>
            </VerticalStackLayout>

            <!-- Role cards + separator -->
            <VerticalStackLayout Padding="20,12,20,0" Spacing="12">

                <!-- Admin card -->
                <Border StrokeShape="RoundRectangle CornerRadius='16'"
                        Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        StrokeThickness="2"
                        Padding="20"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToAdminLoginCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="16">
                        <Border WidthRequest="44" HeightRequest="44"
                                StrokeShape="RoundRectangle CornerRadius='12'"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                            <Label Text="💼" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                            <Label Text="Admin / Manager"
                                   FontSize="15" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            <Label Text="Gestisci team e turni"
                                   FontSize="13" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        </VerticalStackLayout>
                        <Label Text="›" FontSize="20" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Employee card -->
                <Border StrokeShape="RoundRectangle CornerRadius='16'"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        StrokeThickness="1"
                        Padding="20"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToEmployeeLoginCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="16">
                        <Border WidthRequest="44" HeightRequest="44"
                                StrokeShape="RoundRectangle CornerRadius='12'"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                            <Label Text="👤" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                            <Label Text="Dipendente"
                                   FontSize="15" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            <Label Text="Visualizza turni e timbra"
                                   FontSize="13" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        </VerticalStackLayout>
                        <Label Text="›" FontSize="20" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Divider oppure -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="4,14" ColumnSpacing="12" VerticalOptions="Center">
                    <BoxView Grid.Column="0" HeightRequest="1" VerticalOptions="Center"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                    <Label Grid.Column="1" Text="oppure" FontSize="12" FontFamily="PJSReg"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                </Grid>

                <!-- Register link -->
                <Label HorizontalTextAlignment="Center" FontSize="14" FontFamily="PJSReg"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Nuovo qui? " FontFamily="PJSReg"/>
                            <Span Text="Registra la tua azienda"
                                  FontFamily="PJSSemi"
                                  TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}"/>
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>

            <!-- Footer -->
            <Label Margin="24,8,24,28"
                   HorizontalTextAlignment="Center"
                   FontSize="12" FontFamily="PJSReg"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Termini di servizio"/>
                        <Span Text="  ·  "/>
                        <Span Text="Privacy"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
