<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.EmployeeListPage"
             x:DataType="vm:EmployeeListViewModel"
             Title="Team"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header + Search ──────────────────────────── -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" Padding="20,18,20,10">
            <Label Text="Team"
                   FontSize="26" FontAttributes="Bold" FontFamily="PJSXBold"
                   TextColor="{StaticResource OnBackground}"
                   CharacterSpacing="-0.8"/>

            <!-- Search bar -->
            <Border BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1.5">
                <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                <SearchBar Text="{Binding SearchQuery}"
                           Placeholder="Cerca per nome, ruolo…"
                           HeightRequest="48"
                           BackgroundColor="Transparent"
                           CancelButtonColor="{StaticResource Primary}"
                           TextColor="{StaticResource OnBackground}"
                           PlaceholderColor="{StaticResource Outline}"
                           FontFamily="PJSReg"/>
            </Border>

            <!-- Business filter -->
            <Border BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1.5">
                <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                <Picker ItemsSource="{Binding Businesses}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedBusiness}"
                        Title="Tutte le attività"
                        TextColor="{StaticResource OnBackground}"
                        TitleColor="{StaticResource Outline}"
                        FontFamily="PJSReg"
                        Margin="16,0"/>
            </Border>
        </VerticalStackLayout>

        <!-- ── Employee List ─────────────────────────────── -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadDataCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Employees}" Margin="0,2,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="32,52,32,0" Spacing="14">
                        <Border BackgroundColor="{StaticResource Surface}"
                                HeightRequest="68" WidthRequest="68"
                                HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Label Text="👥" FontSize="34"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Nessun dipendente ancora"
                               FontSize="17" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="Aggiungi il tuo primo dipendente per iniziare a gestire i turni."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               Margin="8,0"/>
                        <Button Text="Aggiungi dipendente"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=AddEmployeeCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalOptions="Center"
                                Padding="24,0" WidthRequest="240"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1.5"
                            StrokeDashArray="6,4"
                            Padding="16,20" Margin="20,0,20,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CreateEmployeeCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Aggiungi un utente"
                               FontSize="15" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EmployeeListDto">
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                                Margin="20,0,20,8">
                            <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="14" Opacity="0.06"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=EditEmployeeCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  Padding="14,14" ColumnSpacing="14">
                                <!-- Avatar -->
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        Stroke="Transparent"
                                        HeightRequest="48" WidthRequest="48"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLow}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Initials}"
                                           FontSize="15" FontAttributes="Bold" FontFamily="PJSBold"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource Outline}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1"
                                                     VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding FullName}"
                                           FontSize="14" FontAttributes="Bold" FontFamily="PJSBold"
                                           TextColor="{StaticResource OnBackground}"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Role}"
                                               FontSize="12" FontFamily="PJSReg"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                        <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                                Stroke="Transparent" Padding="7,3"
                                                VerticalOptions="Center"
                                                IsVisible="{Binding ContractType, Converter={StaticResource StringNotEmptyConverter}}">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="5"/></Border.StrokeShape>
                                            <Label Text="{Binding ContractType}"
                                                   FontSize="10" FontAttributes="Bold" FontFamily="PJSBold"
                                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Status badge -->
                                <Border Grid.Column="2"
                                        BackgroundColor="{StaticResource SuccessLight}"
                                        Stroke="Transparent" Padding="9,5"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceContainerLow}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding StatusText}"
                                           FontSize="10" FontAttributes="Bold" FontFamily="PJSBold"
                                           TextColor="{StaticResource SuccessText}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource Outline}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>


    </Grid>
</ContentPage>
