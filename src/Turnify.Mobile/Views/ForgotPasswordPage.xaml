<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Navy}">

    <Grid RowDefinitions="240,*">

        <!-- Hero -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
            <Border BackgroundColor="#FFFFFF14"
                    Stroke="#FFFFFF22" StrokeThickness="1.5"
                    HeightRequest="64" WidthRequest="64"
                    HorizontalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                <Label Text="🔑"
                       FontSize="28"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
            <Label Text="Reimposta password"
                   FontSize="22" FontAttributes="Bold" FontFamily="PJSXBold"
                   TextColor="White" HorizontalOptions="Center"
                   CharacterSpacing="-0.5"/>
            <Label Text="Ti invieremo un link per reimpostarla"
                   FontSize="13" FontFamily="PJSReg"
                   TextColor="#FFFFFF60" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Sheet -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Surface}"
                Stroke="Transparent"
                Margin="0,-24,0,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="28,28,0,0"/></Border.StrokeShape>

            <ScrollView>
                <VerticalStackLayout Spacing="0" Padding="24,30,24,48">

                    <!-- Success state -->
                    <VerticalStackLayout IsVisible="{Binding EmailSent}"
                                         Spacing="16" HorizontalOptions="Center"
                                         Margin="0,20,0,0">
                        <Border BackgroundColor="{StaticResource SuccessLight}"
                                HeightRequest="80" WidthRequest="80"
                                HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="40"/></Border.StrokeShape>
                            <Label Text="✓"
                                   FontSize="36" FontAttributes="Bold"
                                   TextColor="{StaticResource Success}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Email inviata!"
                               FontSize="22" FontAttributes="Bold" FontFamily="PJSXBold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="Se l'indirizzo è registrato, riceverai le istruzioni a breve. Controlla anche la cartella spam."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="Torna al login"
                                Command="{Binding GoBackCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,16,0,0"/>
                    </VerticalStackLayout>

                    <!-- Form state -->
                    <VerticalStackLayout IsVisible="{Binding EmailSent, Converter={StaticResource InverseBoolConverter}}"
                                         Spacing="18">

                        <Border BackgroundColor="{StaticResource ErrorLight}"
                                Stroke="{StaticResource Error}" StrokeThickness="1"
                                Padding="14,10"
                                IsVisible="{Binding HasError}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}"
                                   FontSize="13" FontFamily="PJSSemi"
                                   TextColor="{StaticResource ErrorText}"/>
                        </Border>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="EMAIL" Style="{StaticResource SectionLabel}" Margin="4,0,0,0"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Text="{Binding Email}"
                                       Placeholder="nome@azienda.it"
                                       Keyboard="Email"
                                       Style="{StaticResource FieldEntry}"/>
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Invia link di reset"
                                Command="{Binding SendResetCommand}"
                                Style="{StaticResource PrimaryButton}"/>

                        <Button Text="← Torna al login"
                                Command="{Binding GoBackCommand}"
                                Style="{StaticResource OutlineButton}"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center"
                                           Color="{StaticResource Primary}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
