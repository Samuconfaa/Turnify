<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Cambia Password"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="24,24,24,48">

            <!-- Error -->
            <Border BackgroundColor="{StaticResource ErrorLight}"
                    Stroke="{StaticResource Error}" StrokeThickness="1"
                    Padding="14,10" Margin="0,0,0,20"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       FontSize="13" FontFamily="PJSSemi"
                       TextColor="{StaticResource ErrorText}"/>
            </Border>

            <!-- Current password -->
            <Label Text="PASSWORD ATTUALE" Style="{StaticResource SectionLabel}" Margin="4,0,0,8"/>
            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,22">
                <Entry Text="{Binding CurrentPassword}"
                       IsPassword="True"
                       Placeholder="Inserisci la password attuale"
                       Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- New password -->
            <Label Text="NUOVA PASSWORD" Style="{StaticResource SectionLabel}" Margin="4,0,0,8"/>
            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,8">
                <Entry Text="{Binding NewPassword}"
                       IsPassword="True"
                       Placeholder="Min. 8 caratteri, 1 maiuscola, 1 numero"
                       Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- Confirm password -->
            <Label Text="CONFERMA NUOVA PASSWORD" Style="{StaticResource SectionLabel}" Margin="4,0,0,8"/>
            <Border Style="{StaticResource FieldBorder}" Margin="0,0,0,36">
                <Entry Text="{Binding ConfirmPassword}"
                       IsPassword="True"
                       Placeholder="Ripeti la nuova password"
                       Style="{StaticResource FieldEntry}"/>
            </Border>

            <Button Text="Aggiorna Password"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,12"/>

            <Button Text="Annulla"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource OutlineButton}"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" Margin="0,16,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
