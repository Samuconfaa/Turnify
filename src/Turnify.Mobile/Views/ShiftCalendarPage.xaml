<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ShiftCalendarPage"
             Title="Turni"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Week navigation bar ── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="48,*,48,Auto"
              BackgroundColor="{StaticResource Surface}"
              Padding="8,10">
            <Button Grid.Column="0" Text="‹"
                    Command="{Binding PreviousWeekCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    FontSize="26" Padding="0"
                    HorizontalOptions="Center"/>
            <Label Grid.Column="1"
                   Text="{Binding WeekLabel}"
                   FontSize="15" FontAttributes="Bold"
                   TextColor="{StaticResource OnBackground}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
            <Button Grid.Column="2" Text="›"
                    Command="{Binding NextWeekCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    FontSize="26" Padding="0"
                    HorizontalOptions="Center"/>
            <!-- Add button: admin only -->
            <Button Grid.Column="3"
                    Text="+"
                    Command="{Binding AddShiftCommand}"
                    IsVisible="{Binding IsAdmin}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="20"
                    HeightRequest="38" WidthRequest="38"
                    Padding="0" Margin="0,0,8,0"
                    FontSize="22"/>
        </Grid>

        <!-- ── Error banner ── -->
        <Border Grid.Row="1"
                IsVisible="{Binding HasError}"
                BackgroundColor="#FEF2F2"
                Stroke="#FECACA" StrokeThickness="1"
                Padding="12,8" Margin="16,8,16,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
            <Label Text="{Binding ErrorMessage}"
                   FontSize="13" TextColor="#DC2626"/>
        </Border>

        <!-- ══════════════ EMPLOYEE VIEW ══════════════ -->
        <RefreshView Grid.Row="2"
                     Command="{Binding LoadShiftsCommand}"
                     IsRefreshing="{Binding IsBusy}"
                     IsVisible="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}">
            <CollectionView ItemsSource="{Binding Shifts}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,48,0,0" Spacing="12">
                        <Label Text="📅" FontSize="52" HorizontalOptions="Center"/>
                        <Label Text="Nessun turno questa settimana"
                               FontSize="17" FontAttributes="Bold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="I tuoi turni appariranno qui quando l'admin li assegna."
                               FontSize="14"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="24,0"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ShiftDto">
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource Outline}" StrokeThickness="1"
                                Padding="0" Margin="16,0,16,10">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Grid ColumnDefinitions="5,*">
                                <BoxView Grid.Column="0"
                                         BackgroundColor="{StaticResource Primary}"
                                         VerticalOptions="Fill"/>
                                <Grid Grid.Column="1" ColumnDefinitions="*,Auto" Padding="14,12">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding StartTime, StringFormat='{0:dddd dd MMMM}'}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}"
                                               FontSize="14"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                        <Label Text="{Binding Label}"
                                               FontSize="12"
                                               TextColor="{StaticResource OnSurfaceVariant}"
                                               IsVisible="{Binding Label, Converter={StaticResource StringNotEmptyConverter}}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding EndTime, StringFormat='fino {0:HH:mm}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource OnSurfaceVariant}"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- ══════════════ ADMIN VIEW ══════════════ -->
        <Grid Grid.Row="2"
              IsVisible="{Binding IsAdmin}"
              RowDefinitions="Auto,*">

            <!-- Day header row (7 days) -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="72,*,*,*,*,*,*,*"
                  BackgroundColor="{StaticResource Surface}"
                  Padding="0,6,0,6">
                <Label Grid.Column="0"/>
                <Label Grid.Column="1" Text="Lun" HorizontalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="2" Text="Mar" HorizontalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="3" Text="Mer" HorizontalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="4" Text="Gio" HorizontalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="5" Text="Ven" HorizontalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="6" Text="Sab" HorizontalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="#D97706"/>
                <Label Grid.Column="7" Text="Dom" HorizontalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="#DC2626"/>
            </Grid>

            <!-- Employee rows (scrollable) -->
            <RefreshView Grid.Row="1"
                         Command="{Binding LoadShiftsCommand}"
                         IsRefreshing="{Binding IsBusy}">
                <CollectionView ItemsSource="{Binding EmployeeRows}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             Margin="0,48,0,0" Spacing="10">
                            <Label Text="Nessun turno questa settimana"
                                   FontSize="16"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Usa + per aggiungere un turno."
                                   FontSize="13"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:EmployeeWeekRow">
                            <Grid ColumnDefinitions="72,*,*,*,*,*,*,*"
                                  Padding="2,2" MinimumHeightRequest="52">

                                <!-- Employee name + initials avatar -->
                                <Grid Grid.Column="0" ColumnDefinitions="Auto,*"
                                      Padding="4,0" ColumnSpacing="4">
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource PrimaryContainer}"
                                            HeightRequest="32" WidthRequest="32">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding Initials}"
                                               FontSize="11" FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="{Binding EmployeeName}"
                                           FontSize="10"
                                           TextColor="{StaticResource OnBackground}"
                                           VerticalOptions="Center"
                                           LineBreakMode="TailTruncation"/>
                                </Grid>

                                <!-- 7 day cells -->
                                <Border Grid.Column="1" Margin="1"
                                        BackgroundColor="{Binding Days[0].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                        Stroke="Transparent" Padding="2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Days[0].Label}"
                                           FontSize="9" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="2" Margin="1"
                                        BackgroundColor="{Binding Days[1].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                        Stroke="Transparent" Padding="2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Days[1].Label}"
                                           FontSize="9" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="3" Margin="1"
                                        BackgroundColor="{Binding Days[2].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                        Stroke="Transparent" Padding="2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Days[2].Label}"
                                           FontSize="9" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="4" Margin="1"
                                        BackgroundColor="{Binding Days[3].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                        Stroke="Transparent" Padding="2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Days[3].Label}"
                                           FontSize="9" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="5" Margin="1"
                                        BackgroundColor="{Binding Days[4].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                        Stroke="Transparent" Padding="2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Days[4].Label}"
                                           FontSize="9" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="6" Margin="1"
                                        BackgroundColor="{Binding Days[5].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                        Stroke="Transparent" Padding="2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Days[5].Label}"
                                           FontSize="9" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                                <Border Grid.Column="7" Margin="1"
                                        BackgroundColor="{Binding Days[6].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                        Stroke="Transparent" Padding="2">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                    <Label Text="{Binding Days[6].Label}"
                                           FontSize="9" TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <!-- Loading overlay -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="{StaticResource Primary}"
                           ZIndex="10"/>
    </Grid>
</ContentPage>
