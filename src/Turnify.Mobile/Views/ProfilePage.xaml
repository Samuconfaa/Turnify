<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ProfilePage"
             Title="Profilo"
             BackgroundColor="{StaticResource Background}">
    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="16">
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,16,0,0">
                <Frame BackgroundColor="{StaticResource PrimaryContainer}" CornerRadius="40" HeightRequest="80" WidthRequest="80" Padding="0" HorizontalOptions="Center">
                    <Label Text="MB" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource OnPrimaryContainer}" HorizontalOptions="Center" VerticalOptions="Center" />
                </Frame>
                <Label Text="Mario Rossi" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource OnBackground}" HorizontalOptions="Center" />
                <Label Text="mario.rossi@example.com" FontSize="14" TextColor="{StaticResource OnSurfaceVariant}" HorizontalOptions="Center" />
                <Frame BackgroundColor="#E6F4EA" BorderColor="#CEEAD6" CornerRadius="16" Padding="12,4" HorizontalOptions="Center" Margin="0,4,0,0">
                    <Label Text="Dipendente" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Success}" />
                </Frame>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="16">
                <Label Text="IMPOSTAZIONI ACCOUNT" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource OnSurfaceVariant}" Margin="4,0,0,0" />
                
                <Frame BackgroundColor="{StaticResource Surface}" BorderColor="{StaticResource Outline}" HasShadow="True" Padding="0" CornerRadius="12" IsClippedToBounds="True">
                    <VerticalStackLayout>
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="16">
                            <Label Grid.Column="0" Text="👤" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
                            <Label Grid.Column="1" Text="Modifica Profilo" FontSize="16" TextColor="{StaticResource OnBackground}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="➔" FontSize="16" TextColor="{StaticResource Outline}" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" />
                        
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="16">
                            <Label Grid.Column="0" Text="🔒" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
                            <Label Grid.Column="1" Text="Cambia Password" FontSize="16" TextColor="{StaticResource OnBackground}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="➔" FontSize="16" TextColor="{StaticResource Outline}" VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" />

                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="16">
                            <Label Grid.Column="0" Text="🔔" FontSize="20" VerticalOptions="Center" Margin="0,0,12,0" />
                            <Label Grid.Column="1" Text="Notifiche" FontSize="16" TextColor="{StaticResource OnBackground}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="➔" FontSize="16" TextColor="{StaticResource Outline}" VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <Button Text="Logout" BackgroundColor="Transparent" TextColor="{StaticResource Error}" BorderColor="{StaticResource Error}" BorderWidth="1" CornerRadius="8" FontAttributes="Bold" Margin="0,24,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
