<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.EmployeeDetailPage"
             x:DataType="vm:EmployeeDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20,20,20,40">

            <!-- Nome -->
            <Label Text="NOME" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding FirstName}" Placeholder="Es. Mario" Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- Cognome -->
            <Label Text="COGNOME" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding LastName}" Placeholder="Es. Rossi" Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- Username -->
            <Label Text="NOME UTENTE" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Stroke="{StaticResource Primary}" StrokeThickness="1.5">
                <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                <Entry Text="{Binding Username}" Placeholder="es. mario.rossi" Style="{StaticResource FieldEntry}"/>
            </Border>
            <Label Text="Il dipendente userà questo nome per accedere all'app."
                   FontSize="12" FontFamily="PJSReg"
                   TextColor="{StaticResource Outline}" Margin="4,0,0,0"/>

            <!-- Email -->
            <Label Text="EMAIL (OPZIONALE)" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding Email}" Placeholder="mario.rossi@example.com"
                       Keyboard="Email" Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- Telefono -->
            <Label Text="TELEFONO" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding Phone}" Placeholder="+39 333 1234567"
                       Keyboard="Telephone" Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- Ruolo -->
            <Label Text="RUOLO IN AZIENDA" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding JobRole}" Placeholder="Es. Cameriere, Cuoco…" Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- Contratto -->
            <Label Text="TIPO CONTRATTO" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Picker ItemsSource="{Binding ContractTypesDisplay}"
                        SelectedIndex="{Binding SelectedContractTypeIndex}"
                        FontFamily="PJSReg"
                        TextColor="{StaticResource OnBackground}"
                        Margin="10,0"/>
            </Border>

            <!-- Ore settimanali -->
            <Label Text="ORE SETTIMANALI" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding WeeklyHours}" Placeholder="40"
                       Keyboard="Numeric" Style="{StaticResource FieldEntry}"/>
            </Border>

            <!-- Attività -->
            <Grid ColumnDefinitions="*,Auto" Margin="2,6,0,0">
                <Label Grid.Column="0" Text="ATTIVITÀ DI APPARTENENZA"
                       Style="{StaticResource SectionLabel}" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="+ Crea attività"
                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                       TextColor="{StaticResource Primary}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoCreateBusinessCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
            <Border Style="{StaticResource FieldBorder}">
                <Picker ItemsSource="{Binding Businesses}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedBusiness}"
                        Title="Seleziona attività (opzionale)"
                        FontFamily="PJSReg"
                        TextColor="{StaticResource OnBackground}"
                        TitleColor="{StaticResource Outline}"
                        Margin="10,0"/>
            </Border>

            <!-- Ruolo account -->
            <Label Text="RUOLO ACCOUNT" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Picker ItemsSource="{Binding AccountRolesDisplay}"
                        SelectedIndex="{Binding SelectedAccountRoleIndex}"
                        FontFamily="PJSReg"
                        TextColor="{StaticResource OnBackground}"
                        Margin="10,0"/>
            </Border>

            <!-- Password (create only) -->
            <VerticalStackLayout IsVisible="{Binding IsCreateMode}" Spacing="6" Margin="0,6,0,0">
                <Label Text="PASSWORD TEMPORANEA" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                        Stroke="{StaticResource Primary}" StrokeThickness="1.5">
                    <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                    <Entry Text="{Binding Password}" Placeholder="Es. TempPass123!"
                           IsPassword="True" Style="{StaticResource FieldEntry}"/>
                </Border>
                <Label Text="Comunica questa password al dipendente per il primo accesso."
                       FontSize="12" FontFamily="PJSReg"
                       TextColor="{StaticResource Outline}" Margin="4,0,0,0"/>
            </VerticalStackLayout>

            <!-- Reset password (edit only) -->
            <Button Text="Reimposta password"
                    Command="{Binding ResetPasswordCommand}"
                    IsVisible="{Binding IsEditMode}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}"
                    BorderColor="{StaticResource PrimaryMid}"
                    BorderWidth="1.5" CornerRadius="12"
                    HeightRequest="48" FontSize="14"
                    FontAttributes="Bold" FontFamily="PJSBold"
                    Margin="0,8,0,0"/>

            <!-- Action buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                <Button Grid.Column="0" Text="Disattiva"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding IsEditMode}"
                        Style="{StaticResource DangerButton}"/>
                <Button Grid.Column="1" Text="Salva"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsCreateMode}" Value="True">
                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                            <Setter Property="Grid.Column" Value="0"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" Color="{StaticResource Primary}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
