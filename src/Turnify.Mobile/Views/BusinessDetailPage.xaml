<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.BusinessDetailPage"
             x:DataType="vm:BusinessDetailViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="&#8249;" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="{Binding Title}" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="14">

                <!-- Informazioni -->
                <Label Text="INFORMAZIONI" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,4,0,0"/>

                <!-- Nome attività -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Padding="14,8" Spacing="2">
                        <Label Text="Nome attività" FontSize="10" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#127962;" FontSize="16" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding Name}" Placeholder="Es. Pizzeria Roma"
                                   FontSize="14" FontFamily="PJSReg"
                                   HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Tipo attività -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Tipo attività" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#128188;" FontSize="14" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Picker ItemsSource="{Binding BusinessTypes}"
                                        SelectedItem="{Binding BusinessType}"
                                        Title="Seleziona tipo"
                                        FontFamily="PJSReg" FontSize="14"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                        TitleColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                        HorizontalOptions="FillAndExpand"
                                        BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="&#8744;" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Indirizzo -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Padding="14,8" Spacing="2">
                        <Label Text="Indirizzo" FontSize="10" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#128205;" FontSize="15" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding Address}" Placeholder="Es. Via Roma 1, Milano"
                                   FontSize="14" FontFamily="PJSReg"
                                   HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Telefono -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Padding="14,8" Spacing="2">
                        <Label Text="Telefono" FontSize="10" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#128222;" FontSize="15" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding Phone}" Placeholder="+39 02 1234567"
                                   Keyboard="Telephone"
                                   FontSize="14" FontFamily="PJSReg"
                                   HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Action buttons -->
                <Grid ColumnDefinitions="*,2*" ColumnSpacing="10" Margin="0,10,0,0">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1.5"
                            Stroke="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                            HeightRequest="50" BackgroundColor="Transparent"
                            IsVisible="{Binding IsEditMode}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Disattiva" FontSize="15" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Button Command="{Binding SaveCommand}"
                            Text="Salva"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                            CornerRadius="12" HeightRequest="50"
                            FontFamily="PJSSemi" FontSize="15">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCreateMode}" Value="True">
                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                <Setter Property="Grid.Column" Value="0"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
