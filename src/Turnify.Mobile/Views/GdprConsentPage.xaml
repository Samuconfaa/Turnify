<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.GdprConsentPage"
             x:DataType="vm:GdprConsentViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FAF8FF">

    <Grid RowDefinitions="56,*,Auto">

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" BackgroundColor="#F9FAFB" Padding="20,0">
            <HorizontalStackLayout VerticalOptions="Center" Spacing="10">
                <Label Text="🛡️" FontSize="20" VerticalOptions="Center"/>
                <Label Text="Privacy &amp; Terms"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource OnBackground}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- ══ CONTENUTO ══ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="20,24,20,12">

                <!-- Shield hero -->
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border BackgroundColor="#EFF6FF"
                            HeightRequest="80" WidthRequest="80"
                            HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="40"/></Border.StrokeShape>
                        <Label Text="🛡️" FontSize="38"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="La tua privacy è importante"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="{StaticResource OnBackground}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Prima di iniziare, leggi come trattiamo i tuoi dati."
                           FontSize="14" TextColor="{StaticResource OnSurfaceVariant}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Value proposition card -->
                <Border BackgroundColor="White"
                        Stroke="{StaticResource Outline}" StrokeThickness="1"
                        Padding="16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">

                        <HorizontalStackLayout Spacing="14">
                            <Label Text="🔒" FontSize="22" VerticalOptions="Start" Margin="0,2,0,0"/>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                <Label Text="Dati al sicuro"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="I tuoi dati sono cifrati e conservati su server italiani"
                                       FontSize="13" TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource Outline}"/>

                        <HorizontalStackLayout Spacing="14">
                            <Label Text="👥" FontSize="22" VerticalOptions="Start" Margin="0,2,0,0"/>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                <Label Text="Solo per te"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="Non vendiamo i tuoi dati a terze parti, mai"
                                       FontSize="13" TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource Outline}"/>

                        <HorizontalStackLayout Spacing="14">
                            <Label Text="⚙️" FontSize="22" VerticalOptions="Start" Margin="0,2,0,0"/>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                <Label Text="Controllo totale"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="Puoi esportare o eliminare i tuoi dati in qualsiasi momento"
                                       FontSize="13" TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Consensi ──
                     FIX: usa Grid con ColumnDefinitions invece di HorizontalStackLayout
                     così il testo va a capo correttamente -->
                <VerticalStackLayout Spacing="16">

                    <!-- Consenso obbligatorio -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding PrivacyAccepted}"
                                  Color="#2563EB"
                                  VerticalOptions="Start"
                                  Margin="0,4,0,0"/>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label FontSize="14" TextColor="{StaticResource OnBackground}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Ho letto e accetto la "/>
                                        <Span Text="Privacy Policy"
                                              TextColor="#2563EB"
                                              FontAttributes="Bold"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenPrivacyPolicyCommand}"/>
                                            </Span.GestureRecognizers>
                                        </Span>
                                        <Span Text=" e i "/>
                                        <Span Text="Termini di Servizio"
                                              TextColor="#2563EB"
                                              FontAttributes="Bold"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenTermsOfServiceCommand}"/>
                                            </Span.GestureRecognizers>
                                        </Span>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Consenso marketing (opzionale) -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding MarketingAccepted}"
                                  Color="#2563EB"
                                  VerticalOptions="Start"
                                  Margin="0,4,0,0"/>
                        <Label Grid.Column="1"
                               Text="Acconsento a ricevere comunicazioni di prodotto e aggiornamenti (opzionale)"
                               FontSize="14"
                               TextColor="{StaticResource OnBackground}"
                               LineBreakMode="WordWrap"/>
                    </Grid>

                </VerticalStackLayout>

                <!-- Note footer -->
                <Label FontSize="12"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Puoi revocare il consenso in qualsiasi momento dalle "/>
                            <Span Text="Impostazioni → Profilo → Gestisci dati"
                                  FontAttributes="Bold"/>
                            <Span Text="."/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══ FOOTER CTA ══ -->
        <Grid Grid.Row="2"
              BackgroundColor="#FAF8FF"
              Padding="20,12,20,32">
            <Button Text="Accetta e continua"
                    Command="{Binding AcceptAndContinueCommand}"
                    HeightRequest="48"
                    CornerRadius="12"
                    FontSize="16"
                    FontAttributes="Bold">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding CanProceed}" Value="True">
                        <Setter Property="BackgroundColor" Value="#2563EB"/>
                        <Setter Property="TextColor" Value="White"/>
                        <Setter Property="IsEnabled" Value="True"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding CanProceed}" Value="False">
                        <Setter Property="BackgroundColor" Value="#9CA3AF"/>
                        <Setter Property="TextColor" Value="White"/>
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

    </Grid>
</ContentPage>
