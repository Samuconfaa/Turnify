<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Navy}">

    <Grid RowDefinitions="220,*">

        <!-- ── Hero ──────────────────────────────────────────── -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8">
            <!-- Logo mark -->
            <Border BackgroundColor="#FFFFFF14"
                    Stroke="#FFFFFF22" StrokeThickness="1.5"
                    HeightRequest="68" WidthRequest="68"
                    HorizontalOptions="Center"
                    Margin="0,0,0,4">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <Label Text="T"
                       FontSize="30" FontAttributes="Bold"
                       FontFamily="PJSXBold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
            <Label Text="Turnify"
                   FontSize="28" FontAttributes="Bold"
                   FontFamily="PJSXBold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   CharacterSpacing="-0.8"/>
            <Label Text="Gestisci il tuo team, ovunque"
                   FontSize="14" FontFamily="PJSReg"
                   TextColor="#FFFFFF70"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- ── Bottom sheet ───────────────────────────────────── -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Surface}"
                Stroke="Transparent"
                Margin="0,-24,0,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="28,28,0,0"/></Border.StrokeShape>

            <ScrollView>
                <VerticalStackLayout Spacing="18" Padding="24,30,24,48">

                    <Label Text="Accedi"
                           FontSize="22" FontAttributes="Bold"
                           FontFamily="PJSXBold"
                           TextColor="{StaticResource OnBackground}"
                           CharacterSpacing="-0.5"/>

                    <!-- Error banner -->
                    <Border BackgroundColor="{StaticResource ErrorLight}"
                            Stroke="{StaticResource Error}" StrokeThickness="1"
                            Padding="14,10"
                            IsVisible="{Binding HasError}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="13" FontFamily="PJSSemi"
                               TextColor="{StaticResource ErrorText}"/>
                    </Border>

                    <!-- Mode toggle -->
                    <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                            Stroke="Transparent"
                            Padding="4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="0">
                            <Border Grid.Column="0"
                                    Stroke="Transparent" Padding="0,10">
                                <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsAdminMode}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Navy}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsAdminMode}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectAdminModeCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="Admin / Manager"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsAdminMode}" Value="True">
                                            <Setter Property="TextColor" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsAdminMode}" Value="False">
                                            <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                            <Border Grid.Column="1"
                                    Stroke="Transparent" Padding="0,10">
                                <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsEmployeeMode}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{StaticResource Navy}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsEmployeeMode}" Value="False">
                                        <Setter Property="BackgroundColor" Value="Transparent"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectEmployeeModeCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="Dipendente"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsEmployeeMode}" Value="True">
                                            <Setter Property="TextColor" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsEmployeeMode}" Value="False">
                                            <Setter Property="TextColor" Value="{StaticResource OnSurfaceVariant}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Admin fields -->
                    <VerticalStackLayout IsVisible="{Binding IsAdminMode}" Spacing="6">
                        <Label Text="EMAIL" Style="{StaticResource SectionLabel}" Margin="4,0,0,2"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry Text="{Binding Email}"
                                   Placeholder="nome@azienda.it"
                                   Keyboard="Email"
                                   Style="{StaticResource FieldEntry}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Employee fields -->
                    <VerticalStackLayout IsVisible="{Binding IsEmployeeMode}" Spacing="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="NOME AZIENDA" Style="{StaticResource SectionLabel}" Margin="4,0,0,2"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Text="{Binding CompanySlug}"
                                       Placeholder="pizzeria-mario"
                                       Style="{StaticResource FieldEntry}"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="NOME UTENTE" Style="{StaticResource SectionLabel}" Margin="4,0,0,2"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Text="{Binding Username}"
                                       Placeholder="mario.rossi"
                                       Style="{StaticResource FieldEntry}"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PASSWORD" Style="{StaticResource SectionLabel}" Margin="4,0,0,2"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <Entry Text="{Binding Password}"
                                   Placeholder="••••••••"
                                   IsPassword="True"
                                   Style="{StaticResource FieldEntry}"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Forgot password -->
                    <Label Text="Password dimenticata?"
                           FontSize="13" FontAttributes="Bold" FontFamily="PJSSemi"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="End"
                           IsVisible="{Binding IsAdminMode}"
                           Margin="0,-8,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView HeightRequest="4" BackgroundColor="Transparent"
                             IsVisible="{Binding IsEmployeeMode}"/>

                    <!-- Login button -->
                    <Button Text="Accedi"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryButton}"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center"
                                       Color="{StaticResource Primary}"/>

                    <!-- Divider -->
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                        <BoxView Grid.Column="0" HeightRequest="1"
                                 BackgroundColor="{StaticResource OutlineVariant}"
                                 VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="oppure"
                               FontSize="12" FontFamily="PJSReg"
                               TextColor="{StaticResource Outline}"/>
                        <BoxView Grid.Column="2" HeightRequest="1"
                                 BackgroundColor="{StaticResource OutlineVariant}"
                                 VerticalOptions="Center"/>
                    </Grid>

                    <Button Text="Registra la tua azienda"
                            Command="{Binding GoToRegisterCommand}"
                            Style="{StaticResource OutlineButton}"/>

                    <!-- Legal -->
                    <Label FontSize="11" FontFamily="PJSReg"
                           TextColor="{StaticResource Outline}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Accedendo, accetti i nostri "/>
                                <Span Text="Termini di Servizio"
                                      TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
                                <Span Text=" e la "/>
                                <Span Text="Privacy Policy"
                                      TextColor="{StaticResource Primary}" FontAttributes="Bold"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
