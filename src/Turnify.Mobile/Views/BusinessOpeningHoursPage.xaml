<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.BusinessOpeningHoursPage"
             x:DataType="viewmodels:BusinessOpeningHoursViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="&#8249;" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Orari di apertura" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto" Padding="18,18,18,24">

            <ActivityIndicator Grid.Row="0" Grid.RowSpan="2"
                               IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" ZIndex="10"/>

            <ScrollView Grid.Row="0">
                <VerticalStackLayout Spacing="16">

                    <!-- Days card -->
                    <Border StrokeShape="RoundRectangle CornerRadius='16'" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>

                        <CollectionView ItemsSource="{Binding Days}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:DayScheduleItemViewModel">
                                    <VerticalStackLayout Spacing="0">
                                        <Grid ColumnDefinitions="90,*,Auto" Padding="14,14,16,14">
                                            <Label Grid.Column="0" Text="{Binding DayName}" FontSize="14" FontFamily="PJSSemi"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                   VerticalOptions="Center"/>
                                            <HorizontalStackLayout Grid.Column="1" Spacing="8" IsVisible="{Binding IsOpen}">
                                                <Border StrokeShape="RoundRectangle CornerRadius='10'" StrokeThickness="1"
                                                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                                        HeightRequest="36" HorizontalOptions="FillAndExpand"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                                    <HorizontalStackLayout Spacing="6" Padding="10,0">
                                                        <Label Text="DAL" FontSize="10" FontFamily="PJSSemi" CharacterSpacing="0.4"
                                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                                               VerticalOptions="Center"/>
                                                        <TimePicker Time="{Binding OpenTime}" Format="HH:mm"
                                                                    FontFamily="PJSReg" FontSize="13"
                                                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                                    VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </Border>
                                                <Border StrokeShape="RoundRectangle CornerRadius='10'" StrokeThickness="1"
                                                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                                        HeightRequest="36" HorizontalOptions="FillAndExpand"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                                    <HorizontalStackLayout Spacing="6" Padding="10,0">
                                                        <Label Text="AL" FontSize="10" FontFamily="PJSSemi" CharacterSpacing="0.4"
                                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                                               VerticalOptions="Center"/>
                                                        <TimePicker Time="{Binding CloseTime}" Format="HH:mm"
                                                                    FontFamily="PJSReg" FontSize="13"
                                                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                                    VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </Border>
                                            </HorizontalStackLayout>
                                            <Label Grid.Column="1" Text="Chiuso" FontSize="13" FontFamily="PJSReg"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                                   FontAttributes="Italic" VerticalOptions="Center"
                                                   IsVisible="False">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsOpen}" Value="False">
                                                        <Setter Property="IsVisible" Value="True"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Switch Grid.Column="2" IsToggled="{Binding IsOpen}" VerticalOptions="Center"
                                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" Margin="14,0"
                                                 BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="1"
                    Text="Salva orari"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                    CornerRadius="12" HeightRequest="50"
                    FontFamily="PJSSemi" FontSize="15"
                    Margin="0,12,0,0">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>

        </Grid>

    </Grid>
</ContentPage>
