<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ShiftCalendarPage"
             x:DataType="vm:ShiftCalendarViewModel"
             Title="Turni"
             BackgroundColor="{StaticResource Background}">

    <Grid>
        <!-- ═══ EMPLOYEE VIEW ═══ -->
        <ScrollView IsVisible="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}">
            <VerticalStackLayout Spacing="16" Padding="16">

                <!-- Week navigation (employees can browse too) -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                    <Button Grid.Column="0" Text="‹"
                            Command="{Binding PreviousWeekCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="24" Padding="4,0"/>
                    <Label Grid.Column="1"
                           Text="{Binding WeekLabel}"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{StaticResource OnBackground}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Button Grid.Column="2" Text="›"
                            Command="{Binding NextWeekCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="24" Padding="4,0"/>
                </Grid>

                <!-- Info label for employees -->
                <Border BackgroundColor="{StaticResource PrimaryContainer}"
                        Stroke="Transparent" Padding="12,8">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="📋 I tuoi turni assegnati per questa settimana"
                           FontSize="13"
                           TextColor="{StaticResource Primary}"/>
                </Border>

                <CollectionView ItemsSource="{Binding Shifts}">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center"
                                             Margin="0,40,0,0" Spacing="12">
                            <Label Text="📅" FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label Text="Nessun turno questa settimana"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="{StaticResource OnBackground}"
                                   HorizontalOptions="Center"/>
                            <Label Text="I tuoi turni appariranno qui quando l'admin li assegna."
                                   FontSize="14"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ShiftDto">
                            <Border BackgroundColor="{StaticResource Surface}"
                                    Stroke="{StaticResource Outline}"
                                    StrokeThickness="1"
                                    Padding="0" Margin="0,0,0,10">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="4,*">
                                    <BoxView Grid.Column="0"
                                             BackgroundColor="{StaticResource Primary}"
                                             VerticalOptions="Fill"/>
                                    <Grid Grid.Column="1"
                                          ColumnDefinitions="*,Auto"
                                          Padding="14,12">
                                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                                            <Label Text="{Binding StartTime, StringFormat='{0:dddd dd MMMM}'}"
                                                   FontSize="15" FontAttributes="Bold"
                                                   TextColor="{StaticResource OnBackground}"/>
                                            <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                                            <Label Text="{Binding Label}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource OnSurfaceVariant}"
                                                   IsVisible="{Binding Label, Converter={StaticResource StringNotEmptyConverter}}"/>
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding EndTime, StringFormat='fino {0:HH:mm}'}"
                                               FontSize="13"
                                               TextColor="{StaticResource OnSurfaceVariant}"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ ADMIN VIEW ═══ -->
        <Grid IsVisible="{Binding IsAdmin}"
              RowDefinitions="Auto,Auto,*">

            <!-- Week navigation + Add button (ADMIN only) -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*,Auto,Auto"
                  Padding="16,12"
                  BackgroundColor="{StaticResource Surface}">
                <Button Grid.Column="0" Text="‹"
                        Command="{Binding PreviousWeekCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        FontSize="22" Padding="8,0"/>
                <Label Grid.Column="1"
                       Text="{Binding WeekLabel}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="{StaticResource OnBackground}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
                <Button Grid.Column="2" Text="›"
                        Command="{Binding NextWeekCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        FontSize="22" Padding="8,0"/>
                <!-- Add Shift — ADMIN ONLY -->
                <Button Grid.Column="3" Text="+"
                        Command="{Binding AddShiftCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40" WidthRequest="40"
                        Padding="0" Margin="8,0,0,0"
                        FontSize="20"/>
            </Grid>

            <!-- Day headers -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="90,*,*,*,*,*"
                  BackgroundColor="{StaticResource Surface}"
                  Padding="0,6">
                <Label Grid.Column="0"/>
                <Label Grid.Column="1" Text="LUN" HorizontalOptions="Center"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="2" Text="MAR" HorizontalOptions="Center"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="3" Text="MER" HorizontalOptions="Center"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="4" Text="GIO" HorizontalOptions="Center"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
                <Label Grid.Column="5" Text="VEN" HorizontalOptions="Center"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"/>
            </Grid>

            <!-- Employee rows -->
            <CollectionView Grid.Row="2"
                            ItemsSource="{Binding EmployeeRows}">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,48,0,0" Spacing="10">
                        <Label Text="Nessun turno questa settimana"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource OnSurfaceVariant}"/>
                        <Label Text="Usa il pulsante + per aggiungere un turno."
                               HorizontalOptions="Center"
                               FontSize="13"
                               TextColor="{StaticResource OnSurfaceVariant}"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EmployeeWeekRow">
                        <Grid ColumnDefinitions="90,*,*,*,*,*"
                              Padding="4,2" RowDefinitions="54">
                            <Label Grid.Column="0"
                                   Text="{Binding EmployeeName}"
                                   FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource OnBackground}"
                                   VerticalOptions="Center"
                                   Margin="8,0,4,0"
                                   LineBreakMode="TailTruncation"/>
                            <Border Grid.Column="1" Margin="2"
                                    BackgroundColor="{Binding Days[0].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                    Stroke="Transparent" Padding="4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                <Label Text="{Binding Days[0].Label}"
                                       FontSize="9" TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="2" Margin="2"
                                    BackgroundColor="{Binding Days[1].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                    Stroke="Transparent" Padding="4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                <Label Text="{Binding Days[1].Label}"
                                       FontSize="9" TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" Margin="2"
                                    BackgroundColor="{Binding Days[2].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                    Stroke="Transparent" Padding="4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                <Label Text="{Binding Days[2].Label}"
                                       FontSize="9" TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" Margin="2"
                                    BackgroundColor="{Binding Days[3].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                    Stroke="Transparent" Padding="4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                <Label Text="{Binding Days[3].Label}"
                                       FontSize="9" TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="5" Margin="2"
                                    BackgroundColor="{Binding Days[4].HasShift, Converter={StaticResource BoolToShiftColorConverter}}"
                                    Stroke="Transparent" Padding="4">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                <Label Text="{Binding Days[4].Label}"
                                       FontSize="9" TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Loading overlay -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="{StaticResource Primary}"
                           ZIndex="10"/>
    </Grid>
</ContentPage>
