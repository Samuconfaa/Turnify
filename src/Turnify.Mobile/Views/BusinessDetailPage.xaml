<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.BusinessDetailPage"
             x:DataType="vm:BusinessDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">

            <Label Text="Nome attività *" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Entry Text="{Binding Name}" Placeholder="Es. Pizzeria Roma"
                       HeightRequest="50" Margin="14,0" BackgroundColor="Transparent"/>
            </Border>

            <Label Text="Tipo attività" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Picker ItemsSource="{Binding BusinessTypes}"
                        SelectedItem="{Binding BusinessType}"
                        Title="Seleziona tipo"
                        Margin="10,0"/>
            </Border>

            <Label Text="Indirizzo" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Entry Text="{Binding Address}" Placeholder="Es. Via Roma 1, Milano"
                       HeightRequest="50" Margin="14,0" BackgroundColor="Transparent"/>
            </Border>

            <Label Text="Telefono" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Entry Text="{Binding Phone}" Placeholder="+39 02 1234567"
                       Keyboard="Telephone"
                       HeightRequest="50" Margin="14,0" BackgroundColor="Transparent"/>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                <Button Grid.Column="0" Text="Disattiva"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding IsEditMode}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Error}"
                        BorderColor="{StaticResource Error}"
                        BorderWidth="1" CornerRadius="10" HeightRequest="50"/>
                <Button Grid.Column="1" Text="Salva"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" CornerRadius="10" HeightRequest="50"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsCreateMode}" Value="True">
                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                            <Setter Property="Grid.Column" Value="0"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" Color="{StaticResource Primary}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
