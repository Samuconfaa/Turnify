<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.AvailabilityPage"
             x:DataType="vm:AvailabilityViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="20,20,20,40">

            <Label Text="Disponibilità settimanale"
                   FontSize="22" FontAttributes="Bold" FontFamily="PJSXBold"
                   TextColor="{StaticResource OnBackground}"
                   CharacterSpacing="-0.5" Margin="0,0,0,4"/>
            <Label Text="Seleziona i giorni in cui sei disponibile a ricevere turni."
                   FontSize="13" FontFamily="PJSReg"
                   TextColor="{StaticResource OnSurfaceVariant}"
                   Margin="0,0,0,14"/>

            <!-- Grouped in a single card -->
            <Border BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                    Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.06"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">

                    <!-- Lunedì -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                        <Label Grid.Column="0" Text="Lunedì"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{StaticResource OnBackground}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding Monday}"
                                OnColor="{StaticResource Primary}" ThumbColor="White"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="18,0"/>

                    <!-- Martedì -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                        <Label Grid.Column="0" Text="Martedì"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{StaticResource OnBackground}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding Tuesday}"
                                OnColor="{StaticResource Primary}" ThumbColor="White"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="18,0"/>

                    <!-- Mercoledì -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                        <Label Grid.Column="0" Text="Mercoledì"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{StaticResource OnBackground}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding Wednesday}"
                                OnColor="{StaticResource Primary}" ThumbColor="White"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="18,0"/>

                    <!-- Giovedì -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                        <Label Grid.Column="0" Text="Giovedì"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{StaticResource OnBackground}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding Thursday}"
                                OnColor="{StaticResource Primary}" ThumbColor="White"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="18,0"/>

                    <!-- Venerdì -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                        <Label Grid.Column="0" Text="Venerdì"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{StaticResource OnBackground}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding Friday}"
                                OnColor="{StaticResource Primary}" ThumbColor="White"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="18,0"/>

                    <!-- Sabato -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                        <Label Grid.Column="0" Text="Sabato"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{StaticResource Warning}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding Saturday}"
                                OnColor="{StaticResource Primary}" ThumbColor="White"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="18,0"/>

                    <!-- Domenica -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,14">
                        <Label Grid.Column="0" Text="Domenica"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{StaticResource Error}" VerticalOptions="Center"/>
                        <Switch Grid.Column="1" IsToggled="{Binding Sunday}"
                                OnColor="{StaticResource Primary}" ThumbColor="White"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Button Text="Salva"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,12,0,0"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" Color="{StaticResource Primary}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
