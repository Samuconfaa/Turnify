<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ProfilePage"
             Title="Profilo"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="300,*">

        <!-- ── Hero ──────────────────────────────────────── -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource Navy}">
            <!-- Decorative circles -->
            <BoxView Color="#3B5BDB" Opacity="0.18"
                     HeightRequest="180" WidthRequest="180"
                     CornerRadius="90"
                     HorizontalOptions="Start" VerticalOptions="Start"
                     Margin="-40,-40,0,0"/>
            <BoxView Color="#3B5BDB" Opacity="0.12"
                     HeightRequest="130" WidthRequest="130"
                     CornerRadius="65"
                     HorizontalOptions="End" VerticalOptions="End"
                     Margin="0,0,-30,-30"/>

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8" Margin="0,24,0,0">
                <!-- Avatar -->
                <Grid HorizontalOptions="Center">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickAvatarCommand}"/>
                    </Grid.GestureRecognizers>

                    <!-- Photo avatar -->
                    <Border HeightRequest="88" WidthRequest="88"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowPhoto}"
                            Stroke="#FFFFFF33" StrokeThickness="2.5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="44"/></Border.StrokeShape>
                        <Image Source="{Binding AvatarPhoto}"
                               Aspect="AspectFill"
                               HeightRequest="88" WidthRequest="88"/>
                    </Border>

                    <!-- Emoji avatar -->
                    <Border BackgroundColor="#FFFFFF14"
                            HeightRequest="88" WidthRequest="88"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowEmoji}"
                            Stroke="#FFFFFF33" StrokeThickness="2.5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="44"/></Border.StrokeShape>
                        <Label Text="{Binding AvatarEmoji}"
                               FontSize="44"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Initials avatar -->
                    <Border BackgroundColor="#FFFFFF14"
                            HeightRequest="88" WidthRequest="88"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowInitials}"
                            Stroke="#FFFFFF33" StrokeThickness="2.5">
                        <Border.StrokeShape><RoundRectangle CornerRadius="44"/></Border.StrokeShape>
                        <Label Text="{Binding ComputedInitials}"
                               FontSize="32" FontAttributes="Bold" FontFamily="PJSXBold"
                               TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Edit badge -->
                    <Border BackgroundColor="White"
                            HeightRequest="28" WidthRequest="28"
                            HorizontalOptions="End" VerticalOptions="End"
                            Margin="0,0,2,2"
                            Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.18"/>
                        </Border.Shadow>
                        <Label Text="✏" FontSize="12"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <Label Text="{Binding FullName}"
                       FontSize="22" FontAttributes="Bold" FontFamily="PJSXBold"
                       TextColor="White" HorizontalOptions="Center"
                       CharacterSpacing="-0.5"/>
                <Label Text="{Binding Email}"
                       FontSize="13" FontFamily="PJSReg"
                       TextColor="#FFFFFF55" HorizontalOptions="Center"/>
                <Border BackgroundColor="#FFFFFF12"
                        Stroke="#FFFFFF22" StrokeThickness="1"
                        HorizontalOptions="Center" Padding="16,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Label Text="{Binding RoleDisplay}"
                           FontSize="11" FontAttributes="Bold" FontFamily="PJSBold"
                           TextColor="#FFFFFFCC"/>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Settings card ─────────────────────────────── -->
        <ScrollView Grid.Row="1" Margin="0,-24,0,0">
            <Border BackgroundColor="{StaticResource Surface}"
                    Padding="0,0,0,56"
                    Stroke="Transparent">
                <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0"/></Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- ACCOUNT -->
                    <VerticalStackLayout Padding="24,26,24,0" Spacing="0">
                        <Label Text="ACCOUNT" Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,12"/>
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                                Padding="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <VerticalStackLayout>
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PickAvatarCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36"
                                            Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="✎" FontSize="16"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                    </Border>
                                    <Label Grid.Column="1" Text="Cambia foto profilo"
                                           FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{StaticResource OnBackground}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           FontFamily="PJSBold"
                                           TextColor="{StaticResource Outline}"
                                           VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"
                                         Margin="16,0"/>
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ChangePasswordCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36"
                                            Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="🔒" FontSize="16"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Grid.Column="1" Text="Cambia Password"
                                           FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{StaticResource OnBackground}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="›" FontSize="20"
                                           FontFamily="PJSBold"
                                           TextColor="{StaticResource Outline}"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- GESTIONE ATTIVITÀ (admin only) -->
                    <VerticalStackLayout Padding="24,20,24,0" Spacing="0"
                                         IsVisible="{Binding IsAdmin}">
                        <Label Text="GESTIONE ATTIVITÀ" Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,12"/>
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                                Padding="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>

                            <VerticalStackLayout>
                                <!-- Le mie attività -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ManageBusinessesCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36" Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="🏪" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Le mie attività" FontSize="14" FontFamily="PJSSemi" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Crea e gestisci sedi" FontSize="11" FontFamily="PJSReg" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20" FontFamily="PJSBold" TextColor="{StaticResource Outline}" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="16,0"/>
                                <!-- Orari di apertura -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ManageOpeningHoursCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36" Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="🕐" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Orari di Apertura" FontSize="14" FontFamily="PJSSemi" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Configura apertura/chiusura" FontSize="11" FontFamily="PJSReg" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20" FontFamily="PJSBold" TextColor="{StaticResource Outline}" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="16,0"/>
                                <!-- Team -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToTeamCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36" Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="👥" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Gestisci Team" FontSize="14" FontFamily="PJSSemi" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Aggiungi o modifica dipendenti" FontSize="11" FontFamily="PJSReg" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20" FontFamily="PJSBold" TextColor="{StaticResource Outline}" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="16,0"/>
                                <!-- Report ore dipendenti -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToEmployeeReportsCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36" Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="⏱" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Report ore dipendenti" FontSize="14" FontFamily="PJSSemi" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Ore pianificate per periodo" FontSize="11" FontFamily="PJSReg" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20" FontFamily="PJSBold" TextColor="{StaticResource Outline}" VerticalOptions="Center"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="16,0"/>
                                <!-- Export CSV (presenze/ore) -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToReportsCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36" Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="📊" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Report e statistiche" FontSize="14" FontFamily="PJSSemi" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Esporta ore e presenze in CSV" FontSize="11" FontFamily="PJSReg" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="20" FontFamily="PJSBold" TextColor="{StaticResource Outline}" VerticalOptions="Center"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Logout -->
                    <VerticalStackLayout Padding="24,22,24,0" Spacing="0">
                        <Button Text="Esci dall'account"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource DangerButton}"/>
                    </VerticalStackLayout>

                    <Label Text="Turnify v1.0.0"
                           FontSize="11" FontFamily="PJSReg"
                           TextColor="{StaticResource Outline}"
                           HorizontalOptions="Center"
                           Margin="0,18,0,0"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center"
                                       Color="{StaticResource Primary}"
                                       Margin="0,12,0,0"/>
                </VerticalStackLayout>
            </Border>
        </ScrollView>
    </Grid>
</ContentPage>
