<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ProfilePage"
             Title="Profilo"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="16,0,16,40">

            <!-- AVATAR + INFO -->
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,24,0,0">
                <Border BackgroundColor="{StaticResource PrimaryContainer}"
                        HeightRequest="88" WidthRequest="88"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="44"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding Initials}"
                           FontSize="30" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="{Binding FullName}"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="{StaticResource OnBackground}"
                       HorizontalOptions="Center"/>

                <Label Text="{Binding Email}"
                       FontSize="14"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       HorizontalOptions="Center"/>

                <Border BackgroundColor="{StaticResource PrimaryContainer}"
                        HorizontalOptions="Center"
                        Padding="14,5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding RoleDisplay}"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"/>
                </Border>
            </VerticalStackLayout>

            <!-- ACCOUNT SETTINGS -->
            <VerticalStackLayout Spacing="0">
                <Label Text="IMPOSTAZIONI ACCOUNT"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       Margin="4,0,0,10"/>

                <Border BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Outline}"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangePasswordCommand}"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="🔒" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <Label Grid.Column="1" Text="Cambia Password"
                                   FontSize="15"
                                   TextColor="{StaticResource OnBackground}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"/>

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="🔔" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <Label Grid.Column="1" Text="Preferenze Notifiche"
                                   FontSize="15"
                                   TextColor="{StaticResource OnBackground}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="Prossimamente"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ADMIN-ONLY: Gestione Attività -->
            <VerticalStackLayout Spacing="0" IsVisible="{Binding IsAdmin}">
                <Label Text="GESTIONE ATTIVITÀ"
                       FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       Margin="4,0,0,10"/>

                <Border BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource Outline}"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ManageOpeningHoursCommand}"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="🕐" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Orari di Apertura"
                                       FontSize="15"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="Configura apertura/chiusura per ogni giorno"
                                       FontSize="12"
                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"/>

                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTeamTapped"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="👥" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="Gestisci Team"
                                       FontSize="15"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="Aggiungi o modifica i dipendenti"
                                       FontSize="12"
                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- LOGOUT -->
            <Button Text="Esci dall'account"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Error}"
                    BorderColor="{StaticResource Error}"
                    BorderWidth="1.5"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    Margin="0,8,0,0"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Color="{StaticResource Primary}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
