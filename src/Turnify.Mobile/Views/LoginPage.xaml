<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="210,*">

        <!-- Hero -->
        <Grid Grid.Row="0">
            <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                     VerticalOptions="Fill" HorizontalOptions="Fill"/>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="End"
                                 Spacing="14" Padding="0,0,0,36">
                <Grid WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                    <BoxView CornerRadius="18" BackgroundColor="White" Opacity="0.18"/>
                    <Label Text="⏱" FontSize="32" HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"/>
                </Grid>
                <Label Text="Turnify" FontSize="22" FontFamily="PJSBold"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Sheet card -->
        <Border Grid.Row="1"
                StrokeShape="RoundRectangle CornerRadius='28,28,0,0'"
                StrokeThickness="0"
                Margin="0,-16,0,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <ScrollView>
                <VerticalStackLayout Padding="24,8,24,40" Spacing="0">

                    <!-- Drag handle -->
                    <BoxView WidthRequest="32" HeightRequest="4" CornerRadius="2"
                             HorizontalOptions="Center" Margin="0,10,0,6"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>

                    <!-- Back button -->
                    <Label FontSize="13" FontFamily="PJSSemi"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           HorizontalOptions="Start" Margin="0,4,0,6">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="‹ "/>
                                <Span Text="Cambia ruolo"/>
                            </FormattedString>
                        </Label.FormattedText>
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Title (admin) -->
                    <Label Text="{Binding LoginTitle}"
                           FontSize="20" FontFamily="PJSBold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           Margin="0,4,0,2" CharacterSpacing="-0.3"/>

                    <!-- Subtitle (admin) -->
                    <Label Text="Gestisci la tua azienda"
                           FontSize="13" FontFamily="PJSReg"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           IsVisible="{Binding IsAdminMode}"
                           Margin="0,0,0,16"/>

                    <!-- Subtitle (employee) -->
                    <Label Text="Inserisci il codice della tua azienda"
                           FontSize="13" FontFamily="PJSReg"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           IsVisible="{Binding IsEmployeeMode}"
                           Margin="0,0,0,16"/>

                    <!-- Error banner -->
                    <Border BackgroundColor="{StaticResource ErrorLight}"
                            Stroke="{StaticResource Error}" StrokeThickness="1"
                            Padding="14,10" IsVisible="{Binding HasError}"
                            Margin="0,0,0,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="{Binding ErrorMessage}" FontSize="13" FontFamily="PJSSemi"
                               TextColor="{StaticResource ErrorText}"/>
                    </Border>

                    <VerticalStackLayout Spacing="14">

                        <!-- Admin fields -->
                        <VerticalStackLayout IsVisible="{Binding IsAdminMode}" Spacing="14">

                            <!-- Email input -->
                            <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Label Text="✉" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <Entry Text="{Binding Email}" Placeholder="nome@azienda.it"
                                           Keyboard="Email" FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>

                        </VerticalStackLayout>

                        <!-- Employee fields -->
                        <VerticalStackLayout IsVisible="{Binding IsEmployeeMode}" Spacing="14">

                            <!-- Codice azienda -->
                            <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Label Text="🏢" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <Entry Text="{Binding CompanySlug}" Placeholder="Codice azienda"
                                           FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Username -->
                            <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Label Text="👤" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <Entry Text="{Binding Username}" Placeholder="m.bianchi"
                                           FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>

                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="0">
                            <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    StrokeThickness="2" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="13,0">
                                    <Label Text="🔒" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    <Entry Text="{Binding Password}" Placeholder="••••••••"
                                           IsPassword="True" FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Forgot password (admin only) -->
                            <Label Text="Password dimenticata?"
                                   FontSize="13" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   HorizontalTextAlignment="End" Margin="0,6,0,0"
                                   IsVisible="{Binding IsAdminMode}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToForgotPasswordCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </VerticalStackLayout>

                        <!-- Login button -->
                        <Button Text="Accedi"
                                Command="{Binding LoginCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

                        <!-- Divider -->
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                            <BoxView Grid.Column="0" HeightRequest="1" VerticalOptions="Center"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                            <Label Grid.Column="1" Text="oppure" FontSize="12" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                        </Grid>

                        <!-- Register button -->
                        <Button Text="Registra la tua azienda"
                                Command="{Binding GoToRegisterCommand}"
                                BackgroundColor="Transparent"
                                BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                BorderWidth="1.5"
                                TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"/>

                    </VerticalStackLayout>

                    <Label Text="Continuando accetti i Termini e la Privacy."
                           FontSize="11" FontFamily="PJSReg"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           HorizontalTextAlignment="Center" Margin="0,16,0,0"/>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
