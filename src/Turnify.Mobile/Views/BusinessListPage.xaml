<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.BusinessListPage"
             x:DataType="vm:BusinessListViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,12,16,4">
            <Label Grid.Column="0" Text="Le mie attività"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource OnBackground}"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1" Text="+ Aggiungi"
                    Command="{Binding AddBusinessCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" CornerRadius="20"
                    HeightRequest="38" Padding="14,0" FontSize="14"/>
        </Grid>

        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Businesses}" Margin="16,0,16,16">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" Margin="0,48,0,0" Spacing="12">
                        <Label Text="🏪" FontSize="48" HorizontalOptions="Center"/>
                        <Label Text="Nessuna attività ancora"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="Usa il pulsante + Aggiungi per creare la prima attività."
                               FontSize="14" TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:BusinessDto">
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource Outline}" StrokeThickness="1"
                                Padding="16" Margin="0,0,0,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <VerticalStackLayout Spacing="12">

                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding Name}"
                                               FontSize="17" FontAttributes="Bold"
                                               TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="{Binding BusinessType}"
                                               FontSize="14"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                        <Label Text="{Binding Address}"
                                               FontSize="13"
                                               TextColor="{StaticResource OnSurfaceVariant}"
                                               IsVisible="{Binding Address, Converter={StaticResource StringNotEmptyConverter}}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            BackgroundColor="#E6F4EA" Padding="10,4"
                                            VerticalOptions="Start">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                        <Label Text="{Binding StatusText}"
                                               FontSize="12" FontAttributes="Bold"
                                               TextColor="{StaticResource Success}"/>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Button Grid.Column="0" Text="✏️ Modifica"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BusinessListViewModel}}, Path=EditBusinessCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource Primary}"
                                            BorderColor="{StaticResource Primary}"
                                            BorderWidth="1" CornerRadius="8" HeightRequest="38" FontSize="14"/>
                                    <Button Grid.Column="1" Text="🕐 Orari"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BusinessListViewModel}}, Path=OpenHoursCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Primary}"
                                            TextColor="White"
                                            CornerRadius="8" HeightRequest="38" FontSize="14"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
