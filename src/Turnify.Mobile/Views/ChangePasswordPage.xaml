<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Cambia Password"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="24,24,24,40">

            <!-- Error banner -->
            <Border BackgroundColor="{StaticResource ErrorContainer}"
                    Stroke="{StaticResource Error}" StrokeThickness="1"
                    Padding="14,10" Margin="0,0,0,16"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       FontSize="13" TextColor="{StaticResource OnErrorContainer}"/>
            </Border>

            <!-- Password attuale -->
            <Label Text="PASSWORD ATTUALE" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource Outline}" Margin="4,0,0,8"/>
            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                    Margin="0,0,0,20">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Entry Text="{Binding CurrentPassword}"
                       IsPassword="True"
                       Placeholder="Inserisci la password attuale"
                       PlaceholderColor="{StaticResource Outline}"
                       TextColor="{StaticResource OnBackground}"
                       BackgroundColor="Transparent"
                       HeightRequest="52"
                       Margin="16,0"/>
            </Border>

            <!-- Nuova password -->
            <Label Text="NUOVA PASSWORD" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource Outline}" Margin="4,0,0,8"/>
            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                    Margin="0,0,0,8">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Entry Text="{Binding NewPassword}"
                       IsPassword="True"
                       Placeholder="Min. 8 caratteri, 1 maiuscola, 1 numero"
                       PlaceholderColor="{StaticResource Outline}"
                       TextColor="{StaticResource OnBackground}"
                       BackgroundColor="Transparent"
                       HeightRequest="52"
                       Margin="16,0"/>
            </Border>

            <!-- Conferma password -->
            <Label Text="CONFERMA NUOVA PASSWORD" FontSize="11" FontAttributes="Bold"
                   TextColor="{StaticResource Outline}" Margin="4,0,0,8"/>
            <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                    Margin="0,0,0,32">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Entry Text="{Binding ConfirmPassword}"
                       IsPassword="True"
                       Placeholder="Ripeti la nuova password"
                       PlaceholderColor="{StaticResource Outline}"
                       TextColor="{StaticResource OnBackground}"
                       BackgroundColor="Transparent"
                       HeightRequest="52"
                       Margin="16,0"/>
            </Border>

            <!-- Salva -->
            <Button Text="Aggiorna Password"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White" CornerRadius="14"
                    HeightRequest="52" FontSize="16" FontAttributes="Bold"
                    Margin="0,0,0,12"/>

            <Button Text="Annulla"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource OnSurfaceVariant}"
                    BorderColor="{StaticResource OutlineVariant}"
                    BorderWidth="1" CornerRadius="14"
                    HeightRequest="52" FontSize="16"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" Margin="0,12,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
