<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource DarkBackground}}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0">

            <!-- Hero header -->
            <Grid HeightRequest="200" BackgroundColor="{StaticResource Navy}">
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="6">
                    <Label Text="T"
                           FontSize="32" FontAttributes="Bold" FontFamily="PJSXBold"
                           TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="Crea il tuo account"
                           FontSize="22" FontAttributes="Bold" FontFamily="PJSXBold"
                           TextColor="White" HorizontalOptions="Center"
                           CharacterSpacing="-0.5"/>
                    <Label Text="Registra la tua azienda in pochi secondi"
                           FontSize="13" FontFamily="PJSReg"
                           TextColor="#FFFFFF66" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                    Stroke="Transparent"
                    Margin="0,-20,0,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="20" Padding="24,28,24,48">

                    <!-- Dati Azienda -->
                    <Label Text="DATI AZIENDA" Style="{StaticResource SectionLabel}"/>

                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}" StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <!-- Nome azienda -->
                            <VerticalStackLayout Spacing="6" Padding="16,16,16,0">
                                <Label Text="NOME AZIENDA" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding CompanyName}"
                                           Placeholder="Es. Bar Centrale"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                            <!-- Slug -->
                            <VerticalStackLayout Spacing="6" Padding="16,14,16,0">
                                <Label Text="SLUG IDENTIFICATIVO" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding CompanySlug}"
                                           Placeholder="es. bar-centrale"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                            <!-- Email aziendale -->
                            <VerticalStackLayout Spacing="6" Padding="16,14,16,16">
                                <Label Text="EMAIL AZIENDALE" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding CompanyEmail}"
                                           Placeholder="info@barcentrale.it"
                                           Keyboard="Email"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Account Admin -->
                    <Label Text="ACCOUNT AMMINISTRATORE" Style="{StaticResource SectionLabel}"/>

                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                            Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}" StrokeThickness="1"
                            Padding="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="0">
                            <VerticalStackLayout Spacing="6" Padding="16,16,16,0">
                                <Label Text="EMAIL ADMIN" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding AdminEmail}"
                                           Placeholder="admin@barcentrale.it"
                                           Keyboard="Email"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6" Padding="16,14,16,0">
                                <Label Text="PASSWORD" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding AdminPassword}"
                                           Placeholder="Min. 8 caratteri"
                                           IsPassword="True"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6" Padding="16,14,16,16">
                                <Label Text="CONFERMA PASSWORD" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding ConfirmPassword}"
                                           Placeholder="Ripeti la password"
                                           IsPassword="True"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <Button Text="Registrati"
                            Command="{Binding RegisterCommand}"
                            Style="{StaticResource PrimaryButton}"/>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center"
                                       Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                        <Label Text="Hai già un account?"
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"
                               VerticalOptions="Center"/>
                        <Label Text="Accedi"
                               FontSize="14" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
