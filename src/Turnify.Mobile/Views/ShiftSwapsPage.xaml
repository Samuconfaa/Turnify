<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             xmlns:comp="clr-namespace:Turnify.Mobile.Views.Components"
             x:Class="Turnify.Mobile.Views.ShiftSwapsPage"
             x:DataType="vm:ShiftSwapsViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,Auto,*">

        <comp:StaleDataBanner Grid.Row="0"/>

        <!-- ── Header ──────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <!-- Back (Shell.GoToAsync handles navigation; no GoBackCommand in VM) -->
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="‹" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="{Binding Title}" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
            <BoxView Grid.Column="2" WidthRequest="32" HeightRequest="32" Color="Transparent"/>
        </Grid>

        <!-- ── Scrollable content ──────────────────────────────── -->
        <RefreshView Grid.Row="2" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding Swaps}" IsVisible="{Binding HasData}" SelectionMode="None">

                <CollectionView.Header>
                    <VerticalStackLayout Padding="16,16,16,4" Spacing="10">

                        <!-- Activity indicator (loading) -->
                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center" Margin="0,20,0,0"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

                        <!-- Error state -->
                        <VerticalStackLayout IsVisible="{Binding HasError}" Spacing="8" Margin="0,20,0,0">
                            <Label Text="⚠️" FontSize="36" HorizontalOptions="Center"/>
                            <Label Text="{Binding ErrorMessage}" FontFamily="PJSReg" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource ErrorText}, Dark={StaticResource ErrorTextDark}}"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <!-- Empty state -->
                        <VerticalStackLayout IsVisible="{Binding IsEmptyState}" Spacing="10" Margin="0,32,0,0">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                    HeightRequest="68" WidthRequest="68" HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                <Label Text="🔄" FontSize="34"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="Nessuno scambio turno" FontFamily="PJSSemi" FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Le proposte di scambio ricevute e inviate appariranno qui."
                                   FontFamily="PJSReg" FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="20,0"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ShiftSwapsViewModel+SwapDto">
                        <Border StrokeShape="RoundRectangle CornerRadius='16'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="14" Margin="16,0,16,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                            <VerticalStackLayout Spacing="0">

                                <!-- Status + date row -->
                                <HorizontalStackLayout Spacing="8" Margin="0,0,0,10">
                                    <Border StrokeShape="RoundRectangle CornerRadius='8'"
                                            StrokeThickness="0" Padding="8,4"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource WarningBg}, Dark={StaticResource WarningBgDark}}">
                                        <Label Text="{Binding StatusDisplay}" FontSize="12" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"/>
                                    </Border>
                                    <Label Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yy}'}"
                                           FontSize="11" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           HorizontalOptions="EndAndExpand" VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <!-- Shift A party -->
                                <HorizontalStackLayout Spacing="6">
                                    <Border WidthRequest="36" HeightRequest="36"
                                            StrokeShape="RoundRectangle CornerRadius='18'"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                        <Label FontSize="12" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="T"/>
                                                    <Span Text="{Binding ShiftAId}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Border>
                                    <Label FontSize="13" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Turno "/>
                                                <Span Text="{Binding ShiftAId}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>

                                <!-- Swap arrow -->
                                <HorizontalStackLayout Spacing="8" Padding="6,8">
                                    <Label Text="⇄" FontSize="18"
                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    <BoxView HeightRequest="1" HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                             BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>
                                </HorizontalStackLayout>

                                <!-- Shift B party -->
                                <HorizontalStackLayout Spacing="6">
                                    <Border WidthRequest="36" HeightRequest="36"
                                            StrokeShape="RoundRectangle CornerRadius='18'"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource WarningBg}, Dark={StaticResource WarningBgDark}}">
                                        <Label FontSize="12" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"
                                               HorizontalOptions="Center" VerticalOptions="Center">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="T"/>
                                                    <Span Text="{Binding ShiftBId}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Border>
                                    <Label FontSize="13" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Turno "/>
                                                <Span Text="{Binding ShiftBId}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>

                                <!-- Note (if present) -->
                                <Label Text="{Binding Note}" FontFamily="PJSReg" FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       Margin="0,8,0,0"
                                       IsVisible="{Binding Note, Converter={StaticResource StringNotEmptyConverter}}"/>

                                <!-- Peer accept/reject buttons (IsPending) -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,12,0,0"
                                      IsVisible="{Binding IsPending}">
                                    <Button Grid.Column="0" Text="Accetta"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=AcceptCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                            TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                            CornerRadius="10" HeightRequest="34"
                                            FontFamily="PJSSemi" FontSize="13"/>
                                    <Button Grid.Column="1" Text="Rifiuta"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=RejectCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            BorderColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                            BorderWidth="1"
                                            TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                            CornerRadius="10" HeightRequest="34"
                                            FontFamily="PJSSemi" FontSize="13"/>
                                </Grid>

                                <!-- Admin approve/reject buttons (IsAcceptedByPeer) -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,12,0,0"
                                      IsVisible="{Binding IsAcceptedByPeer}">
                                    <Button Grid.Column="0" Text="Approva"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=AdminApproveCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                            TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                            CornerRadius="10" HeightRequest="34"
                                            FontFamily="PJSSemi" FontSize="13"/>
                                    <Button Grid.Column="1" Text="Blocca"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=AdminRejectCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            BorderColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                            BorderWidth="1"
                                            TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                            CornerRadius="10" HeightRequest="34"
                                            FontFamily="PJSSemi" FontSize="13"/>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
