<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.BusinessListPage"
             x:DataType="vm:BusinessListViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="20,18,20,12">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Attività"
                       FontSize="26" FontAttributes="Bold" FontFamily="PJSXBold"
                       TextColor="{StaticResource OnBackground}"
                       CharacterSpacing="-0.8"/>
                <Label Text="Le mie sedi"
                       FontSize="13" FontFamily="PJSReg"
                       TextColor="{StaticResource Outline}"/>
            </VerticalStackLayout>
            <Border Grid.Column="1"
                    BackgroundColor="{StaticResource Navy}"
                    Stroke="Transparent" Padding="16,10"
                    VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddBusinessCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="+ Aggiungi"
                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                       TextColor="White"/>
            </Border>
        </Grid>

        <!-- List -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Businesses}"
                            Margin="20,0,20,20">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,48,0,0" Spacing="14">
                        <Border BackgroundColor="{StaticResource Surface}"
                                HeightRequest="68" WidthRequest="68"
                                HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Label Text="🏪" FontSize="34"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Nessuna attività ancora"
                               FontSize="18" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="Usa + Aggiungi per creare la prima attività."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:BusinessDto">
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                                Padding="16" Margin="0,0,0,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.06"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontSize="17" FontAttributes="Bold" FontFamily="PJSBold"
                                               TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="{Binding BusinessType}"
                                               FontSize="13" FontFamily="PJSReg"
                                               TextColor="{StaticResource OnSurfaceVariant}"/>
                                        <Label Text="{Binding Address}"
                                               FontSize="12" FontFamily="PJSReg"
                                               TextColor="{StaticResource Outline}"
                                               IsVisible="{Binding Address, Converter={StaticResource StringNotEmptyConverter}}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource SuccessLight}"
                                            Stroke="Transparent" Padding="10,5"
                                            VerticalOptions="Start">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                        <Label Text="{Binding StatusText}"
                                               FontSize="10" FontAttributes="Bold" FontFamily="PJSBold"
                                               TextColor="{StaticResource SuccessText}"/>
                                    </Border>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Button Grid.Column="0" Text="Modifica"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BusinessListViewModel}}, Path=EditBusinessCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource Primary}"
                                            BorderColor="{StaticResource PrimaryMid}"
                                            BorderWidth="1.5" CornerRadius="10"
                                            HeightRequest="40" FontSize="13"
                                            FontAttributes="Bold" FontFamily="PJSBold"/>
                                    <Button Grid.Column="1" Text="Orari"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BusinessListViewModel}}, Path=OpenHoursCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Navy}"
                                            TextColor="White"
                                            CornerRadius="10" HeightRequest="40"
                                            FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
