<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Turnify.Mobile.Converters"
             x:Class="Turnify.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToShiftColorConverter   x:Key="BoolToShiftColorConverter"/>
            <converters:InverseBoolConverter         x:Key="InverseBoolConverter"/>
            <converters:StringNotEmptyConverter      x:Key="StringNotEmptyConverter"/>
            <converters:StatusIsPendingConverter     x:Key="StatusIsPendingConverter"/>
            <converters:InvertedBoolConverter        x:Key="InvertedBoolConverter"/>
            <converters:IntIsZeroConverter           x:Key="IntIsZeroConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
