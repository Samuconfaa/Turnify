<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             xmlns:comp="clr-namespace:Turnify.Mobile.Views.Components"
             x:Class="Turnify.Mobile.Views.EmployeeListPage"
             x:DataType="vm:EmployeeListViewModel"
             Title="Team"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource DarkBackground}}">

    <Grid RowDefinitions="Auto,Auto,*">
        <comp:StaleDataBanner Grid.Row="0"/>

        <!-- ── Gradient header ──────────────────────────────── -->
        <Grid Grid.Row="1" Padding="20,54,20,16" MinimumHeightRequest="80">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{AppThemeBinding Light={StaticResource HeaderGradientStart}, Dark={StaticResource DarkHeaderGradientStart}}" Offset="0"/>
                    <GradientStop Color="{AppThemeBinding Light={StaticResource HeaderGradientEnd}, Dark={StaticResource DarkHeaderGradientEnd}}" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <VerticalStackLayout Spacing="12">
                <Label Text="Team" FontSize="26" FontAttributes="Bold" FontFamily="PJSXBold"
                       TextColor="White" CharacterSpacing="-0.8"/>
                <!-- Search bar -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}" Stroke="Transparent">
                    <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="0">
                        <Image Grid.Column="0" Source="search.svg" HeightRequest="18" WidthRequest="18"
                               VerticalOptions="Center" Margin="14,0,0,0"/>
                        <SearchBar Grid.Column="1" Text="{Binding SearchQuery}"
                                   Placeholder="Cerca per nome, ruolo…"
                                   HeightRequest="48" BackgroundColor="Transparent"
                                   CancelButtonColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"
                                   TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"
                                   FontFamily="PJSReg"/>
                    </Grid>
                </Border>
                <!-- Business filter -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}" Stroke="Transparent">
                    <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                    <Picker ItemsSource="{Binding Businesses}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedBusiness}"
                            Title="Tutte le attività"
                            TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                            TitleColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"
                            FontFamily="PJSReg" Margin="16,0"/>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Employee list ─────────────────────────────── -->
        <RefreshView Grid.Row="2" Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Employees}" Margin="0,8,0,0"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" Margin="32,52,32,0" Spacing="14">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                                HeightRequest="68" WidthRequest="68" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Image Source="users_group.svg" HeightRequest="34" WidthRequest="34"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Nessun dipendente ancora" FontSize="17" FontAttributes="Bold"
                               FontFamily="PJSBold" TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Aggiungi il tuo primo dipendente per iniziare a gestire i turni."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="8,0"/>
                        <Button Text="Aggiungi dipendente"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=AddEmployeeCommand}"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalOptions="Center" Padding="24,0" WidthRequest="240"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <VerticalStackLayout>
                        <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                           IsVisible="{Binding IsLoadingMore}"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"
                                           Margin="0,8,0,4" />
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLow}, Dark={StaticResource DarkSurfaceContainerLow}}"
                            Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" StrokeThickness="1.5"
                            StrokeDashArray="6,4"
                            Padding="16,20" Margin="20,0,20,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CreateEmployeeCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Image Source="plus_circle.svg" HeightRequest="20" WidthRequest="20"
                                   VerticalOptions="Center"/>
                            <Label Text="Aggiungi un utente" FontSize="15" FontAttributes="Bold"
                                   FontFamily="PJSBold" TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                    </VerticalStackLayout>
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EmployeeListDto">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}" StrokeThickness="1"
                                Margin="20,0,20,8">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="14" Opacity="0.05"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=EditEmployeeCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="14,14" ColumnSpacing="14">
                                <!-- Avatar -->
                                <Border Grid.Column="0" BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource DarkPrimaryContainer}}"
                                        Stroke="Transparent" HeightRequest="48" WidthRequest="48"
                                        VerticalOptions="Center">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceContainerLow}, Dark={StaticResource DarkSurfaceContainerLow}}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Initials}" FontSize="15"
                                           FontAttributes="Bold" FontFamily="PJSBold"
                                           TextColor="{StaticResource OnPrimaryContainer}"
                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <Label Text="{Binding FullName}" FontSize="14"
                                           FontAttributes="Bold" FontFamily="PJSBold"
                                           TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"/>
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Role}" FontSize="12" FontFamily="PJSReg"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"/>
                                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainerLow}, Dark={StaticResource DarkSurfaceContainerLow}}"
                                                Stroke="Transparent" Padding="7,3" VerticalOptions="Center"
                                                IsVisible="{Binding ContractType, Converter={StaticResource StringNotEmptyConverter}}">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="5"/></Border.StrokeShape>
                                            <Label Text="{Binding ContractType}" FontSize="10"
                                                   FontAttributes="Bold" FontFamily="PJSBold"
                                                   TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Chevron + status -->
                                <Grid Grid.Column="2" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto"
                                      RowSpacing="6" VerticalOptions="Center">
                                    <Border Grid.Row="0" BackgroundColor="{StaticResource SuccessLight}"
                                            Stroke="Transparent" Padding="9,5">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceContainerLow}, Dark={StaticResource DarkSurfaceContainerLow}}"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding StatusText}" FontSize="10"
                                               FontAttributes="Bold" FontFamily="PJSBold"
                                               TextColor="{StaticResource SuccessText}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                    <Image Grid.Row="1" Source="chevron_right.svg"
                                           HeightRequest="16" WidthRequest="16"
                                           HorizontalOptions="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
