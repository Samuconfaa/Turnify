<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.AvailabilityPage"
             x:DataType="vm:AvailabilityViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="&#8249;" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Disponibilit&#224;" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="16">

                <!-- Info banner -->
                <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="0"
                        Padding="14"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                    <HorizontalStackLayout Spacing="12">
                        <Border WidthRequest="36" HeightRequest="36"
                                StrokeShape="RoundRectangle CornerRadius='10'"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                            <Label Text="&#10022;" FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="FillAndExpand">
                            <Label Text="Indica i giorni in cui sei disponibile" FontSize="13" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"/>
                            <Label Text="Il manager user&#224; queste preferenze per pianificare i tuoi turni settimanali."
                                   FontSize="12" FontFamily="PJSReg" LineHeight="1.4"
                                   TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"
                                   Opacity="0.88"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- Days card -->
                <Border StrokeShape="RoundRectangle CornerRadius='16'" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <!-- Luned&#236; -->
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="Luned&#236;" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" FontSize="12" FontFamily="PJSSemi"
                                   VerticalOptions="Center" Margin="0,0,12,0">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Monday}" Value="True">
                                        <Setter Property="Text" Value="S&#236;"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Monday}" Value="False">
                                        <Setter Property="Text" Value="No"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Switch Grid.Column="2" IsToggled="{Binding Monday}" VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Margin="16,0"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>

                        <!-- Marted&#236; -->
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="Marted&#236;" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" FontSize="12" FontFamily="PJSSemi"
                                   VerticalOptions="Center" Margin="0,0,12,0">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Tuesday}" Value="True">
                                        <Setter Property="Text" Value="S&#236;"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Tuesday}" Value="False">
                                        <Setter Property="Text" Value="No"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Switch Grid.Column="2" IsToggled="{Binding Tuesday}" VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Margin="16,0"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>

                        <!-- Mercoled&#236; -->
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="Mercoled&#236;" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" FontSize="12" FontFamily="PJSSemi"
                                   VerticalOptions="Center" Margin="0,0,12,0">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Wednesday}" Value="True">
                                        <Setter Property="Text" Value="S&#236;"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Wednesday}" Value="False">
                                        <Setter Property="Text" Value="No"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Switch Grid.Column="2" IsToggled="{Binding Wednesday}" VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Margin="16,0"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>

                        <!-- Gioved&#236; -->
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="Gioved&#236;" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" FontSize="12" FontFamily="PJSSemi"
                                   VerticalOptions="Center" Margin="0,0,12,0">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Thursday}" Value="True">
                                        <Setter Property="Text" Value="S&#236;"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Thursday}" Value="False">
                                        <Setter Property="Text" Value="No"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Switch Grid.Column="2" IsToggled="{Binding Thursday}" VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Margin="16,0"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>

                        <!-- Venerd&#236; -->
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="Venerd&#236;" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" FontSize="12" FontFamily="PJSSemi"
                                   VerticalOptions="Center" Margin="0,0,12,0">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Friday}" Value="True">
                                        <Setter Property="Text" Value="S&#236;"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Friday}" Value="False">
                                        <Setter Property="Text" Value="No"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Switch Grid.Column="2" IsToggled="{Binding Friday}" VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Margin="16,0"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>

                        <!-- Sabato (amber accent) -->
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="Sabato" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource KpiAmber}, Dark={StaticResource KpiAmberDark}}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" FontSize="12" FontFamily="PJSSemi"
                                   VerticalOptions="Center" Margin="0,0,12,0">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Saturday}" Value="True">
                                        <Setter Property="Text" Value="S&#236;"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Saturday}" Value="False">
                                        <Setter Property="Text" Value="No"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Switch Grid.Column="2" IsToggled="{Binding Saturday}" VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>
                        <BoxView HeightRequest="1" Margin="16,0"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>

                        <!-- Domenica (danger accent) -->
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,14">
                            <Label Grid.Column="0" Text="Domenica" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" FontSize="12" FontFamily="PJSSemi"
                                   VerticalOptions="Center" Margin="0,0,12,0">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Sunday}" Value="True">
                                        <Setter Property="Text" Value="S&#236;"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding Sunday}" Value="False">
                                        <Setter Property="Text" Value="No"/>
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Switch Grid.Column="2" IsToggled="{Binding Sunday}" VerticalOptions="Center"
                                    OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Save button -->
                <Button Text="Salva disponibilit&#224;"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                        CornerRadius="12" HeightRequest="50"
                        FontFamily="PJSSemi" FontSize="15"/>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
