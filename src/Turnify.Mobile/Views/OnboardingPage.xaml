<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.OnboardingPage"
             x:DataType="vm:OnboardingViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="56,*,Auto">

        <!-- ── Header bar ────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{StaticResource HeaderGradientStart}" Offset="0"/>
                    <GradientStop Color="{StaticResource HeaderGradientEnd}" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid ColumnDefinitions="56,*,56" Padding="0">
                <Button Grid.Column="0" Text="‹"
                        Command="{Binding PreviousStepCommand}"
                        IsVisible="{Binding IsStep1, Converter={StaticResource InverseBoolConverter}}"
                        BackgroundColor="Transparent"
                        TextColor="#FFFFFFCC"
                        FontSize="24" FontFamily="PJSBold"
                        Padding="0"/>

                <!-- Progress dots -->
                <HorizontalStackLayout Grid.Column="1"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Spacing="8">
                    <Border HeightRequest="8" WidthRequest="8"
                            BackgroundColor="#FFFFFF55" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding Step1Dot}" Value="True">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="WidthRequest" Value="22"/>
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border HeightRequest="8" WidthRequest="8"
                            BackgroundColor="#FFFFFF55" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding Step2Dot}" Value="True">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="WidthRequest" Value="22"/>
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border HeightRequest="8" WidthRequest="8"
                            BackgroundColor="#FFFFFF55" Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="4"/></Border.StrokeShape>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding Step3Dot}" Value="True">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="WidthRequest" Value="22"/>
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                </HorizontalStackLayout>

                <Label Grid.Column="2"
                       Text="Salta"
                       FontSize="14" FontAttributes="Bold" FontFamily="PJSSemi"
                       TextColor="#FFFFFFCC"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SkipOnboardingCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Grid>

        <!-- ── Step content ──────────────────────────────────── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- ── STEP 1 – Benvenuto ── -->
                <VerticalStackLayout IsVisible="{Binding IsStep1}"
                                     Spacing="24" Padding="20,36,20,20">
                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="24">
                        <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="20" Opacity="0.07"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="24">
                            <!-- Logo badge -->
                            <Border BackgroundColor="{StaticResource Primary}"
                                    HeightRequest="80" WidthRequest="80"
                                    HorizontalOptions="Center">
                                <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="16" Opacity="0.35"/>
                                </Border.Shadow>
                                <Label Text="T"
                                       FontSize="36" FontAttributes="Bold" FontFamily="PJSXBold"
                                       TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="Benvenuto in Turnify!"
                                       FontSize="24" FontAttributes="Bold" FontFamily="PJSXBold"
                                       TextColor="{StaticResource OnBackground}"
                                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                       CharacterSpacing="-0.5"/>
                                <Label Text="Configura la tua azienda in 3 semplici passi. Ci vogliono meno di 2 minuti."
                                       FontSize="15" FontFamily="PJSReg"
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                            <!-- Feature rows -->
                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                        Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                                        Padding="14,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <HorizontalStackLayout Spacing="14">
                                        <Border BackgroundColor="{StaticResource PrimaryLight}"
                                                HeightRequest="36" WidthRequest="36" Stroke="Transparent">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Image Source="calendar_check.svg" HeightRequest="20" WidthRequest="20"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                            <Label Text="Gestione Turni Automatica"
                                                   FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                                   TextColor="{StaticResource OnBackground}"/>
                                            <Label Text="Ottimizza i tempi con scheduling intelligente."
                                                   FontSize="12" FontFamily="PJSReg"
                                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Border>
                                <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                        Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                                        Padding="14,12">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <HorizontalStackLayout Spacing="14">
                                        <Border BackgroundColor="{StaticResource SuccessLight}"
                                                HeightRequest="36" WidthRequest="36" Stroke="Transparent">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Image Source="users_group.svg" HeightRequest="20" WidthRequest="20"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                            <Label Text="Team Management"
                                                   FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                                   TextColor="{StaticResource OnBackground}"/>
                                            <Label Text="Tieni traccia di disponibilità e ferie."
                                                   FontSize="12" FontFamily="PJSReg"
                                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ── STEP 2 – La tua attività ── -->
                <VerticalStackLayout IsVisible="{Binding IsStep2}"
                                     Spacing="20" Padding="20,32,20,20">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="La tua attività"
                               FontSize="24" FontAttributes="Bold" FontFamily="PJSXBold"
                               TextColor="{StaticResource OnBackground}"
                               CharacterSpacing="-0.5"/>
                        <Label Text="Inserisci i dati base della tua attività"
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{StaticResource OnSurfaceVariant}"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="14">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="NOME ATTIVITÀ" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Text="{Binding BusinessName}" Placeholder="Es. Pizzeria Roma"
                                       Style="{StaticResource FieldEntry}"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="TIPO ATTIVITÀ" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Picker ItemsSource="{Binding BusinessTypes}"
                                        SelectedItem="{Binding BusinessType}"
                                        Title="Seleziona tipo"
                                        FontFamily="PJSReg"
                                        TextColor="{StaticResource OnBackground}"
                                        TitleColor="{StaticResource Outline}"
                                        Margin="10,0"/>
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="INDIRIZZO" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                            <Border Style="{StaticResource FieldBorder}">
                                <Entry Text="{Binding BusinessAddress}" Placeholder="Via Roma 1, Milano"
                                       Style="{StaticResource FieldEntry}"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Border BackgroundColor="{StaticResource PrimaryLight}"
                            Stroke="{StaticResource PrimaryMid}" StrokeThickness="1"
                            Padding="14,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="12">
                            <Border BackgroundColor="{StaticResource Primary}"
                                    HeightRequest="34" WidthRequest="34" Stroke="Transparent">
                                <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                                <Label Text="i" FontSize="16" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Fill">
                                <Label Text="Perché queste informazioni?"
                                       FontSize="12" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="{StaticResource Primary}"/>
                                <Label Text="Personalizzano la tua dashboard e i report."
                                       FontSize="12" FontFamily="PJSReg"
                                       TextColor="{StaticResource Primary}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ── STEP 3 – Primo dipendente ── -->
                <VerticalStackLayout IsVisible="{Binding IsStep3}"
                                     Spacing="20" Padding="20,32,20,20">
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Il tuo primo dipendente"
                               FontSize="24" FontAttributes="Bold" FontFamily="PJSXBold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               CharacterSpacing="-0.5"/>
                        <Label Text="Aggiungi almeno un dipendente per iniziare a creare turni"
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.06"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="NOME" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding EmployeeFirstName}" Placeholder="Es. Mario"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="COGNOME" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding EmployeeLastName}" Placeholder="Es. Rossi"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="EMAIL" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding EmployeeEmail}" Placeholder="mario.rossi@azienda.it"
                                           Keyboard="Email" Style="{StaticResource FieldEntry}"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="PASSWORD TEMPORANEA" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
                                <Border Style="{StaticResource FieldBorder}">
                                    <Entry Text="{Binding EmployeePassword}" IsPassword="True"
                                           Style="{StaticResource FieldEntry}"/>
                                </Border>
                                <Label Text="Il dipendente potrà cambiarla al primo accesso."
                                       FontSize="11" FontFamily="PJSReg"
                                       TextColor="{StaticResource Outline}" Margin="4,0,0,0"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Footer buttons ────────────────────────────────── -->
        <Grid Grid.Row="2" BackgroundColor="{StaticResource Background}"
              Padding="20,12,20,32">

            <!-- Step 1 -->
            <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="10">
                <Button Text="Inizia →"
                        Command="{Binding GoToStep2Command}"
                        Style="{StaticResource PrimaryButton}">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="16" Opacity="0.30"/>
                    </Button.Shadow>
                </Button>
                <Button Text="Salta per ora"
                        Command="{Binding SkipOnboardingCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Outline}"
                        FontSize="13" FontFamily="PJSReg"
                        HeightRequest="36"/>
            </VerticalStackLayout>

            <!-- Step 2 -->
            <Button IsVisible="{Binding IsStep2}"
                    Text="Avanti →"
                    Command="{Binding SaveBusinessAndContinueCommand}"
                    Style="{StaticResource PrimaryButton}">
                <Button.Shadow>
                    <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="16" Opacity="0.30"/>
                </Button.Shadow>
            </Button>

            <!-- Step 3 -->
            <VerticalStackLayout IsVisible="{Binding IsStep3}" Spacing="10">
                <Button Text="Completa configurazione"
                        Command="{Binding SaveEmployeeAndCompleteCommand}"
                        Style="{StaticResource PrimaryButton}">
                    <Button.Shadow>
                        <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="16" Opacity="0.30"/>
                    </Button.Shadow>
                </Button>
                <Button Text="Aggiungi dopo"
                        Command="{Binding SkipEmployeeCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Outline}"
                        FontSize="13" FontFamily="PJSReg"
                        HeightRequest="36"/>
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" Color="{StaticResource Primary}"/>
        </Grid>

    </Grid>
</ContentPage>
