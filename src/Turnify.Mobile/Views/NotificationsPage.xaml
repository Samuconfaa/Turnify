<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.NotificationsPage"
             x:DataType="vm:NotificationsViewModel"
             Title="Notifiche"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource OutlineVariant}" StrokeThickness="0,0,0,1"
                Padding="20,16,20,14">
            <Border.StrokeShape><RoundRectangle CornerRadius="0"/></Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto">
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Label Text="Notifiche"
                           FontSize="24" FontAttributes="Bold" FontFamily="PJSXBold"
                           TextColor="{StaticResource OnBackground}"
                           CharacterSpacing="-0.8"/>
                    <Border BackgroundColor="{StaticResource Primary}"
                            Stroke="Transparent" Padding="9,4"
                            IsVisible="{Binding UnreadCount, Converter={StaticResource IntIsZeroConverter}, ConverterParameter=invert}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="{Binding UnreadCount, StringFormat='{0} non lette'}"
                               FontSize="10" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="White"/>
                    </Border>
                </HorizontalStackLayout>
                <Label Grid.Column="1"
                       Text="Segna tutte lette"
                       FontSize="13" FontAttributes="Bold" FontFamily="PJSSemi"
                       TextColor="{StaticResource Primary}"
                       VerticalOptions="Center"
                       IsVisible="{Binding UnreadCount, Converter={StaticResource IntIsZeroConverter}, ConverterParameter=invert}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MarkAllReadCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Border>

        <!-- Error -->
        <Border Grid.Row="1"
                IsVisible="{Binding HasError}"
                BackgroundColor="{StaticResource ErrorLight}"
                Stroke="{StaticResource Error}" StrokeThickness="1"
                Padding="16" Margin="20,16,20,0"
                VerticalOptions="Start">
            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
            <Label Text="{Binding ErrorMessage}"
                   FontSize="13" FontFamily="PJSSemi"
                   TextColor="{StaticResource ErrorText}"/>
        </Border>

        <!-- List -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Notifications}" Margin="0,6,0,0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,60,0,0" Spacing="14"
                                         IsVisible="{Binding HasError, Converter={StaticResource InverseBoolConverter}}">
                        <Border BackgroundColor="{StaticResource Surface}"
                                HeightRequest="68" WidthRequest="68"
                                HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Label Text="🔔" FontSize="34"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Nessuna notifica"
                               FontSize="18" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="Le notifiche sui tuoi turni e ferie appariranno qui."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               Margin="32,0"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:NotificationDto">
                        <Border BackgroundColor="{Binding BackgroundColor}"
                                Stroke="Transparent"
                                Padding="16,14" Margin="12,0,12,4">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=MarkReadCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <!-- Icon -->
                                <Border Grid.Column="0"
                                        BackgroundColor="{StaticResource PrimaryLight}"
                                        HeightRequest="44" WidthRequest="44"
                                        VerticalOptions="Start"
                                        Stroke="Transparent">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                                    <Label Text="{Binding Icon}"
                                           FontSize="20"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Border>

                                <!-- Content -->
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontSize="14" FontAttributes="Bold" FontFamily="PJSBold"
                                           TextColor="{StaticResource OnBackground}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Body}"
                                           FontSize="13" FontFamily="PJSReg"
                                           TextColor="{StaticResource OnSurfaceVariant}"
                                           LineBreakMode="WordWrap"/>
                                    <Label Text="{Binding TimeAgo}"
                                           FontSize="11" FontFamily="PJSReg"
                                           TextColor="{StaticResource Outline}"
                                           Margin="0,2,0,0"/>
                                </VerticalStackLayout>

                                <!-- Unread dot -->
                                <Ellipse Grid.Column="2"
                                         Fill="{StaticResource Primary}"
                                         HeightRequest="8" WidthRequest="8"
                                         VerticalOptions="Start"
                                         Margin="0,6,0,0">
                                    <Ellipse.Triggers>
                                        <DataTrigger TargetType="Ellipse" Binding="{Binding IsRead}" Value="True">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </DataTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Color="{StaticResource Primary}"/>
    </Grid>
</ContentPage>
