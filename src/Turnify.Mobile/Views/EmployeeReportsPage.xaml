<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.EmployeeReportsPage"
             x:DataType="vm:EmployeeReportsViewModel"
             Title="Report ore"
             BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource DarkBackground}}">

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Padding="20,18,20,4" Spacing="2">
            <Label Text="Report ore"
                   FontSize="26" FontAttributes="Bold" FontFamily="PJSXBold"
                   TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                   CharacterSpacing="-0.8"/>
            <Label Text="Ore pianificate per dipendente"
                   FontSize="13" FontFamily="PJSReg"
                   TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"/>
        </VerticalStackLayout>

        <!-- Filtri -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}" StrokeThickness="1"
                Padding="16,12" Margin="20,8,20,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="DAL" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <DatePicker Date="{Binding From}"
                                        TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                                        FontFamily="PJSReg" Margin="16,0"/>
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="AL" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource FieldBorder}">
                            <DatePicker Date="{Binding To}"
                                        TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                                        FontFamily="PJSReg" Margin="16,0"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
                <VerticalStackLayout Spacing="4">
                    <Label Text="RAGGRUPPA PER" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource FieldBorder}">
                        <Picker ItemsSource="{Binding GroupByOptions}"
                                SelectedItem="{Binding SelectedGroupBy}"
                                TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                                FontFamily="PJSReg" Margin="16,0"/>
                    </Border>
                </VerticalStackLayout>
                <Button Text="Carica report"
                        Command="{Binding LoadReportsCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </VerticalStackLayout>
        </Border>

        <!-- Error -->
        <Border Grid.Row="2" IsVisible="{Binding HasError}"
                BackgroundColor="{StaticResource ErrorLight}"
                Stroke="{StaticResource Error}" StrokeThickness="1"
                Padding="12,8" Margin="20,8,20,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
            <Label Text="{Binding ErrorMessage}"
                   FontSize="13" FontFamily="PJSSemi"
                   TextColor="{StaticResource ErrorText}"/>
        </Border>

        <!-- Lista -->
        <RefreshView Grid.Row="3"
                     Command="{Binding LoadReportsCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Reports}"
                            Margin="20,8,20,20">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,48,0,0" Spacing="12"
                                         IsVisible="{Binding IsEmptyState}">
                        <Label Text="Nessun dato disponibile"
                               FontSize="17" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Seleziona un intervallo di date e premi Carica report."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               Margin="8,0"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EmployeeHoursReportDto">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}" StrokeThickness="1"
                                Padding="0" Margin="0,0,0,10">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,3" Radius="12" Opacity="0.05"/>
                            </Border.Shadow>
                            <VerticalStackLayout>
                                <!-- Header riga dipendente -->
                                <Grid ColumnDefinitions="*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeReportsViewModel}}, Path=ToggleExpandCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>
                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding EmployeeName}"
                                               FontSize="15" FontAttributes="Bold" FontFamily="PJSBold"
                                               TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"/>
                                        <Label Text="{Binding TotalHoursDisplay}"
                                               FontSize="13" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="›"
                                           FontSize="20" FontFamily="PJSBold"
                                           TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"
                                           VerticalOptions="Center"/>
                                </Grid>

                                <!-- Breakdown espandibile -->
                                <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                     Padding="16,0,16,12" Spacing="6">
                                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}" Margin="0,0,0,6"/>
                                    <CollectionView ItemsSource="{Binding Breakdown}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:HoursBreakdownDto">
                                                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                                    <Label Grid.Column="0" Text="{Binding Period}"
                                                           FontSize="13" FontFamily="PJSReg"
                                                           TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"/>
                                                    <Label Grid.Column="1" Text="{Binding HoursDisplay}"
                                                           FontSize="13" FontAttributes="Bold" FontFamily="PJSSemi"
                                                           TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Start"
                           Margin="0,20,0,0"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>
    </Grid>
</ContentPage>
