<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             xmlns:comp="clr-namespace:Turnify.Mobile.Views.Components"
             x:Class="Turnify.Mobile.Views.ShiftSwapsPage"
             x:DataType="vm:ShiftSwapsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">
        <comp:StaleDataBanner Grid.Row="0"/>
        <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}"
                 IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="16,12,16,40">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" Margin="0,30,0,0"
                                   Color="{StaticResource Primary}"/>

                <!-- Error -->
                <VerticalStackLayout IsVisible="{Binding HasError}" Spacing="8" Margin="0,30,0,0">
                    <Label Text="⚠️" FontSize="36" HorizontalOptions="Center"/>
                    <Label Text="{Binding ErrorMessage}" FontFamily="PJSReg" FontSize="14"
                           TextColor="{StaticResource Error}" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Empty -->
                <VerticalStackLayout IsVisible="{Binding IsEmptyState}" Spacing="8" Margin="0,40,0,0">
                    <Label Text="🔄" FontSize="44" HorizontalOptions="Center"/>
                    <Label Text="Nessuno scambio turno" FontFamily="PJSSemi" FontSize="16"
                           TextColor="{StaticResource OnBackground}" HorizontalOptions="Center"/>
                    <Label Text="Le proposte di scambio ricevute e inviate appariranno qui."
                           FontFamily="PJSReg" FontSize="13" TextColor="{StaticResource Outline}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="20,0"/>
                </VerticalStackLayout>

                <!-- List -->
                <CollectionView ItemsSource="{Binding Swaps}" IsVisible="{Binding HasData}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ShiftSwapsViewModel+SwapDto">
                            <Border Margin="0,0,0,10" Padding="16,14"
                                    BackgroundColor="{StaticResource Surface}"
                                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <VerticalStackLayout Spacing="6">

                                    <!-- IDs row -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding StatusDisplay}"
                                               FontFamily="PJSSemi" FontSize="13"
                                               TextColor="{StaticResource OnBackground}"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yy}'}"
                                               FontFamily="PJSReg" FontSize="12"
                                               TextColor="{StaticResource Outline}"/>
                                    </Grid>

                                    <Label FontFamily="PJSReg" FontSize="12" TextColor="{StaticResource Outline}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Turno "/>
                                                <Span Text="{Binding ShiftAId}"/>
                                                <Span Text=" ⇄ Turno "/>
                                                <Span Text="{Binding ShiftBId}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <Label Text="{Binding Note}" FontFamily="PJSReg" FontSize="12"
                                           TextColor="{StaticResource Outline}"
                                           IsVisible="{Binding Note, Converter={StaticResource StringNotEmptyConverter}}"/>

                                    <!-- Peer buttons (employee sees pending swaps directed to them) -->
                                    <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsPending}">
                                        <Button Text="Accetta"
                                                CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=AcceptCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                HeightRequest="36" FontSize="13"/>
                                        <Button Text="Rifiuta"
                                                CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=RejectCommand}"
                                                Style="{StaticResource GhostButton}"
                                                HeightRequest="36" FontSize="13"/>
                                    </HorizontalStackLayout>

                                    <!-- Admin buttons -->
                                    <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsAcceptedByPeer}">
                                        <Button Text="Approva"
                                                CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=AdminApproveCommand}"
                                                Style="{StaticResource PrimaryButton}"
                                                HeightRequest="36" FontSize="13"/>
                                        <Button Text="Blocca"
                                                CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftSwapsViewModel}}, Path=AdminRejectCommand}"
                                                Style="{StaticResource GhostButton}"
                                                HeightRequest="36" FontSize="13"/>
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
