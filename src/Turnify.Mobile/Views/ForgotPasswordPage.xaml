<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="210,*">

        <!-- Hero -->
        <Grid Grid.Row="0">
            <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                     VerticalOptions="Fill" HorizontalOptions="Fill"/>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="End"
                                 Spacing="14" Padding="0,0,0,36">
                <Grid WidthRequest="64" HeightRequest="64" HorizontalOptions="Center">
                    <BoxView CornerRadius="18" BackgroundColor="White" Opacity="0.18"/>
                    <Label Text="🔑" FontSize="30" HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"/>
                </Grid>
                <Label Text="Recupera password" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                       HorizontalOptions="Center" CharacterSpacing="-0.2"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Sheet card -->
        <Border Grid.Row="1"
                StrokeShape="RoundRectangle CornerRadius='28,28,0,0'"
                StrokeThickness="0"
                Margin="0,-16,0,0"
                Padding="24,8,24,40"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <BoxView WidthRequest="32" HeightRequest="4" CornerRadius="2"
                             HorizontalOptions="Center" Margin="0,10,0,10"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>

                    <!-- Success state (EmailSent = true) -->
                    <VerticalStackLayout IsVisible="{Binding EmailSent}"
                                         Spacing="16" HorizontalOptions="Center">

                        <Border WidthRequest="72" HeightRequest="72"
                                StrokeShape="RoundRectangle CornerRadius='36'"
                                StrokeThickness="0"
                                HorizontalOptions="Center"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SuccessBg}, Dark={StaticResource SuccessBgDark}}">
                            <Label Text="✓" FontSize="32" FontFamily="PJSBold"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"/>
                        </Border>

                        <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                            <Label Text="Email inviata!"
                                   FontSize="22" FontFamily="PJSBold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   HorizontalTextAlignment="Center" CharacterSpacing="-0.4"/>
                            <Label Text="Se l'indirizzo è registrato, riceverai le istruzioni a breve. Controlla anche la cartella spam."
                                   FontSize="14" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   HorizontalTextAlignment="Center" LineHeight="1.5"
                                   Margin="12,8,12,0"/>
                        </VerticalStackLayout>

                        <Button Text="Torna al login"
                                Command="{Binding GoBackCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"
                                HorizontalOptions="Fill" Margin="0,12,0,0"/>

                    </VerticalStackLayout>

                    <!-- Form state (EmailSent = false) -->
                    <VerticalStackLayout IsVisible="{Binding EmailSent, Converter={StaticResource InverseBoolConverter}}"
                                         Spacing="0">

                        <Label Text="Reimposta password"
                               FontSize="20" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               Margin="0,6,0,0" CharacterSpacing="-0.3"/>
                        <Label Text="Inserisci la tua email. Ti invieremo un link sicuro per impostarne una nuova."
                               FontSize="13" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,6,0,22" LineHeight="1.45"/>

                        <!-- Error banner -->
                        <Border BackgroundColor="{StaticResource ErrorLight}"
                                Stroke="{StaticResource Error}" StrokeThickness="1"
                                Padding="14,10" IsVisible="{Binding HasError}"
                                Margin="0,0,0,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}" FontSize="13" FontFamily="PJSSemi"
                                   TextColor="{StaticResource ErrorText}"/>
                        </Border>

                        <!-- Email input -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                StrokeThickness="2" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="13,0">
                                <Label Text="✉" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                <Entry Text="{Binding Email}" Placeholder="nome@azienda.it"
                                       Keyboard="Email" FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                        <Button Text="Invia link di reset"
                                Command="{Binding SendResetCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"
                                Margin="0,22,0,0"/>

                        <Label Text="‹ Torna al login"
                               FontSize="13" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               HorizontalTextAlignment="Center" Margin="0,16,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center" Margin="0,12,0,0"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
