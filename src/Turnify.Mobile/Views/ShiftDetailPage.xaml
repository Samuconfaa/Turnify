<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ShiftDetailPage"
             x:DataType="vm:ShiftDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <!-- Dipendente -->
            <Label Text="Dipendente *" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Picker ItemsSource="{Binding Employees}"
                        ItemDisplayBinding="{Binding FullName}"
                        SelectedItem="{Binding SelectedEmployee}"
                        Title="Seleziona dipendente"
                        Margin="10,0"/>
            </Border>

            <!-- Nessun dipendente warning -->
            <Border BackgroundColor="#FEF3C7" Stroke="#FDE68A" StrokeThickness="1" Padding="12"
                    IsVisible="{Binding Employees.Count, Converter={StaticResource IntIsZeroConverter}}">
                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                <HorizontalStackLayout Spacing="10">
                    <Label Text="⚠️" FontSize="18" VerticalOptions="Center"/>
                    <VerticalStackLayout>
                        <Label Text="Nessun dipendente disponibile."
                               FontSize="14" FontAttributes="Bold" TextColor="#92400E"/>
                        <Label Text="Aggiungi prima un dipendente dalla sezione Team."
                               FontSize="13" TextColor="#92400E"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- Data -->
            <Label Text="Data *" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,6,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="4">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <DatePicker Date="{Binding ShiftDate}"
                            Format="dddd dd MMMM yyyy"
                            MinimumDate="2020-01-01"
                            Margin="10,0"/>
            </Border>

            <!-- Orari -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <VerticalStackLayout Grid.Column="0" Spacing="4">
                    <Label Text="Inizio *" FontSize="13"
                           TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
                    <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <TimePicker Time="{Binding StartTime}" Format="HH:mm" Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="Fine *" FontSize="13"
                           TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
                    <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <TimePicker Time="{Binding EndTime}" Format="HH:mm" Margin="10,0"/>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Etichetta -->
            <Label Text="Etichetta (opzionale)" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,6,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Entry Text="{Binding Label}" Placeholder="Es. Apertura, Turno pranzo..."
                       HeightRequest="50" Margin="14,0" BackgroundColor="Transparent"/>
            </Border>

            <!-- Note -->
            <Label Text="Note (opzionale)" FontSize="13"
                   TextColor="{StaticResource OnSurfaceVariant}" Margin="2,0,0,0"/>
            <Border Stroke="{StaticResource Outline}" StrokeThickness="1" Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Editor Text="{Binding Note}" Placeholder="Es. Copertura per Mario assente..."
                        HeightRequest="80" Margin="10,4"/>
            </Border>

            <!-- Bottoni -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                <Button Grid.Column="0" Text="Elimina"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding IsEditMode}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Error}"
                        BorderColor="{StaticResource Error}"
                        BorderWidth="1" CornerRadius="10" HeightRequest="50"/>
                <Button Grid.Column="1" Text="Salva Turno"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" CornerRadius="10" HeightRequest="50"
                        FontAttributes="Bold">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsCreateMode}" Value="True">
                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                            <Setter Property="Grid.Column" Value="0"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" Color="{StaticResource Primary}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
