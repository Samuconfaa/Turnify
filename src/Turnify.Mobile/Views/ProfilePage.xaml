<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ProfilePage"
             Title="Profilo"
             BackgroundColor="{StaticResource Background}">
    <ScrollView>
        <VerticalStackLayout Spacing="24" Padding="16">

            <!-- Avatar + info -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Margin="0,16,0,0">
                <Frame BackgroundColor="{StaticResource PrimaryContainer}"
                       CornerRadius="40" HeightRequest="80" WidthRequest="80"
                       Padding="0" HorizontalOptions="Center" HasShadow="False">
                    <Label Text="{Binding Initials}"
                           FontSize="28" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
                <Label Text="{Binding Email}"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource OnBackground}"
                       HorizontalOptions="Center"/>
                <Frame BackgroundColor="{StaticResource PrimaryContainer}"
                       BorderColor="Transparent" CornerRadius="16"
                       Padding="12,4" HorizontalOptions="Center">
                    <Label Text="{Binding Role}"
                           FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Impostazioni account -->
            <VerticalStackLayout Spacing="0">
                <Label Text="IMPOSTAZIONI ACCOUNT"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurfaceVariant}"
                       Margin="4,0,0,8"/>

                <Frame BackgroundColor="{StaticResource Surface}"
                       BorderColor="{StaticResource Outline}"
                       HasShadow="True" Padding="0"
                       CornerRadius="12" IsClippedToBounds="True">
                    <VerticalStackLayout>

                        <!-- Modifica profilo -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EditProfileCommand}"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="👤" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,12,0"/>
                            <Label Grid.Column="1" Text="Modifica Profilo"
                                   FontSize="16" TextColor="{StaticResource OnBackground}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"/>

                        <!-- Cambia password -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangePasswordCommand}"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="🔒" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,12,0"/>
                            <Label Grid.Column="1" Text="Cambia Password"
                                   FontSize="16" TextColor="{StaticResource OnBackground}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"/>

                        <!-- Notifiche -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenNotificationsCommand}"/>
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="🔔" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,12,0"/>
                            <Label Grid.Column="1" Text="Notifiche"
                                   FontSize="16" TextColor="{StaticResource OnBackground}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="{StaticResource OnSurfaceVariant}"
                                   VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

            <!-- Logout -->
            <Button Text="Logout"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource DangerColor}"
                    BorderColor="{StaticResource DangerColor}"
                    BorderWidth="1" CornerRadius="8"
                    FontAttributes="Bold" Margin="0,8,0,32"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>