<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ReportsPage"
             x:DataType="vm:ReportsViewModel"
             Title="Report"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="&#8249;" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Report" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="16">

                <!-- Error banner -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                        Padding="14,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBg}, Dark={StaticResource ErrorBgDark}}"
                        IsVisible="{Binding HasError}">
                    <Label Text="{Binding ErrorMessage}" FontSize="13" FontFamily="PJSSemi"
                           TextColor="{AppThemeBinding Light={StaticResource ErrorText}, Dark={StaticResource ErrorTextDark}}"/>
                </Border>

                <!-- Success banner -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="0"
                        Padding="14,12"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                        IsVisible="{Binding HasSuccess}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="&#10003;" FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding SuccessMessage}"
                               FontSize="13" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Periodo -->
                <Label Text="PERIODO" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            HeightRequest="56"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <VerticalStackLayout Padding="14,8" Spacing="2">
                            <Label Text="Dal" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#128197;" FontSize="14" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <DatePicker Date="{Binding FromDate}"
                                            FontFamily="PJSReg" FontSize="14"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                            HorizontalOptions="FillAndExpand" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            HeightRequest="56"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <VerticalStackLayout Padding="14,8" Spacing="2">
                            <Label Text="Al" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#128197;" FontSize="14" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <DatePicker Date="{Binding ToDate}"
                                            FontFamily="PJSReg" FontSize="14"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                            HorizontalOptions="FillAndExpand" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Esporta label -->
                <Label Text="ESPORTA" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,6,0,0"/>

                <!-- Ore pianificate card -->
                <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DownloadHoursCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="14">
                        <Border WidthRequest="44" HeightRequest="44"
                                StrokeShape="RoundRectangle CornerRadius='12'"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                            <Label Text="&#9201;" FontSize="20"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                            <Label Text="Ore pianificate" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            <Label Text="Tutti i turni assegnati nel periodo selezionato." FontSize="12" FontFamily="PJSReg"
                                   LineHeight="1.4"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        </VerticalStackLayout>
                        <Border WidthRequest="36" HeightRequest="36"
                                StrokeShape="RoundRectangle CornerRadius='10'"
                                StrokeThickness="0" VerticalOptions="Center"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                            <Label Text="&#8595;" FontSize="16" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>
                </Border>

                <!-- Presenze effettive card -->
                <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DownloadAttendanceCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="14">
                        <Border WidthRequest="44" HeightRequest="44"
                                StrokeShape="RoundRectangle CornerRadius='12'"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource KpiBlueBg}, Dark={StaticResource KpiBlueBgDark}}">
                            <Label Text="&#128203;" FontSize="20"
                                   TextColor="{AppThemeBinding Light={StaticResource KpiBlue}, Dark={StaticResource KpiBlueDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                            <Label Text="Presenze effettive" FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            <Label Text="Timbrature entrata e uscita con ore lavorate." FontSize="12" FontFamily="PJSReg"
                                   LineHeight="1.4"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        </VerticalStackLayout>
                        <Border WidthRequest="36" HeightRequest="36"
                                StrokeShape="RoundRectangle CornerRadius='10'"
                                StrokeThickness="0" VerticalOptions="Center"
                                BackgroundColor="{AppThemeBinding Light={StaticResource KpiBlue}, Dark={StaticResource KpiBlueDark}}">
                            <Label Text="&#8595;" FontSize="16" FontFamily="PJSSemi" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   HorizontalOptions="Center" Margin="0,8,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
