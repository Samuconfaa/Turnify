<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.EmployeeReportsPage"
             x:DataType="vm:EmployeeReportsViewModel"
             Title="Report ore"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="&#8249;" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Report ore" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
            <Border Grid.Column="2" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="36" HeightRequest="36"
                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LoadReportsCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="&#8595;" FontSize="16" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- Content -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadReportsCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Reports}">

                <CollectionView.Header>
                    <VerticalStackLayout Spacing="10">

                        <!-- Filters -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" Padding="16,14,16,0">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='12'"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    HeightRequest="52"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <VerticalStackLayout Padding="10,6" Spacing="2">
                                    <Label Text="Dal" FontSize="10" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="&#128197;" FontSize="12" VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                        <DatePicker Date="{Binding From}"
                                                    FontFamily="PJSReg" FontSize="13"
                                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                    VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle CornerRadius='12'"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    HeightRequest="52"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <VerticalStackLayout Padding="10,6" Spacing="2">
                                    <Label Text="Al" FontSize="10" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="&#128197;" FontSize="12" VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                        <DatePicker Date="{Binding To}"
                                                    FontFamily="PJSReg" FontSize="13"
                                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                    VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" StrokeShape="RoundRectangle CornerRadius='12'"
                                    StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    HeightRequest="52"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <Grid ColumnDefinitions="*,Auto" Padding="10,6">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Raggruppa" FontSize="10" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                        <Picker ItemsSource="{Binding GroupByOptions}"
                                                SelectedItem="{Binding SelectedGroupBy}"
                                                FontFamily="PJSReg" FontSize="13"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                BackgroundColor="Transparent"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1" Text="&#8744;" FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Error banner -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                Padding="12,8" Margin="16,0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBg}, Dark={StaticResource ErrorBgDark}}"
                                IsVisible="{Binding HasError}">
                            <Label Text="{Binding ErrorMessage}" FontSize="13" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource ErrorText}, Dark={StaticResource ErrorTextDark}}"/>
                        </Border>

                        <VerticalStackLayout Padding="16,4,16,0" Spacing="0">
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,48,0,0" Spacing="12"
                                         IsVisible="{Binding IsEmptyState}">
                        <Label Text="Nessun dato disponibile"
                               FontSize="17" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Seleziona un intervallo di date e premi Carica report."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               Margin="8,0"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EmployeeHoursReportDto">
                        <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                Margin="16,0,16,10">
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <!-- Employee row header -->
                                <HorizontalStackLayout Spacing="12" Padding="14,14,14,14">
                                    <HorizontalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeReportsViewModel}}, Path=ToggleExpandCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </HorizontalStackLayout.GestureRecognizers>
                                    <Border WidthRequest="40" HeightRequest="40"
                                            StrokeShape="RoundRectangle CornerRadius='12'"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                        <Label Text="{Binding EmployeeName, Converter={StaticResource InitialsConverter}}"
                                               FontSize="13" FontFamily="PJSBold"
                                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                        <Label Text="{Binding EmployeeName}" FontSize="14" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                        <Label Text="{Binding TotalHoursDisplay}" FontSize="12" FontFamily="PJSReg"
                                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    </VerticalStackLayout>
                                    <Label Text="&#8250;" FontSize="18"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>

                                <!-- Expandable breakdown -->
                                <VerticalStackLayout IsVisible="{Binding IsExpanded}"
                                                     Padding="14,0,14,14" Spacing="0">
                                    <BoxView HeightRequest="1" Margin="0,0,0,4"
                                             BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"/>
                                    <CollectionView ItemsSource="{Binding Breakdown}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:HoursBreakdownDto">
                                                <Grid ColumnDefinitions="*,Auto,Auto" Padding="4,10,4,10">
                                                    <Label Grid.Column="0" Text="{Binding Period}"
                                                           FontSize="13" FontFamily="PJSReg"
                                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                                           VerticalOptions="Center"/>
                                                    <Border Grid.Column="1" WidthRequest="80" HeightRequest="4"
                                                            StrokeShape="RoundRectangle CornerRadius='2'"
                                                            StrokeThickness="0" Margin="0,0,10,0"
                                                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}"
                                                            VerticalOptions="Center">
                                                        <BoxView HeightRequest="4" CornerRadius="2"
                                                                 HorizontalOptions="FillAndExpand"
                                                                 BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                                    </Border>
                                                    <Label Grid.Column="2" Text="{Binding HoursDisplay}"
                                                           FontSize="13" FontFamily="PJSSemi"
                                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                           VerticalOptions="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="24"/>
                </CollectionView.Footer>

            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Start"
                           Margin="0,80,0,0"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
    </Grid>
</ContentPage>
