<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── Base ─────────────────────────────────────────────────────── -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <!-- ── Turnify Design System (light) ────────────────────────────── -->
    <!-- Background & Surfaces -->
    <Color x:Key="Background">#FAF8FF</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceContainer">#EDEDF9</Color>
    <Color x:Key="SurfaceContainerLow">#F3F3FE</Color>
    <Color x:Key="SurfaceContainerHigh">#E7E7F3</Color>
    <Color x:Key="SurfaceContainerHighest">#E1E2ED</Color>
    <Color x:Key="SurfaceContainerLowest">#FFFFFF</Color>

    <!-- Primary -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryContainer">#2563EB</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>
    <Color x:Key="OnPrimaryContainer">#EEEFFF</Color>
    <Color x:Key="PrimaryFixed">#DBE1FF</Color>
    <Color x:Key="PrimaryFixedDim">#B4C5FF</Color>

    <!-- Text -->
    <Color x:Key="OnBackground">#191B23</Color>
    <Color x:Key="OnSurface">#191B23</Color>
    <Color x:Key="OnSurfaceVariant">#434655</Color>
    <Color x:Key="Outline">#737686</Color>
    <Color x:Key="OutlineVariant">#C3C6D7</Color>

    <!-- Semantic -->
    <Color x:Key="Error">#BA1A1A</Color>
    <Color x:Key="ErrorContainer">#FFDAD6</Color>
    <Color x:Key="OnErrorContainer">#93000A</Color>
    <Color x:Key="Success">#16A34A</Color>
    <Color x:Key="SuccessContainer">#DCFCE7</Color>
    <Color x:Key="Warning">#D97706</Color>
    <Color x:Key="Tertiary">#943700</Color>
    <Color x:Key="TertiaryContainer">#BC4800</Color>
    <Color x:Key="TertiaryFixedDim">#FFB596</Color>

    <!-- Secondary -->
    <Color x:Key="Secondary">#505F76</Color>
    <Color x:Key="SecondaryContainer">#D0E1FB</Color>
    <Color x:Key="OnSecondaryContainer">#54647A</Color>

    <!-- Aliases (backward compat) -->
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="SecondaryDarkText">#C8C8C8</Color>
    <Color x:Key="TextPrimary">#191B23</Color>
    <Color x:Key="TextSecondary">#434655</Color>
    <Color x:Key="BorderColor">#C3C6D7</Color>
    <Color x:Key="Surface2">#F3F3FE</Color>

</ResourceDictionary>
