<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             xmlns:comp="clr-namespace:Turnify.Mobile.Views.Components"
             x:Class="Turnify.Mobile.Views.EmployeeListPage"
             x:DataType="vm:EmployeeListViewModel"
             Title="Team"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <comp:StaleDataBanner Grid.Row="0"/>

        <!-- ── Header ──────────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Label Grid.Column="0" Text="Team" FontSize="22" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   VerticalOptions="Center" CharacterSpacing="-0.3"/>
            <Border Grid.Column="2" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" Padding="14,0" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddEmployeeCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="+ Aggiungi" FontSize="12" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                       VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- ── Content ─────────────────────────────────────────── -->
        <RefreshView Grid.Row="2" Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Employees}"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.Header>
                    <VerticalStackLayout Padding="16,12,16,0" Spacing="10">

                        <!-- Search input -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                HeightRequest="48"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="0">
                                <Image Grid.Column="0" Source="search.svg" HeightRequest="16" WidthRequest="16"
                                       VerticalOptions="Center" Margin="14,0,0,0"/>
                                <SearchBar Grid.Column="1" Text="{Binding SearchQuery}"
                                           Placeholder="Cerca per nome o ruolo"
                                           HeightRequest="48" BackgroundColor="Transparent"
                                           CancelButtonColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           PlaceholderColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           FontFamily="PJSReg"/>
                            </Grid>
                        </Border>

                        <!-- Business filter chips -->
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                            <HorizontalStackLayout Spacing="8" Padding="0,0,0,2">
                                <Border StrokeShape="RoundRectangle CornerRadius='20'" StrokeThickness="0" Padding="14,8"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=LoadDataCommand}"/>
                                    </Border.GestureRecognizers>
                                    <Label FontSize="13" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Tutte le attività"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Border>
                                <!-- Dynamic business picker rendered as a Picker beneath chips -->
                                <Border StrokeShape="RoundRectangle CornerRadius='20'" StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                        Padding="0,0,14,0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                    <Picker ItemsSource="{Binding Businesses}"
                                            ItemDisplayBinding="{Binding Name}"
                                            SelectedItem="{Binding SelectedBusiness}"
                                            Title="Attività…"
                                            FontFamily="PJSReg" FontSize="13"
                                            TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                            TitleColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                            Margin="14,0,0,0"/>
                                </Border>
                            </HorizontalStackLayout>
                        </ScrollView>

                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" Margin="32,52,32,0" Spacing="14">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                HeightRequest="68" WidthRequest="68" HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Image Source="users_group.svg" HeightRequest="34" WidthRequest="34"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Nessun dipendente ancora" FontSize="17" FontAttributes="Bold"
                               FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Aggiungi il tuo primo dipendente per iniziare a gestire i turni."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="8,0"/>
                        <Button Text="Aggiungi dipendente"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=AddEmployeeCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                CornerRadius="12" HeightRequest="46"
                                FontFamily="PJSSemi" FontSize="14"
                                HorizontalOptions="Center" Padding="24,0" WidthRequest="240"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.Footer>
                    <VerticalStackLayout Padding="16,4,16,12" Spacing="10">
                        <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                           IsVisible="{Binding IsLoadingMore}"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                           Margin="0,4,0,4"/>
                        <!-- Add employee dashed card -->
                        <Border StrokeShape="RoundRectangle CornerRadius='14'"
                                StrokeThickness="1.5"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="16" BackgroundColor="Transparent">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CreateEmployeeCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="+" FontSize="16" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       VerticalOptions="Center"/>
                                <Label Text="Aggiungi dipendente" FontSize="14" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </CollectionView.Footer>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EmployeeListDto">
                        <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="14"
                                Margin="16,0,16,8"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=EditEmployeeCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <!-- Inactive: lower opacity -->
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                    <Setter Property="Opacity" Value="0.55"/>
                                </DataTrigger>
                            </Border.Triggers>

                            <HorizontalStackLayout Spacing="12">
                                <!-- Avatar -->
                                <Border WidthRequest="44" HeightRequest="44"
                                        StrokeShape="RoundRectangle CornerRadius='14'"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Initials}" FontSize="14" FontFamily="PJSBold"
                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>

                                <!-- Info -->
                                <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding FullName}" FontSize="14" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                               VerticalOptions="Center"/>
                                        <Border StrokeShape="RoundRectangle CornerRadius='6'" StrokeThickness="0"
                                                Padding="8,2"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}"
                                                IsVisible="{Binding ContractType, Converter={StaticResource StringNotEmptyConverter}}">
                                            <Label Text="{Binding ContractType}" FontSize="10" FontFamily="PJSSemi"
                                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding Role}" FontSize="13" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                </VerticalStackLayout>

                                <!-- Status badge + chevron -->
                                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            Padding="8,4"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource SuccessBg}, Dark={StaticResource SuccessBgDark}}">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding StatusText}" FontSize="11" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                    <Label Text="›" FontSize="18"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

        <!-- ── Tab bar (admin: Casa, Turni, Team*, Ferie, Profilo) ── -->
        <Border Grid.Row="3"
                StrokeShape="RoundRectangle CornerRadius='28'" StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                Padding="6" Margin="16,8,16,24"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border.Shadow><Shadow Brush="Black" Offset="0,6" Radius="24" Opacity="0.10"/></Border.Shadow>
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4">

                <!-- Casa -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToDashCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="⊞" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Casa" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>

                <!-- Turni -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToShiftsCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📅" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Turni" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>

                <!-- Team (current, active) -->
                <Border Grid.Column="2" StrokeShape="RoundRectangle CornerRadius='22'"
                        StrokeThickness="0" HeightRequest="44"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                        <Label Text="👥" FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Team" FontSize="9" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Ferie -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToVacationsCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🌴" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Ferie" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>

                <!-- Profilo -->
                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToProfileCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="👤" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Profilo" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
