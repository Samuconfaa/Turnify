<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.NotificationsPage"
             x:DataType="vm:NotificationsViewModel"
             Title="Notifiche"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Label Grid.Column="0" Text="&#8249;" FontSize="22" FontFamily="PJSSemi"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   VerticalOptions="Center"/>
            <Label Grid.Column="1" Text="Notifiche" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
            <Label Grid.Column="2" Text="Segna lette" FontSize="12" FontFamily="PJSSemi"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                   VerticalOptions="Center"
                   IsVisible="{Binding UnreadCount, Converter={StaticResource IntIsZeroConverter}, ConverterParameter=invert}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding MarkAllReadCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- Content -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Notifications}">

                <CollectionView.Header>
                    <VerticalStackLayout Padding="16,14,16,4" Spacing="8">
                        <!-- Error banner -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                Padding="14,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBg}, Dark={StaticResource ErrorBgDark}}"
                                IsVisible="{Binding HasError}">
                            <Label Text="{Binding ErrorMessage}" FontSize="13" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource ErrorText}, Dark={StaticResource ErrorTextDark}}"/>
                        </Border>
                        <!-- Unread count pill -->
                        <Border StrokeShape="RoundRectangle CornerRadius='13'"
                                StrokeThickness="0" Padding="10,4"
                                HorizontalOptions="Start"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                IsVisible="{Binding UnreadCount, Converter={StaticResource IntIsZeroConverter}, ConverterParameter=invert}">
                            <Label Text="{Binding UnreadCount, StringFormat='{0} non lette'}"
                                   FontSize="12" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"/>
                        </Border>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center"
                                         Margin="0,60,0,0" Spacing="14"
                                         IsVisible="{Binding HasError, Converter={StaticResource InverseBoolConverter}}">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                HeightRequest="68" WidthRequest="68"
                                HorizontalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                            <Label Text="&#128276;" FontSize="34"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Nessuna notifica"
                               FontSize="18" FontAttributes="Bold" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Le notifiche sui tuoi turni e ferie appariranno qui."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               Margin="32,0"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:NotificationDto">
                        <Border StrokeShape="RoundRectangle CornerRadius='14'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"
                                Padding="14" Margin="16,0,16,8"
                                BackgroundColor="{Binding BackgroundColor}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=MarkReadCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        StrokeShape="RoundRectangle CornerRadius='12'"
                                        StrokeThickness="0" WidthRequest="40" HeightRequest="40"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                    <Label Text="{Binding Icon}" FontSize="18"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Title}" FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Body}" FontSize="13" FontFamily="PJSReg" LineHeight="1.4"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           LineBreakMode="WordWrap"/>
                                    <Label Text="{Binding TimeAgo}" FontSize="11" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           Opacity="0.7"/>
                                </VerticalStackLayout>
                                <!-- Unread dot -->
                                <BoxView Grid.Column="2" WidthRequest="6" HeightRequest="6" CornerRadius="3"
                                         BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                         VerticalOptions="Start" Margin="0,4,0,0">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding IsRead}" Value="True">
                                            <Setter Property="IsVisible" Value="False"/>
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="8"/>
                </CollectionView.Footer>

            </CollectionView>
        </RefreshView>

        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

        <!-- Custom tab bar -->
        <Border Grid.Row="2"
                StrokeShape="RoundRectangle CornerRadius='28'" StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                Padding="6" Margin="16,8,16,24"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border.Shadow><Shadow Brush="Black" Offset="0,6" Radius="24" Opacity="0.10"/></Border.Shadow>
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4">
                <!-- Dashboard -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToDashCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#8862;" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Dashboard" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
                <!-- Turni -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToShiftsCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#128197;" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Turni" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
                <!-- Ferie -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToVacationsCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#127796;" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Ferie" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
                <!-- Notifiche (active) -->
                <Border Grid.Column="3" StrokeShape="RoundRectangle CornerRadius='22'"
                        StrokeThickness="0" HeightRequest="44"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                        <Label Text="&#128276;" FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Notifiche" FontSize="9" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Profilo -->
                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToProfileCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="&#128100;" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Profilo" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
