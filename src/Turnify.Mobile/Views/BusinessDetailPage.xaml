<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.BusinessDetailPage"
             x:DataType="vm:BusinessDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20,20,20,40">

            <Label Text="NOME ATTIVITÀ" Style="{StaticResource SectionLabel}" Margin="2,0,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding Name}" Placeholder="Es. Pizzeria Roma" Style="{StaticResource FieldEntry}"/>
            </Border>

            <Label Text="TIPO ATTIVITÀ" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Picker ItemsSource="{Binding BusinessTypes}"
                        SelectedItem="{Binding BusinessType}"
                        Title="Seleziona tipo"
                        FontFamily="PJSReg"
                        TextColor="{StaticResource OnBackground}"
                        TitleColor="{StaticResource Outline}"
                        Margin="10,0"/>
            </Border>

            <Label Text="INDIRIZZO" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding Address}" Placeholder="Es. Via Roma 1, Milano" Style="{StaticResource FieldEntry}"/>
            </Border>

            <Label Text="TELEFONO" Style="{StaticResource SectionLabel}" Margin="2,6,0,0"/>
            <Border Style="{StaticResource FieldBorder}">
                <Entry Text="{Binding Phone}" Placeholder="+39 02 1234567"
                       Keyboard="Telephone" Style="{StaticResource FieldEntry}"/>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,12,0,0">
                <Button Grid.Column="0" Text="Disattiva"
                        Command="{Binding DeleteCommand}"
                        IsVisible="{Binding IsEditMode}"
                        Style="{StaticResource DangerButton}"/>
                <Button Grid.Column="1" Text="Salva"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsCreateMode}" Value="True">
                            <Setter Property="Grid.ColumnSpan" Value="2"/>
                            <Setter Property="Grid.Column" Value="0"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" Color="{StaticResource Primary}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
