<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.EmployeeDetailPage"
             x:DataType="vm:EmployeeDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="*">

        <!-- ── Content ─────────────────────────────────────────── -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="18,18,18,32" Spacing="14">

                <!-- DATI PERSONALI -->
                <Label Text="DATI PERSONALI" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,4,0,0"/>

                <!-- Nome + Cognome row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            HeightRequest="50"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <VerticalStackLayout Padding="14,8" Spacing="2">
                            <Label Text="Nome" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding FirstName}" Placeholder="Nome" FontSize="14" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            HeightRequest="50"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <VerticalStackLayout Padding="14,8" Spacing="2">
                            <Label Text="Cognome" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding LastName}" Placeholder="Cognome" FontSize="14" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Username (highlighted) -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        StrokeThickness="2" HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Padding="14,8" Spacing="2">
                        <Label Text="Username" FontSize="10" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="👤" FontSize="16" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                            <Entry Text="{Binding Username}" Placeholder="es. m.bianchi"
                                   FontSize="14" FontFamily="PJSReg"
                                   HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
                <Label Text="Identificatore univoco per il login" FontSize="12" FontFamily="PJSReg"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="4,-10,0,0"/>

                <!-- CONTATTI -->
                <Label Text="CONTATTI" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,8,0,0"/>
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Padding="14,8" Spacing="2">
                        <Label Text="Email (opzionale)" FontSize="10" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="✉" FontSize="15" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding Email}" Placeholder="email@esempio.it"
                                   Keyboard="Email"
                                   FontSize="14" FontFamily="PJSReg"
                                   HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Padding="14,8" Spacing="2">
                        <Label Text="Telefono (opzionale)" FontSize="10" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📞" FontSize="15" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding Phone}" Placeholder="+39 000 00 00 000"
                                   Keyboard="Telephone"
                                   FontSize="14" FontFamily="PJSReg"
                                   HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- LAVORO -->
                <Label Text="LAVORO" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,8,0,0"/>
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <VerticalStackLayout Padding="14,8" Spacing="2">
                        <Label Text="Ruolo in azienda" FontSize="10" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="💼" FontSize="15" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Entry Text="{Binding JobRole}" Placeholder="es. Barista"
                                   FontSize="14" FontFamily="PJSReg"
                                   HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   BackgroundColor="Transparent"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Contratto + Ore settimanali -->
                <Grid ColumnDefinitions="1.4*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            HeightRequest="56"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <VerticalStackLayout Padding="14,8" Spacing="2">
                            <Label Text="Tipo contratto" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Picker ItemsSource="{Binding ContractTypesDisplay}"
                                    SelectedIndex="{Binding SelectedContractTypeIndex}"
                                    FontFamily="PJSReg" FontSize="14"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    Margin="0,0"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            HeightRequest="56"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <VerticalStackLayout Padding="14,8" Spacing="2">
                            <Label Text="Ore / sett." FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="⏱" FontSize="14" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding WeeklyHours}" Placeholder="40"
                                       Keyboard="Numeric"
                                       FontSize="14" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ATTIVITÀ E ACCOUNT -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                    <Label Grid.Column="0" Text="ATTIVITÀ E ACCOUNT" FontSize="11" FontFamily="PJSSemi"
                           CharacterSpacing="0.8"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="+ Crea attività" FontSize="12" FontFamily="PJSSemi"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoCreateBusinessCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- Attività picker -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Attività di riferimento" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🏢" FontSize="14" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Picker ItemsSource="{Binding Businesses}"
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedBusiness}"
                                        Title="Seleziona attività (opzionale)"
                                        FontFamily="PJSReg" FontSize="14"
                                        HorizontalOptions="FillAndExpand"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                        TitleColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                        Margin="0,0"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="∨" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Ruolo account picker -->
                <Border StrokeShape="RoundRectangle CornerRadius='12'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="56"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Grid ColumnDefinitions="*,Auto" Padding="14,8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Ruolo account" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <Picker ItemsSource="{Binding AccountRolesDisplay}"
                                    SelectedIndex="{Binding SelectedAccountRoleIndex}"
                                    FontFamily="PJSReg" FontSize="14"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    Margin="0,0"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="∨" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- SICUREZZA — Password (create only) -->
                <VerticalStackLayout IsVisible="{Binding IsCreateMode}" Spacing="6" Margin="0,8,0,0">
                    <Label Text="SICUREZZA" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Border StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            HeightRequest="56"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <VerticalStackLayout Padding="14,8" Spacing="2">
                            <Label Text="Password temporanea" FontSize="10" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🔒" FontSize="15" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding Password}" Placeholder="Es. TempPass123!"
                                       IsPassword="True"
                                       FontSize="14" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                    <Label Text="Sarà richiesta al primo accesso" FontSize="12" FontFamily="PJSReg"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           Margin="4,-4,0,0"/>
                </VerticalStackLayout>

                <!-- SALDO FERIE (edit only) -->
                <VerticalStackLayout IsVisible="{Binding ShowEmployeeBalance}" Spacing="6" Margin="0,8,0,0">
                    <Label Text="SALDO FERIE" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            Padding="16"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                        <HorizontalStackLayout Spacing="14">
                            <Border WidthRequest="40" HeightRequest="40"
                                    StrokeShape="RoundRectangle CornerRadius='12'"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                <Label Text="🌴" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                <Label Text="{Binding HolidayBalance}"
                                       FontSize="13" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                <Label Text="{Binding PaidLeaveBalance}"
                                       FontSize="13" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Reset password (edit only) -->
                <Button Text="Reimposta password"
                        Command="{Binding ResetPasswordCommand}"
                        IsVisible="{Binding IsEditMode}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        BorderColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        BorderWidth="1.5" CornerRadius="12"
                        HeightRequest="48" FontSize="14"
                        FontAttributes="Bold" FontFamily="PJSSemi"
                        Margin="0,4,0,0"/>

                <!-- Action buttons -->
                <Grid ColumnDefinitions="*,2*" ColumnSpacing="10" Margin="0,8,0,0">
                    <!-- Disattiva (edit only) -->
                    <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1.5"
                            Stroke="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                            HeightRequest="50" BackgroundColor="Transparent"
                            IsVisible="{Binding IsEditMode}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Disattiva" FontSize="15" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <!-- Salva / Crea -->
                    <Button HeightRequest="50"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                            CornerRadius="12"
                            FontFamily="PJSSemi" FontSize="15"
                            Command="{Binding SaveCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsCreateMode}" Value="True">
                                <Setter Property="Text" Value="Crea dipendente"/>
                                <Setter Property="Grid.ColumnSpan" Value="2"/>
                                <Setter Property="Grid.Column" Value="0"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="Text" Value="Salva"/>
                                <Setter Property="Grid.Column" Value="1"/>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center"
                                   Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   Margin="0,8,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
