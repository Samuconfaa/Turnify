<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ProfilePage"
             Title="Profilo"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="300,*">

        <!-- ── Hero header con gradiente ────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E40AF" Offset="0"/>
                    <GradientStop Color="#2563EB" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="6" Margin="0,24,0,0">

                <!-- Avatar (tap to change) -->
                <Grid HorizontalOptions="Center">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickAvatarCommand}"/>
                    </Grid.GestureRecognizers>

                    <!-- Photo avatar -->
                    <Border HeightRequest="96" WidthRequest="96"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowPhoto}"
                            Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="48"/></Border.StrokeShape>
                        <Image Source="{Binding AvatarPhoto}"
                               Aspect="AspectFill"
                               HeightRequest="96" WidthRequest="96"/>
                    </Border>

                    <!-- Emoji avatar -->
                    <Border BackgroundColor="#FFFFFF26"
                            HeightRequest="96" WidthRequest="96"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowEmoji}"
                            Stroke="#FFFFFF4D" StrokeThickness="2">
                        <Border.StrokeShape><RoundRectangle CornerRadius="48"/></Border.StrokeShape>
                        <Label Text="{Binding AvatarEmoji}"
                               FontSize="48"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Initials avatar (default) -->
                    <Border BackgroundColor="#FFFFFF26"
                            HeightRequest="96" WidthRequest="96"
                            HorizontalOptions="Center"
                            IsVisible="{Binding ShowInitials}"
                            Stroke="#FFFFFF4D" StrokeThickness="2">
                        <Border.StrokeShape><RoundRectangle CornerRadius="48"/></Border.StrokeShape>
                        <Label Text="{Binding ComputedInitials}"
                               FontSize="34" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Edit badge -->
                    <Border BackgroundColor="White"
                            HeightRequest="28" WidthRequest="28"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            Margin="0,0,2,2"
                            Stroke="Transparent">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Label Text="✏️" FontSize="13"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- User info -->
                <Label Text="{Binding FullName}"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>
                <Label Text="{Binding Email}"
                       FontSize="14"
                       TextColor="#B3FFFFFF"
                       HorizontalOptions="Center"/>
                <Border BackgroundColor="#FFFFFF1A"
                        Stroke="#FFFFFF66" StrokeThickness="1"
                        HorizontalOptions="Center" Padding="14,5">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <Label Text="{Binding RoleDisplay}"
                           FontSize="11" FontAttributes="Bold"
                           TextColor="White"/>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- ── Settings card (scrollabile) ─────────────────── -->
        <ScrollView Grid.Row="1" Margin="0,-32,0,0">
            <Border BackgroundColor="{StaticResource Surface}"
                    Padding="0,0,0,48"
                    Stroke="Transparent">
                <Border.StrokeShape><RoundRectangle CornerRadius="28,28,0,0"/></Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- ── ACCOUNT ─────────────────────────── -->
                    <VerticalStackLayout Padding="24,24,24,0" Spacing="0">
                        <Label Text="ACCOUNT"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource Outline}"
                               Margin="0,0,0,12"/>
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="#E2E8F0" StrokeThickness="1"
                                Padding="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <VerticalStackLayout>

                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding PickAvatarCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36"
                                            Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="🖼️" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Grid.Column="1" Text="Cambia foto profilo"
                                           FontSize="15" TextColor="{StaticResource OnBackground}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="›" FontSize="22"
                                           TextColor="{StaticResource OutlineVariant}"
                                           VerticalOptions="Center"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"
                                         Margin="16,0"/>

                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ChangePasswordCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36"
                                            Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="🔒" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Grid.Column="1" Text="Cambia Password"
                                           FontSize="15" TextColor="{StaticResource OnBackground}"
                                           VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="›" FontSize="22"
                                           TextColor="{StaticResource OutlineVariant}"
                                           VerticalOptions="Center"/>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ── GESTIONE ATTIVITÀ (admin only) ───── -->
                    <VerticalStackLayout Padding="24,20,24,0" Spacing="0"
                                         IsVisible="{Binding IsAdmin}">
                        <Label Text="GESTIONE ATTIVITÀ"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource Outline}"
                               Margin="0,0,0,12"/>
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="#E2E8F0" StrokeThickness="1"
                                Padding="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <VerticalStackLayout>

                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ManageBusinessesCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36"
                                            Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="🏪" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Le mie attività"
                                               FontSize="15" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Crea e gestisci sedi"
                                               FontSize="12" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="22"
                                           TextColor="{StaticResource OutlineVariant}"
                                           VerticalOptions="Center"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"
                                         Margin="16,0"/>

                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ManageOpeningHoursCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36"
                                            Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="🕐" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Orari di Apertura"
                                               FontSize="15" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Configura apertura/chiusura"
                                               FontSize="12" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="22"
                                           TextColor="{StaticResource OutlineVariant}"
                                           VerticalOptions="Center"/>
                                </Grid>

                                <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}"
                                         Margin="16,0"/>

                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToTeamCommand}"/>
                                    </Grid.GestureRecognizers>
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource SurfaceContainerLow}"
                                            HeightRequest="36" WidthRequest="36"
                                            Stroke="Transparent" Margin="0,0,14,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                        <Label Text="👥" FontSize="18"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="Gestisci Team"
                                               FontSize="15" TextColor="{StaticResource OnBackground}"/>
                                        <Label Text="Aggiungi o modifica dipendenti"
                                               FontSize="12" TextColor="{StaticResource Outline}"/>
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" FontSize="22"
                                           TextColor="{StaticResource OutlineVariant}"
                                           VerticalOptions="Center"/>
                                </Grid>

                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ── Logout + version ───────────────── -->
                    <VerticalStackLayout Padding="24,24,24,0" Spacing="12">
                        <Button Text="Esci dall'account"
                                Command="{Binding LogoutCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Error}"
                                BorderColor="{StaticResource Error}"
                                BorderWidth="1.5" CornerRadius="14"
                                FontSize="15" FontAttributes="Bold"
                                HeightRequest="52"/>

                        <Label Text="Turnify v1.0.0"
                               FontSize="12"
                               TextColor="{StaticResource OutlineVariant}"
                               HorizontalOptions="Center"
                               Margin="0,8,0,0"/>
                    </VerticalStackLayout>

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center"
                                       Color="{StaticResource Primary}"
                                       Margin="0,12,0,0"/>

                </VerticalStackLayout>
            </Border>
        </ScrollView>

    </Grid>
</ContentPage>
