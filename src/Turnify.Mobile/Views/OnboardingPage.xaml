<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.OnboardingPage"
             x:DataType="vm:OnboardingViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Top bar: back + logo + skip -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,16,20,0">

            <!-- Back button (hidden on step 1) -->
            <Border Grid.Column="0"
                    StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}"
                    IsVisible="{Binding IsStep1, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="‹" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PreviousStepCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </Border>

            <!-- Spacer when on step 1 -->
            <BoxView Grid.Column="0" WidthRequest="32" HeightRequest="32" BackgroundColor="Transparent"
                     IsVisible="{Binding IsStep1}"/>

            <!-- Logo -->
            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center"
                                   HorizontalOptions="Center">
                <Border WidthRequest="28" HeightRequest="28"
                        StrokeShape="RoundRectangle CornerRadius='8'"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <Label Text="T" FontSize="14" FontFamily="PJSBold"
                           TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Turnify" FontSize="16" FontFamily="PJSBold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Skip -->
            <Label Grid.Column="2" Text="Salta" FontSize="13" FontFamily="PJSSemi"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SkipOnboardingCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- Progress dots -->
        <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="6" Margin="0,16,0,0">
            <!-- Dot 1 -->
            <BoxView HeightRequest="6" CornerRadius="3"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                <BoxView.Triggers>
                    <DataTrigger TargetType="BoxView" Binding="{Binding Step1Dot}" Value="True">
                        <Setter Property="WidthRequest" Value="20"/>
                    </DataTrigger>
                    <DataTrigger TargetType="BoxView" Binding="{Binding Step1Dot}" Value="False">
                        <Setter Property="WidthRequest" Value="6"/>
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                    </DataTrigger>
                </BoxView.Triggers>
            </BoxView>
            <!-- Dot 2 -->
            <BoxView HeightRequest="6" CornerRadius="3"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}">
                <BoxView.Triggers>
                    <DataTrigger TargetType="BoxView" Binding="{Binding Step2Dot}" Value="True">
                        <Setter Property="WidthRequest" Value="20"/>
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    </DataTrigger>
                    <DataTrigger TargetType="BoxView" Binding="{Binding Step2Dot}" Value="False">
                        <Setter Property="WidthRequest" Value="6"/>
                    </DataTrigger>
                </BoxView.Triggers>
            </BoxView>
            <!-- Dot 3 -->
            <BoxView HeightRequest="6" CornerRadius="3"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}">
                <BoxView.Triggers>
                    <DataTrigger TargetType="BoxView" Binding="{Binding Step3Dot}" Value="True">
                        <Setter Property="WidthRequest" Value="20"/>
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                    </DataTrigger>
                    <DataTrigger TargetType="BoxView" Binding="{Binding Step3Dot}" Value="False">
                        <Setter Property="WidthRequest" Value="6"/>
                    </DataTrigger>
                </BoxView.Triggers>
            </BoxView>
        </HorizontalStackLayout>

        <!-- Step content -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="0">

                <!-- ── STEP 1 – Benvenuto ── -->
                <VerticalStackLayout IsVisible="{Binding IsStep1}"
                                     Padding="24,8,24,0" Spacing="20" VerticalOptions="Center">

                    <!-- 2x2 feature cards -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*" ColumnSpacing="14" RowSpacing="14">

                        <Border Grid.Row="0" Grid.Column="0"
                                StrokeShape="RoundRectangle CornerRadius='16'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="20"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12" VerticalOptions="Fill">
                                <Border WidthRequest="40" HeightRequest="40"
                                        StrokeShape="RoundRectangle CornerRadius='12'"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                    <Label Text="📅" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Gestione turni" FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    <Label Text="Pianifica in pochi tap" FontSize="11" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1"
                                StrokeShape="RoundRectangle CornerRadius='16'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="20"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12" VerticalOptions="Fill">
                                <Border WidthRequest="40" HeightRequest="40"
                                        StrokeShape="RoundRectangle CornerRadius='12'"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource KpiAmberBg}, Dark={StaticResource KpiAmberBgDark}}">
                                    <Label Text="👥" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Il tuo team" FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    <Label Text="Tutti sulla stessa pagina" FontSize="11" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0"
                                StrokeShape="RoundRectangle CornerRadius='16'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="20"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12" VerticalOptions="Fill">
                                <Border WidthRequest="40" HeightRequest="40"
                                        StrokeShape="RoundRectangle CornerRadius='12'"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource KpiBlueBg}, Dark={StaticResource KpiBlueBgDark}}">
                                    <Label Text="🌴" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Ferie e permessi" FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    <Label Text="Approva con un tap" FontSize="11" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1"
                                StrokeShape="RoundRectangle CornerRadius='16'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="20"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12" VerticalOptions="Fill">
                                <Border WidthRequest="40" HeightRequest="40"
                                        StrokeShape="RoundRectangle CornerRadius='12'"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource KpiDangerBg}, Dark={StaticResource KpiDangerBgDark}}">
                                    <Label Text="📊" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Report ore" FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    <Label Text="Esporta in CSV" FontSize="11" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>

                    <!-- Bottom text -->
                    <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                        <Label Text="Benvenuto in Turnify"
                               FontSize="22" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalTextAlignment="Center" CharacterSpacing="-0.4" LineHeight="1.2"/>
                        <Label Text="Configuriamo insieme la tua attività. Tre passi, due minuti."
                               FontSize="14" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalTextAlignment="Center" LineHeight="1.45" Margin="0,8,0,0"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- ── STEP 2 – La tua attività ── -->
                <VerticalStackLayout IsVisible="{Binding IsStep2}"
                                     Padding="24,0,24,0" Spacing="0">

                    <Label Text="La tua attività"
                           FontSize="22" FontFamily="PJSBold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           CharacterSpacing="-0.4"/>
                    <Label Text="Dicci dove lavora il tuo team."
                           FontSize="13" FontFamily="PJSReg"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           Margin="0,6,0,22"/>

                    <VerticalStackLayout Spacing="14">

                        <!-- Nome attività -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                StrokeThickness="2" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="13,0">
                                <Label Text="🏢" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                <Entry Text="{Binding BusinessName}" Placeholder="Es. Pizzeria Roma"
                                       FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Tipo attività -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="💼" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Picker ItemsSource="{Binding BusinessTypes}"
                                        SelectedItem="{Binding BusinessType}"
                                        Title="Seleziona tipo"
                                        FontFamily="PJSReg" FontSize="15"
                                        HorizontalOptions="FillAndExpand"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                        TitleColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Label Text="›" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Indirizzo -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="📍" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding BusinessAddress}" Placeholder="Via Roma 1, Milano"
                                       FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- ── STEP 3 – Primo dipendente ── -->
                <VerticalStackLayout IsVisible="{Binding IsStep3}"
                                     Padding="24,0,24,0" Spacing="0">

                    <Label Text="Aggiungi il primo dipendente"
                           FontSize="22" FontFamily="PJSBold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           CharacterSpacing="-0.4"/>
                    <Label Text="Potrai aggiungerne altri dal Profilo."
                           FontSize="13" FontFamily="PJSReg"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           Margin="0,6,0,22"/>

                    <VerticalStackLayout Spacing="14">

                        <!-- Nome + Cognome row -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Entry Text="{Binding EmployeeFirstName}" Placeholder="Es. Mario"
                                           FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Entry Text="{Binding EmployeeLastName}" Placeholder="Es. Rossi"
                                           FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Email -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="✉" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding EmployeeEmail}" Placeholder="mario.rossi@azienda.it"
                                       Keyboard="Email" FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Password temporanea -->
                        <VerticalStackLayout Spacing="4">
                            <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Label Text="🔒" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <Entry Text="{Binding EmployeePassword}" IsPassword="True"
                                           Placeholder="Password temporanea" FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Label Text="Il dipendente potrà cambiarla al primo accesso."
                                   FontSize="12" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   Margin="4,0,0,0"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer buttons -->
        <Grid Grid.Row="3" Padding="24,20,24,16">

            <!-- Step 1 -->
            <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="10">
                <Button Text="Inizia"
                        Command="{Binding GoToStep2Command}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                        CornerRadius="12" HeightRequest="50"
                        FontFamily="PJSSemi" FontSize="15"/>
                <Button Text="Salta per ora"
                        Command="{Binding SkipOnboardingCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                        FontSize="13" FontFamily="PJSReg"
                        HeightRequest="36"/>
            </VerticalStackLayout>

            <!-- Step 2 -->
            <Grid IsVisible="{Binding IsStep2}" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="Indietro"
                        Command="{Binding PreviousStepCommand}"
                        BackgroundColor="Transparent"
                        BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        BorderWidth="1.5"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        CornerRadius="12" HeightRequest="50"
                        FontFamily="PJSSemi" FontSize="15"/>
                <Button Grid.Column="1" Text="Avanti"
                        Command="{Binding SaveBusinessAndContinueCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                        CornerRadius="12" HeightRequest="50"
                        FontFamily="PJSSemi" FontSize="15"/>
            </Grid>

            <!-- Step 3 -->
            <VerticalStackLayout IsVisible="{Binding IsStep3}" Spacing="10">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" Text="Indietro"
                            Command="{Binding PreviousStepCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            BorderWidth="1.5"
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            CornerRadius="12" HeightRequest="50"
                            FontFamily="PJSSemi" FontSize="15"/>
                    <Button Grid.Column="1" Text="Crea dipendente"
                            Command="{Binding SaveEmployeeAndCompleteCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                            CornerRadius="12" HeightRequest="50"
                            FontFamily="PJSSemi" FontSize="15"/>
                </Grid>
                <Button Text="Aggiungi dopo"
                        Command="{Binding SkipEmployeeCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                        FontSize="13" FontFamily="PJSReg"
                        HeightRequest="36"/>
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

        </Grid>

    </Grid>
</ContentPage>
