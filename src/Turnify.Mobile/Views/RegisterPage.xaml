<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="150,*">

        <!-- Hero -->
        <Grid Grid.Row="0">
            <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                     VerticalOptions="Fill" HorizontalOptions="Fill"/>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="End"
                                 Spacing="6" Padding="24,16,24,28">
                <Label Text="Crea il tuo account"
                       FontSize="24" FontFamily="PJSBold"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                       CharacterSpacing="-0.4"/>
                <Label Text="Registra la tua azienda in pochi secondi"
                       FontSize="14" FontFamily="PJSReg"
                       TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                       Opacity="0.9"/>
            </VerticalStackLayout>
        </Grid>

        <!-- Sheet -->
        <Border Grid.Row="1"
                StrokeShape="RoundRectangle CornerRadius='28,28,0,0'"
                StrokeThickness="0"
                Margin="0,-16,0,0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <ScrollView>
                <VerticalStackLayout Padding="24,8,24,40" Spacing="0">

                    <BoxView WidthRequest="32" HeightRequest="4" CornerRadius="2"
                             HorizontalOptions="Center" Margin="0,10,0,16"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>

                    <!-- Dati Azienda -->
                    <Label Text="DATI AZIENDA" FontSize="11" FontFamily="PJSSemi"
                           CharacterSpacing="0.8" TextTransform="Uppercase"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           Margin="4,0,0,10"/>

                    <VerticalStackLayout Spacing="14">

                        <!-- Nome azienda -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="🏢" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding CompanyName}" Placeholder="Es. Bar Centrale"
                                       FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Slug -->
                        <VerticalStackLayout Spacing="4">
                            <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Label Text="🌐" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <Entry Text="{Binding CompanySlug}" Placeholder="es. bar-centrale"
                                           FontSize="15" FontFamily="PJSReg"
                                           HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Email aziendale -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="✉" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding CompanyEmail}" Placeholder="info@barcentrale.it"
                                       Keyboard="Email" FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                    <!-- Account Admin -->
                    <Label Text="ACCOUNT ADMIN" FontSize="11" FontFamily="PJSSemi"
                           CharacterSpacing="0.8" TextTransform="Uppercase"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                           Margin="4,22,0,10"/>

                    <VerticalStackLayout Spacing="14">

                        <!-- Email admin -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="✉" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding AdminEmail}" Placeholder="admin@barcentrale.it"
                                       Keyboard="Email" FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Password -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="🔒" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding AdminPassword}" Placeholder="Min. 8 caratteri"
                                       IsPassword="True" FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                                <Label Text="👁" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Conferma Password -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Label Text="🔒" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Entry Text="{Binding ConfirmPassword}" Placeholder="Ripeti la password"
                                       IsPassword="True" FontSize="15" FontFamily="PJSReg"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12" Margin="0,22,0,0">

                        <Button Text="Registrati"
                                Command="{Binding RegisterCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

                        <Label HorizontalTextAlignment="Center" FontSize="13" FontFamily="PJSReg"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Hai già un account? " FontFamily="PJSReg"/>
                                    <Span Text="Accedi" FontFamily="PJSSemi"
                                          TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                </FormattedString>
                            </Label.FormattedText>
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
