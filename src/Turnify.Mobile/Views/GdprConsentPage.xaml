<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.GdprConsentPage"
             x:DataType="vm:GdprConsentViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="56,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Surface}"
                Stroke="{StaticResource OutlineVariant}" StrokeThickness="0,0,0,1"
                Padding="20,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="0"/></Border.StrokeShape>
            <HorizontalStackLayout VerticalOptions="Center" Spacing="10">
                <Border BackgroundColor="{StaticResource Navy}"
                        HeightRequest="32" WidthRequest="32" Stroke="Transparent">
                    <Border.StrokeShape><RoundRectangle CornerRadius="9"/></Border.StrokeShape>
                    <Label Text="🛡"
                           FontSize="16"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Privacy &amp; Terms"
                       FontSize="17" FontAttributes="Bold" FontFamily="PJSBold"
                       TextColor="{StaticResource OnBackground}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20" Padding="20,28,20,16">

                <!-- Hero -->
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Border BackgroundColor="{StaticResource Navy}"
                            HeightRequest="76" WidthRequest="76"
                            HorizontalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="24"/></Border.StrokeShape>
                        <Label Text="🛡"
                               FontSize="36"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="La tua privacy è importante"
                           FontSize="22" FontAttributes="Bold" FontFamily="PJSXBold"
                           TextColor="{StaticResource OnBackground}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"
                           CharacterSpacing="-0.5"/>
                    <Label Text="Prima di iniziare, leggi come trattiamo i tuoi dati."
                           FontSize="14" FontFamily="PJSReg"
                           TextColor="{StaticResource OnSurfaceVariant}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Value props -->
                <Border BackgroundColor="{StaticResource Surface}"
                        Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <HorizontalStackLayout Spacing="14" Padding="16,16">
                            <Border BackgroundColor="{StaticResource PrimaryLight}"
                                    HeightRequest="38" WidthRequest="38" Stroke="Transparent">
                                <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                <Label Text="🔒" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Fill">
                                <Label Text="Dati al sicuro"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="Cifrati e conservati su server italiani"
                                       FontSize="12" FontFamily="PJSReg"
                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="16,0"/>

                        <HorizontalStackLayout Spacing="14" Padding="16,16">
                            <Border BackgroundColor="{StaticResource SuccessLight}"
                                    HeightRequest="38" WidthRequest="38" Stroke="Transparent">
                                <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                <Label Text="👥" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Fill">
                                <Label Text="Solo per te"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="Non vendiamo i tuoi dati a terze parti, mai"
                                       FontSize="12" FontFamily="PJSReg"
                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="16,0"/>

                        <HorizontalStackLayout Spacing="14" Padding="16,16">
                            <Border BackgroundColor="{StaticResource PurpleLight}"
                                    HeightRequest="38" WidthRequest="38" Stroke="Transparent">
                                <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                <Label Text="⚙" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Fill">
                                <Label Text="Controllo totale"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="{StaticResource OnBackground}"/>
                                <Label Text="Esporta o elimina i dati in qualsiasi momento"
                                       FontSize="12" FontFamily="PJSReg"
                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Consents -->
                <VerticalStackLayout Spacing="14">
                    <!-- Obbligatorio -->
                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding PrivacyAccepted}"
                                      Color="{StaticResource Primary}"
                                      VerticalOptions="Start"
                                      Margin="0,2,0,0"/>
                            <Label Grid.Column="1" FontSize="14" FontFamily="PJSReg"
                                   TextColor="{StaticResource OnBackground}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Ho letto e accetto la "/>
                                        <Span Text="Privacy Policy"
                                              TextColor="{StaticResource Primary}"
                                              FontAttributes="Bold"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenPrivacyPolicyCommand}"/>
                                            </Span.GestureRecognizers>
                                        </Span>
                                        <Span Text=" e i "/>
                                        <Span Text="Termini di Servizio"
                                              TextColor="{StaticResource Primary}"
                                              FontAttributes="Bold"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenTermsOfServiceCommand}"/>
                                            </Span.GestureRecognizers>
                                        </Span>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </Border>

                    <!-- Marketing -->
                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding MarketingAccepted}"
                                      Color="{StaticResource Primary}"
                                      VerticalOptions="Start"
                                      Margin="0,2,0,0"/>
                            <Label Grid.Column="1"
                                   Text="Acconsento a ricevere comunicazioni di prodotto e aggiornamenti (opzionale)"
                                   FontSize="14" FontFamily="PJSReg"
                                   TextColor="{StaticResource OnBackground}"
                                   LineBreakMode="WordWrap"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <Label FontSize="11" FontFamily="PJSReg"
                       TextColor="{StaticResource Outline}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Puoi revocare il consenso da "/>
                            <Span Text="Impostazioni → Profilo → Gestisci dati" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer CTA -->
        <Grid Grid.Row="2" BackgroundColor="{StaticResource Background}" Padding="20,12,20,36">
            <Button Text="Accetta e continua"
                    Command="{Binding AcceptAndContinueCommand}"
                    HeightRequest="52" CornerRadius="14"
                    FontSize="15" FontAttributes="Bold" FontFamily="PJSBold">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding CanProceed}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource Navy}"/>
                        <Setter Property="TextColor" Value="White"/>
                        <Setter Property="IsEnabled" Value="True"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding CanProceed}" Value="False">
                        <Setter Property="BackgroundColor" Value="{StaticResource OutlineVariant}"/>
                        <Setter Property="TextColor" Value="{StaticResource Outline}"/>
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

    </Grid>
</ContentPage>
