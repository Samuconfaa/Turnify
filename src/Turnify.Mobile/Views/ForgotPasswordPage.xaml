<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E40AF">

    <Grid RowDefinitions="260,*">

        <!-- Hero top -->
        <VerticalStackLayout Grid.Row="0" VerticalOptions="Center"
                             HorizontalOptions="Center" Spacing="8">
            <Label Text="🔑" FontSize="48" HorizontalOptions="Center"/>
            <Label Text="Reimposta password"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"/>
            <Label Text="Ti invieremo un link per reimpostarla"
                   FontSize="14" TextColor="#B3FFFFFF" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Card bianca -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource Surface}"
                Padding="24,32,24,32"
                Margin="0,-28,0,0">
            <Border.StrokeShape><RoundRectangle CornerRadius="28,28,0,0"/></Border.StrokeShape>
            <Border.Stroke>Transparent</Border.Stroke>

            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- Successo -->
                    <VerticalStackLayout IsVisible="{Binding EmailSent}" Spacing="16"
                                         HorizontalOptions="Center">
                        <Label Text="✅" FontSize="56" HorizontalOptions="Center"/>
                        <Label Text="Email inviata!"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource OnBackground}"
                               HorizontalOptions="Center"/>
                        <Label Text="Se l'indirizzo è registrato, riceverai le istruzioni entro qualche minuto. Controlla anche la cartella spam."
                               FontSize="14" TextColor="{StaticResource OnSurfaceVariant}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        <Button Text="Torna al login"
                                Command="{Binding GoBackCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                HeightRequest="52" CornerRadius="12"
                                FontSize="16" FontAttributes="Bold"
                                Margin="0,16,0,0"/>
                    </VerticalStackLayout>

                    <!-- Form -->
                    <VerticalStackLayout IsVisible="{Binding EmailSent, Converter={StaticResource InverseBoolConverter}}"
                                         Spacing="0">

                        <!-- Error banner -->
                        <Border BackgroundColor="{StaticResource ErrorContainer}"
                                Stroke="{StaticResource Error}"
                                StrokeThickness="1" Padding="14,10"
                                IsVisible="{Binding HasError}"
                                Margin="0,0,0,16">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Label Text="{Binding ErrorMessage}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource OnErrorContainer}"/>
                        </Border>

                        <!-- Email field -->
                        <Label Text="Email"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurfaceVariant}"
                               Margin="4,0,0,6"/>
                        <Border BackgroundColor="{StaticResource SurfaceContainerLow}"
                                Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                                Margin="0,0,0,24">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Entry Text="{Binding Email}"
                                   Placeholder="nome@azienda.it"
                                   Keyboard="Email"
                                   HeightRequest="52" Margin="16,0"
                                   TextColor="{StaticResource OnBackground}"
                                   PlaceholderColor="{StaticResource Outline}"
                                   BackgroundColor="Transparent"/>
                        </Border>

                        <!-- Send button -->
                        <Button Text="Invia link di reset"
                                Command="{Binding SendResetCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                HeightRequest="52" CornerRadius="12"
                                FontSize="16" FontAttributes="Bold"
                                Margin="0,0,0,16"/>

                        <!-- Back -->
                        <Button Text="← Torna al login"
                                Command="{Binding GoBackCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource OnSurfaceVariant}"
                                HeightRequest="44" FontSize="14"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center"
                                           Color="{StaticResource Primary}"/>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>
</ContentPage>
