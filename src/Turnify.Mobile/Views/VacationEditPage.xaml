<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.VacationEditPage"
             x:DataType="vm:VacationEditViewModel"
             Title="{Binding Title}"
             BackgroundColor="Transparent">

    <Grid>
        <!-- Dim overlay -->
        <BoxView BackgroundColor="Black" Opacity="0.4"/>

        <!-- Bottom sheet -->
        <Border VerticalOptions="End"
                StrokeShape="RoundRectangle CornerRadius='28,28,0,0'"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-4" Radius="24" Opacity="0.14"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Header -->
                <VerticalStackLayout Grid.Row="0" Spacing="0">
                    <BoxView WidthRequest="32" HeightRequest="4" CornerRadius="2"
                             HorizontalOptions="Center" Margin="0,10,0,6"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                    <Grid ColumnDefinitions="*,Auto" Padding="20,0,20,8">
                        <Label Grid.Column="0" Text="{Binding Title}"
                               FontSize="18" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               CharacterSpacing="-0.3" VerticalOptions="Center"/>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle CornerRadius='10'"
                                StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                            <Label Text="✕" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <!-- Employee badge -->
                    <Border Margin="20,4,20,12"
                            StrokeShape="RoundRectangle CornerRadius='12'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            Padding="14,10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                        <HorizontalStackLayout Spacing="10">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    HeightRequest="32" WidthRequest="32" Stroke="Transparent">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Label Text="👤" FontSize="14"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="{Binding EmployeeName}"
                                   FontSize="14" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Scrollable content -->
                <ScrollView Grid.Row="1" MaximumHeightRequest="520">
                    <VerticalStackLayout Padding="20,4,20,20" Spacing="14">

                        <!-- TIPO DI ASSENZA -->
                        <Label Text="TIPO DI ASSENZA" FontSize="11" FontFamily="PJSSemi"
                               CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,4,0,0"/>
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Picker ItemsSource="{Binding VacationTypesDisplay}"
                                    SelectedIndex="{Binding SelectedTypeIndex}"
                                    FontFamily="PJSReg" FontSize="14"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    Margin="16,0"/>
                        </Border>

                        <!-- Balance info -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="#86EFAC" Padding="14,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SuccessBg}, Dark={StaticResource SuccessBgDark}}"
                                IsVisible="{Binding ShowBalance}">
                            <Label Text="{Binding BalanceLabel}"
                                   FontSize="13" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"/>
                        </Border>
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource WarningBg}, Dark={StaticResource WarningBgDark}}"
                                Padding="14,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource WarningBg}, Dark={StaticResource WarningBgDark}}"
                                IsVisible="{Binding ShowBalanceWarning}">
                            <Label Text="Saldo esaurito — la richiesta verrà comunque inoltrata"
                                   FontSize="13" FontFamily="PJSSemi"
                                   TextColor="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"/>
                        </Border>

                        <!-- PERIODO -->
                        <Label Text="PERIODO" FontSize="11" FontFamily="PJSSemi"
                               CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,4,0,0"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    StrokeThickness="2" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="8" Padding="13,0">
                                    <Label Text="📅" FontSize="15" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                    <DatePicker Date="{Binding StartDate}"
                                                FontFamily="PJSReg" FontSize="14"
                                                HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="8" Padding="13,0">
                                    <Label Text="📅" FontSize="15" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <DatePicker Date="{Binding EndDate}"
                                                FontFamily="PJSReg" FontSize="14"
                                                HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                        <!-- STATO -->
                        <Label Text="STATO" FontSize="11" FontFamily="PJSSemi"
                               CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,4,0,0"/>
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Picker ItemsSource="{Binding StatusOptionsDisplay}"
                                    SelectedIndex="{Binding SelectedStatusIndex}"
                                    FontFamily="PJSReg" FontSize="14"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    Margin="16,0"/>
                        </Border>

                        <!-- NOTA -->
                        <Label Text="NOTA (OPZIONALE)" FontSize="11" FontFamily="PJSSemi"
                               CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,4,0,0"/>
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="14" MinimumHeightRequest="80"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Editor Text="{Binding Reason}"
                                    Placeholder="Motivazione…"
                                    PlaceholderColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                    FontFamily="PJSReg" FontSize="14" LineHeight="1.4"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    AutoSize="TextChanges"/>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Bottom button -->
                <VerticalStackLayout Grid.Row="2" Padding="20,12,20,28" Spacing="0">
                    <BoxView HeightRequest="1"
                             BackgroundColor="{AppThemeBinding Light={StaticResource BorderSoft}, Dark={StaticResource BorderSoftDark}}"
                             Margin="0,0,0,12"/>
                    <Button Text="Salva modifiche"
                            Command="{Binding SaveCommand}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                            CornerRadius="12" HeightRequest="50"
                            FontFamily="PJSSemi" FontSize="15"/>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center" Margin="0,12,0,0"
                                       Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
