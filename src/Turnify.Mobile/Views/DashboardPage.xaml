<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.DashboardPage"
             Title="Dashboard"
             BackgroundColor="{StaticResource Background}">

    <RefreshView Command="{Binding LoadDataCommand}"
                 IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="16,8,16,32">

                <!-- ERROR STATE -->
                <Border IsVisible="{Binding HasError}"
                        BackgroundColor="#FEF2F2"
                        Stroke="#FECACA"
                        StrokeThickness="1"
                        Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="⚠️" FontSize="20" VerticalOptions="Center"/>
                        <Label Text="{Binding ErrorMessage}"
                               FontSize="14"
                               TextColor="#DC2626"
                               VerticalOptions="Center"
                               HorizontalOptions="Fill"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- HEADER -->
                <VerticalStackLayout Margin="0,8,0,0" Spacing="4">
                    <Label Text="Dashboard Admin"
                           FontSize="26" FontAttributes="Bold"
                           TextColor="{StaticResource OnBackground}"/>
                </VerticalStackLayout>

                <!-- KPI CARDS -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                      ColumnSpacing="12" RowSpacing="12">

                    <Border Grid.Row="0" Grid.Column="0"
                            BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Outline}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="👥" FontSize="22"/>
                            <Label Text="{Binding TotalEmployees}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"/>
                            <Label Text="Dipendenti attivi"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1"
                            BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Outline}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="📅" FontSize="22"/>
                            <Label Text="{Binding ShiftsThisWeek}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"/>
                            <Label Text="Turni settimana"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0"
                            BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Outline}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="🏖️" FontSize="22"/>
                            <Label Text="{Binding PendingVacations}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="#D97706"/>
                            <Label Text="Ferie in attesa"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1"
                            BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Outline}"
                            StrokeThickness="1" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="⏱️" FontSize="22"/>
                            <Label Text="{Binding TotalHoursScheduled, StringFormat='{0:0}h'}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource Success}"/>
                            <Label Text="Ore settimana"
                                   FontSize="12"
                                   TextColor="{StaticResource OnSurfaceVariant}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- EMPTY STATE -->
                <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                     HorizontalOptions="Center"
                                     Margin="0,24,0,0" Spacing="12">
                    <Label Text="🏪" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="Nessun dato ancora"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnBackground}"
                           HorizontalOptions="Center"/>
                    <Label Text="Aggiungi dipendenti e crea turni dal menu Team e Turni."
                           FontSize="14"
                           TextColor="{StaticResource OnSurfaceVariant}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- TURNI OGGI -->
                <VerticalStackLayout Spacing="12"
                                     IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">
                    <Label Text="TURNI OGGI"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceVariant}"/>

                    <CollectionView ItemsSource="{Binding ShiftsToday}">
                        <CollectionView.EmptyView>
                            <Border BackgroundColor="{StaticResource Surface}"
                                    Stroke="{StaticResource Outline}"
                                    StrokeThickness="1" Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="Nessun turno programmato per oggi."
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       HorizontalOptions="Center"/>
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DashboardShiftDto">
                                <Border BackgroundColor="{StaticResource Surface}"
                                        Stroke="{StaticResource Outline}"
                                        StrokeThickness="1"
                                        Padding="0" Margin="0,0,0,8">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="4,*">
                                        <BoxView Grid.Column="0"
                                                 BackgroundColor="{StaticResource Success}"
                                                 VerticalOptions="Fill"/>
                                        <Grid Grid.Column="1"
                                              ColumnDefinitions="*,Auto"
                                              Padding="14,12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                <Label Text="{Binding EmployeeName}"
                                                       FontSize="15" FontAttributes="Bold"
                                                       TextColor="{StaticResource OnBackground}"/>
                                                <Label Text="{Binding DisplayTime}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="#E6F4EA"
                                                    Stroke="#CEEAD6"
                                                    StrokeThickness="1"
                                                    Padding="10,4"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="16"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Status}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource Success}"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- RICHIESTE FERIE PENDENTI -->
                <VerticalStackLayout Spacing="12"
                                     IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">
                    <Label Text="RICHIESTE FERIE IN ATTESA"
                           FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurfaceVariant}"/>

                    <CollectionView ItemsSource="{Binding PendingRequests}">
                        <CollectionView.EmptyView>
                            <Border BackgroundColor="{StaticResource Surface}"
                                    Stroke="{StaticResource Outline}"
                                    StrokeThickness="1" Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="Nessuna richiesta in attesa."
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       HorizontalOptions="Center"/>
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DashboardPendingVacationDto">
                                <Border BackgroundColor="{StaticResource Surface}"
                                        Stroke="{StaticResource Outline}"
                                        StrokeThickness="1"
                                        Padding="16" Margin="0,0,0,10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="14">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    BackgroundColor="{StaticResource PrimaryContainer}"
                                                    HeightRequest="44" WidthRequest="44">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="22"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Initials}"
                                                       FontSize="16" FontAttributes="Bold"
                                                       TextColor="{StaticResource Primary}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1"
                                                                 VerticalOptions="Center"
                                                                 Spacing="2">
                                                <Label Text="{Binding EmployeeName}"
                                                       FontSize="15" FontAttributes="Bold"
                                                       TextColor="{StaticResource OnBackground}"/>
                                                <Label Text="{Binding DisplayDate}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource OnSurfaceVariant}"/>
                                            </VerticalStackLayout>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                            <Button Grid.Column="0"
                                                    Text="✕  Rifiuta"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=RejectVacationCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{StaticResource Error}"
                                                    BorderColor="{StaticResource Error}"
                                                    BorderWidth="1"
                                                    CornerRadius="8"
                                                    HeightRequest="40"
                                                    FontSize="14"/>
                                            <Button Grid.Column="1"
                                                    Text="✓  Approva"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=ApproveVacationCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="{StaticResource Success}"
                                                    TextColor="White"
                                                    CornerRadius="8"
                                                    HeightRequest="40"
                                                    FontSize="14"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
