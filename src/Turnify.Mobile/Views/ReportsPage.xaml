<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ReportsPage"
             x:DataType="vm:ReportsViewModel"
             Title="Report"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20,20,20,48">

            <!-- Error -->
            <Border BackgroundColor="{StaticResource ErrorLight}"
                    Stroke="{StaticResource Error}" StrokeThickness="1"
                    Padding="14,10" Margin="0,0,0,14"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}" FontSize="13" FontFamily="PJSSemi"
                       TextColor="{StaticResource ErrorText}"/>
            </Border>

            <!-- Success -->
            <Border BackgroundColor="{StaticResource SuccessLight}"
                    Stroke="{StaticResource Success}" StrokeThickness="1"
                    Padding="14,10" Margin="0,0,0,14"
                    IsVisible="{Binding HasSuccess}">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Label Text="{Binding SuccessMessage}" FontSize="13" FontFamily="PJSSemi"
                       TextColor="{StaticResource SuccessText}"/>
            </Border>

            <!-- Periodo -->
            <Label Text="PERIODO" Style="{StaticResource SectionLabel}" Margin="4,0,0,12"/>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,28">
                <VerticalStackLayout Grid.Column="0" Spacing="6">
                    <Label Text="INIZIO" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource FieldBorder}">
                        <DatePicker Date="{Binding FromDate}"
                                    FontFamily="PJSReg"
                                    TextColor="{StaticResource OnBackground}"
                                    Margin="12,0"/>
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="6">
                    <Label Text="FINE" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource FieldBorder}">
                        <DatePicker Date="{Binding ToDate}"
                                    FontFamily="PJSReg"
                                    TextColor="{StaticResource OnBackground}"
                                    Margin="12,0"/>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Esporta -->
            <Label Text="ESPORTA" Style="{StaticResource SectionLabel}" Margin="4,0,0,12"/>
            <Border BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                    Padding="0">
                <Border.StrokeShape><RoundRectangle CornerRadius="18"/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="16" Opacity="0.06"/>
                </Border.Shadow>

                <!-- Ore pianificate -->
                <VerticalStackLayout>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,18">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DownloadHoursCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                HeightRequest="46" WidthRequest="46"
                                Stroke="Transparent" Margin="0,0,14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                            <Label Text="⏰" FontSize="22"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                            <Label Text="Ore pianificate"
                                   FontSize="15" FontAttributes="Bold" FontFamily="PJSBold"
                                   TextColor="{StaticResource OnBackground}"/>
                            <Label Text="Turni programmati per dipendente · CSV"
                                   FontSize="12" FontFamily="PJSReg"
                                   TextColor="{StaticResource Outline}"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource PrimaryLight}"
                                HeightRequest="34" WidthRequest="34"
                                Stroke="Transparent" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="17"/></Border.StrokeShape>
                            <Label Text="↓" FontSize="18" FontAttributes="Bold" FontFamily="PJSBold"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource OutlineVariant}" Margin="16,0"/>

                    <!-- Presenze effettive -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,18">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DownloadAttendanceCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource SuccessLight}"
                                HeightRequest="46" WidthRequest="46"
                                Stroke="Transparent" Margin="0,0,14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="13"/></Border.StrokeShape>
                            <Label Text="📋" FontSize="22"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                            <Label Text="Presenze effettive"
                                   FontSize="15" FontAttributes="Bold" FontFamily="PJSBold"
                                   TextColor="{StaticResource OnBackground}"/>
                            <Label Text="Timbrature reali: giorni e ore lavorate · CSV"
                                   FontSize="12" FontFamily="PJSReg"
                                   TextColor="{StaticResource Outline}"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="2"
                                BackgroundColor="{StaticResource SuccessLight}"
                                HeightRequest="34" WidthRequest="34"
                                Stroke="Transparent" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="17"/></Border.StrokeShape>
                            <Label Text="↓" FontSize="18" FontAttributes="Bold" FontFamily="PJSBold"
                                   TextColor="{StaticResource Success}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center" Margin="0,16,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
