<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.AttendanceHistoryPage"
             x:DataType="vm:AttendanceHistoryViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,8,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="&#8249;" FontSize="18" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Storico presenze" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
        </Grid>

        <!-- Content -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadDataCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Entries}"
                            RemainingItemsThreshold="5"
                            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}">

                <CollectionView.Header>
                    <VerticalStackLayout Padding="16,14,16,0" Spacing="12">

                        <!-- Month navigator -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Grid ColumnDefinitions="44,*,44" Padding="4,10">
                                <Button Grid.Column="0" Text="&#8249;"
                                        Command="{Binding PreviousMonthCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                        FontSize="22" FontFamily="PJSSemi"
                                        Padding="0" HeightRequest="36"/>
                                <Label Grid.Column="1" Text="{Binding MonthLabel}" FontSize="14" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Button Grid.Column="2" Text="&#8250;"
                                        Command="{Binding NextMonthCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                        FontSize="22" FontFamily="PJSSemi"
                                        Padding="0" HeightRequest="36"/>
                            </Grid>
                        </Border>

                        <!-- KPI 2-col -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    Padding="14"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="GIORNI LAVORATI" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.4"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <Label Text="{Binding DaysWorked, StringFormat='{0}'}"
                                           FontSize="24" FontFamily="PJSBold" CharacterSpacing="-0.6"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    Padding="14"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="ORE TOTALI" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.4"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <Label Text="{Binding TotalHours, StringFormat='{0:F1} h'}"
                                           FontSize="24" FontFamily="PJSBold" CharacterSpacing="-0.6"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Section label -->
                        <Label Text="REGISTRO GIORNALIERO" FontSize="11" FontFamily="PJSSemi" CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,4,0,0"/>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                         Spacing="10" Margin="0,40,0,0">
                        <Label Text="&#8212;"
                               FontSize="40" FontAttributes="Bold" FontFamily="PJSXBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Nessuna presenza registrata"
                               FontSize="15" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:AttendanceEntryDto">
                        <Border StrokeShape="RoundRectangle CornerRadius='12'" StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="12,12" Margin="16,0,16,6"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="12">
                                <Border WidthRequest="32" HeightRequest="32" StrokeShape="RoundRectangle CornerRadius='10'"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding IsComplete, Converter={StaticResource BoolToShiftColorConverter}}">
                                    <Label Text="&#10003;" FontSize="14"
                                           TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding DayLabel}" FontSize="13" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       VerticalOptions="Center" WidthRequest="60"/>
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                    <Label Text="{Binding TimeDisplay}" FontSize="13" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                </HorizontalStackLayout>
                                <Label Text="{Binding HoursLabel}" FontSize="13" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <VerticalStackLayout Padding="0,6,0,24">
                        <ActivityIndicator IsRunning="{Binding IsLoadingMore}"
                                           IsVisible="{Binding IsLoadingMore}"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                           HorizontalOptions="Center" Margin="0,8,0,0"/>
                    </VerticalStackLayout>
                </CollectionView.Footer>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
