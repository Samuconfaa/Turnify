<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.GdprConsentPage"
             x:DataType="vm:GdprConsentViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="20,12,20,16"
              BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                <Label Text="🛡" FontSize="16"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
            <Label Grid.Column="1" Text="Privacy &amp; Terms" FontSize="18" FontFamily="PJSBold"
                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="-0.3"/>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="22,22,22,28" Spacing="18">

                <!-- Hero section -->
                <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                    <Border WidthRequest="72" HeightRequest="72"
                            StrokeShape="RoundRectangle CornerRadius='20'"
                            StrokeThickness="0" HorizontalOptions="Center"
                            BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                        <Label Text="🛡" FontSize="36"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="La tua privacy è importante" FontSize="22" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               CharacterSpacing="-0.4"/>
                        <Label Text="Prima di iniziare, leggi come trattiamo i tuoi dati."
                               FontSize="13" FontFamily="PJSReg" LineHeight="1.5"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Value props card -->
                <Border StrokeShape="RoundRectangle CornerRadius='16'" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        Padding="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.06"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <HorizontalStackLayout Spacing="14" Padding="16,16">
                            <Border WidthRequest="38" HeightRequest="38"
                                    StrokeShape="RoundRectangle CornerRadius='11'"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                                <Label Text="🔒" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Fill">
                                <Label Text="Dati al sicuro"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                <Label Text="Cifrati e conservati su server italiani"
                                       FontSize="12" FontFamily="PJSReg"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}" Margin="16,0"/>

                        <HorizontalStackLayout Spacing="14" Padding="16,16">
                            <Border WidthRequest="38" HeightRequest="38"
                                    StrokeShape="RoundRectangle CornerRadius='11'"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource KpiGreenBg}, Dark={StaticResource KpiGreenBgDark}}">
                                <Label Text="👥" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Fill">
                                <Label Text="Solo per te"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                <Label Text="Non vendiamo i tuoi dati a terze parti, mai"
                                       FontSize="12" FontFamily="PJSReg"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}" Margin="16,0"/>

                        <HorizontalStackLayout Spacing="14" Padding="16,16">
                            <Border WidthRequest="38" HeightRequest="38"
                                    StrokeShape="RoundRectangle CornerRadius='11'"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource KpiAmberBg}, Dark={StaticResource KpiAmberBgDark}}">
                                <Label Text="⚙" FontSize="18"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Fill">
                                <Label Text="Controllo totale"
                                       FontSize="13" FontAttributes="Bold" FontFamily="PJSBold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                <Label Text="Esporta o elimina i dati in qualsiasi momento"
                                       FontSize="12" FontFamily="PJSReg"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Consents -->
                <VerticalStackLayout Spacing="12">

                    <!-- Obbligatorio -->
                    <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            Padding="16,14"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding PrivacyAccepted}"
                                      Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                      VerticalOptions="Start"
                                      Margin="0,2,0,0"/>
                            <Label Grid.Column="1" FontSize="14" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Ho letto e accetto la "/>
                                        <Span Text="Privacy Policy"
                                              TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                              FontAttributes="Bold"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenPrivacyPolicyCommand}"/>
                                            </Span.GestureRecognizers>
                                        </Span>
                                        <Span Text=" e i "/>
                                        <Span Text="Termini di Servizio"
                                              TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                              FontAttributes="Bold"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding OpenTermsOfServiceCommand}"/>
                                            </Span.GestureRecognizers>
                                        </Span>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </Border>

                    <!-- Marketing -->
                    <Border StrokeShape="RoundRectangle CornerRadius='14'" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            Padding="16,14"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding MarketingAccepted}"
                                      Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                      VerticalOptions="Start"
                                      Margin="0,2,0,0"/>
                            <Label Grid.Column="1"
                                   Text="Acconsento a ricevere comunicazioni di prodotto e aggiornamenti (opzionale)"
                                   FontSize="14" FontFamily="PJSReg"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   LineBreakMode="WordWrap"/>
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <Label FontSize="11" FontFamily="PJSReg"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Puoi revocare il consenso da "/>
                            <Span Text="Impostazioni → Profilo → Gestisci dati" FontAttributes="Bold"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer CTA -->
        <Grid Grid.Row="2"
              BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}"
              Padding="20,12,20,36">
            <Button Text="Accetta e continua"
                    Command="{Binding AcceptAndContinueCommand}"
                    CornerRadius="12" HeightRequest="50"
                    FontSize="15" FontAttributes="Bold" FontFamily="PJSBold">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding CanProceed}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"/>
                        <Setter Property="IsEnabled" Value="True"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding CanProceed}" Value="False">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

    </Grid>
</ContentPage>
