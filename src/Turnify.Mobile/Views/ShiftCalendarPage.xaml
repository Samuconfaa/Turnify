<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             xmlns:comp="clr-namespace:Turnify.Mobile.Views.Components"
             x:Class="Turnify.Mobile.Views.ShiftCalendarPage"
             x:DataType="vm:ShiftCalendarViewModel"
             x:Name="page"
             Title="Turni"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource BgDark}}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="12" Padding="20,8,20,14"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="Turni" FontSize="22" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                       CharacterSpacing="-0.4" VerticalOptions="Center"/>
                <!-- Admin action buttons -->
                <HorizontalStackLayout Grid.Column="1" Spacing="8" IsVisible="{Binding IsAdmin}">
                    <!-- View mode toggle -->
                    <Border StrokeShape="RoundRectangle CornerRadius='10'"
                            StrokeThickness="0" WidthRequest="36" HeightRequest="36"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ChangeViewModeCommand}"
                                                  CommandParameter="{x:Static vm:CalendarViewMode.Day}"/>
                        </Border.GestureRecognizers>
                        <Label Text="≡" FontSize="16" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <!-- Add shift -->
                    <Border StrokeShape="RoundRectangle CornerRadius='10'"
                            StrokeThickness="0" WidthRequest="36" HeightRequest="36"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding AddShiftCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="+" FontSize="20" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <!-- Week nav -->
            <HorizontalStackLayout Spacing="8">
                <!-- Prev week -->
                <Border StrokeShape="RoundRectangle CornerRadius='10'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        WidthRequest="32" HeightRequest="32"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PreviousWeekCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="‹" FontSize="16" FontFamily="PJSSemi"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <!-- Week label -->
                <Border StrokeShape="RoundRectangle CornerRadius='10'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        HeightRequest="32"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToTodayCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8" Padding="14,0">
                        <Label Text="📅" FontSize="14" VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                        <Label Text="{Binding WeekLabel}" FontSize="13" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                <!-- Next week -->
                <Border StrokeShape="RoundRectangle CornerRadius='10'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        WidthRequest="32" HeightRequest="32"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NextWeekCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="›" FontSize="16" FontFamily="PJSSemi"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <!-- Oggi pill (only when not current week) -->
                <Border StrokeShape="RoundRectangle CornerRadius='10'"
                        StrokeThickness="0" HeightRequest="32"
                        HorizontalOptions="EndAndExpand"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                        IsVisible="{Binding IsCurrentWeek, Converter={StaticResource InverseBoolConverter}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToTodayCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="Oggi" FontSize="13" FontFamily="PJSSemi" Padding="12,0"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           VerticalOptions="Center"/>
                </Border>
            </HorizontalStackLayout>

            <!-- Admin: view mode tabs (Employee / Day) -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="6" IsVisible="{Binding IsAdmin}">
                <!-- Employee mode tab -->
                <Border Grid.Column="0" Padding="0,8">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChangeViewModeCommand}"
                                              CommandParameter="{x:Static vm:CalendarViewMode.Employee}"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAdminEmployeeMode}" Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                            <Setter Property="Stroke" Value="Transparent"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAdminEmployeeMode}" Value="False">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}"/>
                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Dipendenti" FontSize="11" FontFamily="PJSBold"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAdminEmployeeMode}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAdminEmployeeMode}" Value="False">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
                <!-- Day mode tab -->
                <Border Grid.Column="1" Padding="0,8">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChangeViewModeCommand}"
                                              CommandParameter="{x:Static vm:CalendarViewMode.Day}"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAdminDayMode}" Value="True">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                            <Setter Property="Stroke" Value="Transparent"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAdminDayMode}" Value="False">
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}"/>
                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="Giorno" FontSize="11" FontFamily="PJSBold"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAdminDayMode}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAdminDayMode}" Value="False">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>
            </Grid>

            <!-- Admin: Copy previous week -->
            <Border StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                    Padding="0" IsVisible="{Binding IsAdmin}"
                    BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CopyPreviousWeekCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" Padding="16,10">
                    <Label Text="Duplica settimana precedente"
                           FontSize="13" FontFamily="PJSBold"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!-- Content area -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <!-- Error banner -->
            <Border Grid.Row="0" IsVisible="{Binding HasError}"
                    StrokeShape="RoundRectangle CornerRadius='10'"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                    Padding="12,8" Margin="16,8,16,0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBg}, Dark={StaticResource ErrorBgDark}}">
                <Label Text="{Binding ErrorMessage}"
                       FontSize="13" FontFamily="PJSSemi"
                       TextColor="{AppThemeBinding Light={StaticResource ErrorText}, Dark={StaticResource ErrorTextDark}}"
                       VerticalOptions="Center"/>
            </Border>

            <!-- ═══ EMPLOYEE VIEW ═══ -->
            <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*"
                  IsVisible="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}">

                <!-- Timbratura card -->
                <Border Grid.Row="0"
                        StrokeShape="RoundRectangle CornerRadius='16'"
                        StrokeThickness="0" Padding="16"
                        Margin="16,12,16,4"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}">
                    <VerticalStackLayout Spacing="0">
                        <HorizontalStackLayout Spacing="12">
                            <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                     VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                <Label Text="TIMBRATURA OGGI" FontSize="12" FontFamily="PJSSemi"
                                       CharacterSpacing="0.4"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                <Label Text="{Binding AttendanceStatusText}"
                                       FontSize="15" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,14,0,0">
                            <Button Grid.Column="0" Text="Timbra Entrata"
                                    Command="{Binding CheckInCommand}"
                                    IsVisible="{Binding CanCheckIn}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                    CornerRadius="11" HeightRequest="44"
                                    FontFamily="PJSSemi" FontSize="14"/>
                            <Button Grid.Column="1" Text="Timbra Uscita"
                                    Command="{Binding CheckOutCommand}"
                                    IsVisible="{Binding CanCheckOut}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                    BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    BorderWidth="1"
                                    TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                    CornerRadius="11" HeightRequest="44"
                                    FontFamily="PJSSemi" FontSize="14"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Check-in feedback -->
                <Border Grid.Row="1"
                        IsVisible="{Binding HasCheckInFeedback}"
                        StrokeShape="RoundRectangle CornerRadius='10'"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"
                        Padding="12,7" Margin="16,4,16,0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource SuccessBg}, Dark={StaticResource SuccessBgDark}}">
                    <Label Text="{Binding CheckInFeedback}"
                           FontSize="13" FontFamily="PJSSemi"
                           TextColor="{AppThemeBinding Light={StaticResource SuccessText}, Dark={StaticResource SuccessTextDark}}"
                           VerticalOptions="Center"/>
                </Border>

                <Label Grid.Row="1" Text="QUESTA SETTIMANA" FontSize="11" FontFamily="PJSSemi"
                       CharacterSpacing="0.8" Margin="20,12,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                       IsVisible="{Binding HasCheckInFeedback, Converter={StaticResource InverseBoolConverter}}"/>

                <!-- Shift list -->
                <RefreshView Grid.Row="2"
                             Command="{Binding LoadShiftsCommand}"
                             IsRefreshing="{Binding IsBusy}">
                    <CollectionView ItemsSource="{Binding Shifts}" Margin="0,4,0,0">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 Margin="0,52,0,0" Spacing="12">
                                <Label Text="—" FontSize="48" FontFamily="PJSBold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Nessun turno questa settimana"
                                       FontSize="17" FontFamily="PJSBold"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       HorizontalOptions="Center"/>
                                <Label Text="I tuoi turni appariranno qui quando l'admin li assegna."
                                       FontSize="14" FontFamily="PJSReg"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                       Margin="28,0"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShiftDto">
                                <Border StrokeShape="RoundRectangle CornerRadius='14'"
                                        StrokeThickness="1"
                                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                        Margin="16,0,16,10"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                    <Border.Shadow><Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/></Border.Shadow>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsToday}" Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                            <Setter Property="StrokeThickness" Value="1.5"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Grid ColumnDefinitions="4,*" ColumnSpacing="0">
                                        <BoxView Grid.Column="0" CornerRadius="14,0,0,14"
                                                 BackgroundColor="{Binding AccentColor}"/>
                                        <HorizontalStackLayout Grid.Column="1" Spacing="12" Padding="14,14,16,14">
                                            <VerticalStackLayout Spacing="2" WidthRequest="60" VerticalOptions="Center">
                                                <Label Text="{Binding StartTime, StringFormat='{0:ddd dd}'}" FontSize="13" FontFamily="PJSSemi"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                                <Label Text="Oggi" FontSize="11" FontFamily="PJSSemi"
                                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                       IsVisible="{Binding IsToday}"/>
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                                <Label Text="{Binding Label, TargetNullValue='Turno'}" FontSize="14" FontFamily="PJSSemi"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                                <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}" FontSize="13" FontFamily="PJSReg"
                                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                            </VerticalStackLayout>
                                            <Border StrokeShape="RoundRectangle CornerRadius='8'"
                                                    StrokeThickness="0" Padding="8,4"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding EndTime, StringFormat='fino {0:HH:mm}'}"
                                                       FontSize="11" FontFamily="PJSSemi"
                                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>

            <!-- ═══ ADMIN EMPLOYEE GRID VIEW ═══ -->
            <Grid Grid.Row="1" IsVisible="{Binding IsAdminEmployeeMode}" RowDefinitions="Auto,*">

                <!-- Day header row -->
                <Border Grid.Row="0"
                        StrokeShape="RoundRectangle CornerRadius='0'"
                        StrokeThickness="0,0,0,1"
                        Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                        Padding="0,6,0,6"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                    <Grid ColumnDefinitions="60,*,*,*,*,*,*,*">
                        <Label Grid.Column="0"/>
                        <Border Grid.Column="1" Padding="2,4" Stroke="Transparent">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayColumnIndex}" Value="0">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="LUN" HorizontalOptions="Center" FontSize="9" FontFamily="PJSBold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   CharacterSpacing="0.5"/>
                        </Border>
                        <Border Grid.Column="2" Padding="2,4" Stroke="Transparent">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayColumnIndex}" Value="1">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="MAR" HorizontalOptions="Center" FontSize="9" FontFamily="PJSBold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   CharacterSpacing="0.5"/>
                        </Border>
                        <Border Grid.Column="3" Padding="2,4" Stroke="Transparent">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayColumnIndex}" Value="2">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="MER" HorizontalOptions="Center" FontSize="9" FontFamily="PJSBold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   CharacterSpacing="0.5"/>
                        </Border>
                        <Border Grid.Column="4" Padding="2,4" Stroke="Transparent">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayColumnIndex}" Value="3">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="GIO" HorizontalOptions="Center" FontSize="9" FontFamily="PJSBold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   CharacterSpacing="0.5"/>
                        </Border>
                        <Border Grid.Column="5" Padding="2,4" Stroke="Transparent">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayColumnIndex}" Value="4">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="VEN" HorizontalOptions="Center" FontSize="9" FontFamily="PJSBold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                   CharacterSpacing="0.5"/>
                        </Border>
                        <Border Grid.Column="6" Padding="2,4" Stroke="Transparent">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayColumnIndex}" Value="5">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="SAB" HorizontalOptions="Center" FontSize="9" FontFamily="PJSBold"
                                   TextColor="#B45309"
                                   CharacterSpacing="0.5"/>
                        </Border>
                        <Border Grid.Column="7" Padding="2,4" Stroke="Transparent">
                            <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TodayColumnIndex}" Value="6">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="DOM" HorizontalOptions="Center" FontSize="9" FontFamily="PJSBold"
                                   TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                   CharacterSpacing="0.5"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Employee rows -->
                <RefreshView Grid.Row="1"
                             Command="{Binding LoadShiftsCommand}"
                             IsRefreshing="{Binding IsBusy}">
                    <CollectionView ItemsSource="{Binding EmployeeRows}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 Margin="0,48,0,0" Spacing="10">
                                <Label Text="Nessun dato questa settimana"
                                       FontSize="15" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:EmployeeWeekRow">
                                <Grid ColumnDefinitions="60,*,*,*,*,*,*,*"
                                      Padding="0,2" MinimumHeightRequest="62"
                                      BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                    <BoxView Grid.ColumnSpan="8"
                                             HeightRequest="1" VerticalOptions="End"
                                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                             Opacity="0.5"/>
                                    <!-- Avatar + name -->
                                    <VerticalStackLayout Grid.Column="0"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Spacing="3" Padding="3,0">
                                        <Border StrokeShape="RoundRectangle CornerRadius='14'"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource PrimaryLightDark}}"
                                                HeightRequest="28" WidthRequest="28"
                                                HorizontalOptions="Center">
                                            <Label Text="{Binding Initials}"
                                                   FontSize="10" FontFamily="PJSBold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Label Text="{Binding EmployeeName}"
                                               FontSize="8" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                               HorizontalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"/>
                                    </VerticalStackLayout>
                                    <!-- Day cells -->
                                    <Border Grid.Column="1" Margin="2" StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            BackgroundColor="{Binding Days[0].CellColor}" Padding="2">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftCalendarViewModel}}, Path=TapShiftCommand}" CommandParameter="{Binding Days[0]}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Days[0].Label}" FontSize="9" FontFamily="PJSBold"
                                               TextColor="{Binding Days[0].LabelColor}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="2" Margin="2" StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            BackgroundColor="{Binding Days[1].CellColor}" Padding="2">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftCalendarViewModel}}, Path=TapShiftCommand}" CommandParameter="{Binding Days[1]}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Days[1].Label}" FontSize="9" FontFamily="PJSBold" TextColor="{Binding Days[1].LabelColor}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="3" Margin="2" StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            BackgroundColor="{Binding Days[2].CellColor}" Padding="2">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftCalendarViewModel}}, Path=TapShiftCommand}" CommandParameter="{Binding Days[2]}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Days[2].Label}" FontSize="9" FontFamily="PJSBold" TextColor="{Binding Days[2].LabelColor}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="4" Margin="2" StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            BackgroundColor="{Binding Days[3].CellColor}" Padding="2">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftCalendarViewModel}}, Path=TapShiftCommand}" CommandParameter="{Binding Days[3]}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Days[3].Label}" FontSize="9" FontFamily="PJSBold" TextColor="{Binding Days[3].LabelColor}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="5" Margin="2" StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            BackgroundColor="{Binding Days[4].CellColor}" Padding="2">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftCalendarViewModel}}, Path=TapShiftCommand}" CommandParameter="{Binding Days[4]}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Days[4].Label}" FontSize="9" FontFamily="PJSBold" TextColor="{Binding Days[4].LabelColor}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="6" Margin="2" StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            BackgroundColor="{Binding Days[5].CellColor}" Padding="2">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftCalendarViewModel}}, Path=TapShiftCommand}" CommandParameter="{Binding Days[5]}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Days[5].Label}" FontSize="9" FontFamily="PJSBold" TextColor="{Binding Days[5].LabelColor}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="7" Margin="2" StrokeShape="RoundRectangle CornerRadius='8'" StrokeThickness="0"
                                            BackgroundColor="{Binding Days[6].CellColor}" Padding="2">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ShiftCalendarViewModel}}, Path=TapShiftCommand}" CommandParameter="{Binding Days[6]}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding Days[6].Label}" FontSize="9" FontFamily="PJSBold" TextColor="{Binding Days[6].LabelColor}" HorizontalOptions="Center" VerticalOptions="Center" HorizontalTextAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>

            <!-- ═══ ADMIN DAY VIEW ═══ -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*"
                  IsVisible="{Binding IsAdminDayMode}">
                <!-- Day selector -->
                <Grid Grid.Row="0" ColumnDefinitions="40,*,40" Padding="8,8,8,4">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle CornerRadius='10'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            WidthRequest="32" HeightRequest="32"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                            HorizontalOptions="Center" VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PreviousDayCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="‹" FontSize="16" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Grid.Column="1" Text="{Binding DayLabel}"
                           FontSize="14" FontFamily="PJSBold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border Grid.Column="2" StrokeShape="RoundRectangle CornerRadius='10'"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                            WidthRequest="32" HeightRequest="32"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                            HorizontalOptions="Center" VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NextDayCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="›" FontSize="16" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding DaySlots}"
                                Margin="16,0,16,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TimeSlot">
                            <Grid ColumnDefinitions="52,*" Padding="0,2" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="{Binding Time}"
                                       FontSize="11" FontFamily="PJSSemi"
                                       TextColor="{Binding TimeColor}"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1"
                                        StrokeShape="RoundRectangle CornerRadius='8'"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding RowColor}"
                                        Padding="10,6"
                                        MinimumHeightRequest="36">
                                    <Label Text="{Binding EmployeesDisplay}"
                                           FontSize="12" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                           LineBreakMode="TailTruncation"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Activity indicator overlay -->
            <ActivityIndicator Grid.Row="1"
                               IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               ZIndex="10"/>
        </Grid>

        <!-- Tab bar -->
        <Border Grid.Row="2"
                StrokeShape="RoundRectangle CornerRadius='28'"
                StrokeThickness="1"
                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                Padding="6" Margin="16,8,16,24"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Border.Shadow><Shadow Brush="Black" Offset="0,6" Radius="24" Opacity="0.10"/></Border.Shadow>
            <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="4">
                <!-- Casa -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToDashCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="⊞" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Casa" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
                <!-- Turni (active) -->
                <Border Grid.Column="1" StrokeShape="RoundRectangle CornerRadius='22'"
                        StrokeThickness="0" HeightRequest="44"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                        <Label Text="📅" FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                               HorizontalOptions="Center"/>
                        <Label Text="Turni" FontSize="9" FontFamily="PJSSemi"
                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <!-- Ferie/Team -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLeaveCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🌴" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Ferie" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
                <!-- Notifiche/Report -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToNotificationsOrReportsCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🔔" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Notifiche" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
                <!-- Profilo -->
                <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" VerticalOptions="Center" Spacing="1">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToProfileCommand}"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="👤" FontSize="18" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                    <Label Text="Profilo" FontSize="9" FontFamily="PJSSemi" HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
