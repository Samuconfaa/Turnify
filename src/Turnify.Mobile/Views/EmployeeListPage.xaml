<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.EmployeeListPage"
             x:DataType="vm:EmployeeListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto, *">
        
        <!-- Toolbar & Filters -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="16" Margin="16,16,16,8">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*, Auto">
                <Picker Grid.Column="0" 
                        ItemsSource="{Binding Businesses}" 
                        ItemDisplayBinding="{Binding Name}" 
                        SelectedItem="{Binding SelectedBusiness}" 
                        Title="Filtra per attività..." />
                
                <Button Grid.Column="1" 
                        Text="+" 
                        Command="{Binding AddEmployeeCommand}"
                        WidthRequest="40" HeightRequest="40"
                        CornerRadius="20" Padding="0"
                        VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Employee List -->
        <RefreshView Grid.Row="1" Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Employees}" Margin="16,0,16,16">
                <CollectionView.EmptyView>
                    <Label Text="Nessun dipendente trovato." HorizontalOptions="Center" VerticalOptions="Center" TextColor="Gray" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:EmployeeListDto">
                        <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="16" Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EmployeeListViewModel}}, Path=EditEmployeeCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <!-- Avatar -->
                                <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainerHigh}" HeightRequest="50" WidthRequest="50" Margin="0,0,16,0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="25" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding Initials}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource OnSurfaceVariant}" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding FullName}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource OnBackground}" />
                                    <Label Text="{Binding Role}" FontSize="14" TextColor="{StaticResource OnSurfaceVariant}" />
                                </VerticalStackLayout>

                                <!-- Status -->
                                <Border Grid.Column="2" BackgroundColor="#E6F4EA" Stroke="#CEEAD6" Padding="8,4" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="BackgroundColor" Value="#FCE8E6" />
                                            <Setter Property="Stroke" Value="#FAD2CF" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding StatusText}" FontSize="12" TextColor="{StaticResource Success}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsActive}" Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource Error}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
