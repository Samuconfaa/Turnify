<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.DashboardPage"
             Title="Dashboard"
             BackgroundColor="{StaticResource Background}">
    <Grid>
        <!-- Activity Indicator -->
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" VerticalOptions="Center" ZIndex="10" />

        <ScrollView IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}, FallbackValue=True}">
            <VerticalStackLayout Spacing="24" Padding="16">
                <!-- Header Section -->
                <Grid ColumnDefinitions="*, Auto" Margin="0,16,0,8">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Dashboard Admin" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource OnBackground}" />
                        <Label Text="Statistiche aggregate" FontSize="14" TextColor="{StaticResource OnSurfaceVariant}" Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Grid>

                <!-- KPI Section -->
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="16" RowSpacing="16">
                    <!-- Card 1 -->
                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="👥" FontSize="20" HorizontalOptions="Start" Margin="0,0,0,8"/>
                            <Label Text="{Binding TotalEmployees}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Label Text="Dipendenti" FontSize="12" TextColor="{StaticResource OnSurfaceVariant}" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Card 2 -->
                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="📅" FontSize="20" HorizontalOptions="Start" Margin="0,0,0,8"/>
                            <Label Text="{Binding ShiftsThisWeek}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Label Text="Turni settimana" FontSize="12" TextColor="{StaticResource OnSurfaceVariant}" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Card 3 -->
                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="🏖️" FontSize="20" HorizontalOptions="Start" Margin="0,0,0,8"/>
                            <Label Text="{Binding PendingVacations}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Tertiary}" />
                            <Label Text="Ferie in attesa" FontSize="12" TextColor="{StaticResource OnSurfaceVariant}" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Card 4 -->
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <VerticalStackLayout>
                            <Label Text="⏱️" FontSize="20" HorizontalOptions="Start" Margin="0,0,0,8"/>
                            <Label Text="{Binding TotalHoursScheduled, StringFormat='{0:0}h'}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Success}" />
                            <Label Text="Ore totali" FontSize="12" TextColor="{StaticResource OnSurfaceVariant}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Turni Oggi Section -->
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="TURNI OGGI" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource OnBackground}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Vedi tutti ➔" FontSize="14" TextColor="{StaticResource Primary}" TextDecorations="Underline" VerticalOptions="Center" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding ShiftsToday}">
                        <CollectionView.EmptyView>
                            <Label Text="Nessun turno oggi." TextColor="{StaticResource OnSurfaceVariant}" Margin="0,10" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DashboardShiftDto">
                                <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="0" Margin="0,0,0,10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="4, *" RowDefinitions="Auto">
                                        <BoxView Grid.Column="0" BackgroundColor="{StaticResource Success}" />
                                        <Grid Grid.Column="1" ColumnDefinitions="*, Auto" Padding="16">
                                            <VerticalStackLayout Grid.Column="0">
                                                <Label Text="{Binding EmployeeName}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource OnBackground}" />
                                                <Label Text="{Binding DisplayTime}" FontSize="14" TextColor="{StaticResource OnSurfaceVariant}" Margin="0,4,0,0" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1" BackgroundColor="#E6F4EA" Stroke="#CEEAD6" Padding="8,4" VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="16" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Status}" FontSize="12" TextColor="{StaticResource Success}" />
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Richieste Pendenti Section -->
                <VerticalStackLayout Spacing="16" Margin="0,8,0,0">
                    <Label Text="RICHIESTE PENDENTI" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource OnBackground}" />
                    
                    <CollectionView ItemsSource="{Binding PendingRequests}">
                        <CollectionView.EmptyView>
                            <Label Text="Nessuna richiesta in attesa." TextColor="{StaticResource OnSurfaceVariant}" Margin="0,10" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DashboardPendingVacationDto">
                                <Border BackgroundColor="{StaticResource Surface}" Stroke="{StaticResource Outline}" Padding="16" Margin="0,0,0,10">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="16">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainerHigh}" HeightRequest="40" WidthRequest="40" Padding="0" Margin="0,0,12,0" VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="20" />
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Initials}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource OnSurfaceVariant}" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label Text="{Binding EmployeeName}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource OnBackground}" />
                                                <Label Text="{Binding DisplayDate}" FontSize="14" TextColor="{StaticResource OnSurfaceVariant}" />
                                            </VerticalStackLayout>
                                        </Grid>
                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                            <Button Grid.Column="0" Text="Rifiuta" BackgroundColor="Transparent" TextColor="{StaticResource Error}" BorderColor="{StaticResource Outline}" BorderWidth="1" CornerRadius="8" />
                                            <Button Grid.Column="1" Text="Approva" BackgroundColor="{StaticResource Success}" TextColor="{StaticResource OnPrimary}" CornerRadius="8" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
