<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.BusinessOpeningHoursPage"
             x:DataType="viewmodels:BusinessOpeningHoursViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource DarkBackground}}">

    <Grid RowDefinitions="*,Auto" Padding="20,16,20,24">

        <ActivityIndicator Grid.Row="0" Grid.RowSpan="2"
                           IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" ZIndex="10"/>

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="10">
                <Label Text="Imposta gli orari per questa attività"
                       FontSize="16" FontAttributes="Bold" FontFamily="PJSBold"
                       TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                       Margin="2,0,0,8"/>

                <CollectionView ItemsSource="{Binding Days}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:DayScheduleItemViewModel">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}" StrokeThickness="1"
                                    Padding="16,14" Margin="0,0,0,8">
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#000000" Offset="0,2" Radius="10" Opacity="0.05"/>
                                </Border.Shadow>
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10">

                                    <!-- Day + toggle -->
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding DayName}"
                                           FontSize="15" FontAttributes="Bold" FontFamily="PJSBold"
                                           TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                                           VerticalOptions="Center"/>
                                    <Switch Grid.Row="0" Grid.Column="1"
                                            IsToggled="{Binding IsOpen}"
                                            OnColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"
                                            ThumbColor="White"/>

                                    <!-- Time pickers (open) -->
                                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Spacing="10"
                                                           IsVisible="{Binding IsOpen}">
                                        <Label Text="Da"
                                               FontSize="13" FontFamily="PJSReg"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"
                                               VerticalOptions="Center"/>
                                        <Border Style="{StaticResource FieldBorder}" WidthRequest="110">
                                            <TimePicker Time="{Binding OpenTime}" Format="HH:mm"
                                                        FontFamily="PJSReg"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                                                        Margin="10,0"/>
                                        </Border>
                                        <Label Text="a"
                                               FontSize="13" FontFamily="PJSReg"
                                               TextColor="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"
                                               VerticalOptions="Center" Margin="6,0,0,0"/>
                                        <Border Style="{StaticResource FieldBorder}" WidthRequest="110">
                                            <TimePicker Time="{Binding CloseTime}" Format="HH:mm"
                                                        FontFamily="PJSReg"
                                                        TextColor="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"
                                                        Margin="10,0"/>
                                        </Border>
                                    </HorizontalStackLayout>

                                    <!-- Closed label -->
                                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="Chiuso"
                                           FontSize="13" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"
                                           FontAttributes="Italic"
                                           IsVisible="False">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsOpen}" Value="False">
                                                <Setter Property="IsVisible" Value="True"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1"
                Text="Salva Orari"
                Command="{Binding SaveCommand}"
                Style="{StaticResource PrimaryButton}"
                Margin="0,12,0,0">
            <Button.Triggers>
                <DataTrigger TargetType="Button" Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Button.Triggers>
        </Button>
    </Grid>
</ContentPage>
