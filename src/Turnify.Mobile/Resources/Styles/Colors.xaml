<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ── MAUI default keys (required by Styles.xaml) ─────────── -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1F1F1F</Color>
    <Color x:Key="PrimaryDark">#68DBA9</Color>
    <Color x:Key="PrimaryDarkText">#68DBA9</Color>
    <Color x:Key="Secondary">#006A63</Color>

    <!-- ── Tropic Burst — Core palette ──────────────────────── -->
    <Color x:Key="Navy">#064E3B</Color>
    <Color x:Key="Primary">#006948</Color>
    <Color x:Key="PrimaryLight">#D1FAE5</Color>
    <Color x:Key="PrimaryMid">#00855D</Color>

    <!-- Header gradient endpoints -->
    <Color x:Key="HeaderGradientStart">#064E3B</Color>
    <Color x:Key="HeaderGradientEnd">#115E59</Color>

    <!-- MD3 surface scale -->
    <Color x:Key="Background">#F5FBF5</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceContainerLowest">#FFFFFF</Color>
    <Color x:Key="SurfaceContainerLow">#EFF5EF</Color>
    <Color x:Key="SurfaceContainerHigh">#E4EAE4</Color>
    <Color x:Key="SurfaceContainer">#E9EFE9</Color>
    <Color x:Key="SurfaceVariant">#DEE4DE</Color>

    <!-- Text -->
    <Color x:Key="OnBackground">#171D19</Color>
    <Color x:Key="OnSurfaceVariant">#3D4A42</Color>
    <Color x:Key="Outline">#6D7A72</Color>
    <Color x:Key="OutlineVariant">#BCCAC0</Color>

    <!-- Primary container -->
    <Color x:Key="PrimaryContainer">#00855D</Color>
    <Color x:Key="OnPrimaryContainer">#F5FFF7</Color>
    <Color x:Key="InversePrimary">#68DBA9</Color>
    <Color x:Key="PrimaryFixed">#85F8C4</Color>
    <Color x:Key="PrimaryFixedDim">#68DBA9</Color>

    <!-- Secondary / teal -->
    <Color x:Key="SecondaryContainer">#99EFE5</Color>
    <Color x:Key="OnSecondaryContainer">#006F67</Color>

    <!-- Tertiary / coral -->
    <Color x:Key="Tertiary">#9B3E3B</Color>
    <Color x:Key="TertiaryContainer">#BA5551</Color>
    <Color x:Key="OnTertiaryContainer">#FFFBFF</Color>

    <!-- Semantic states -->
    <Color x:Key="Success">#006948</Color>
    <Color x:Key="SuccessLight">#D1FAE5</Color>
    <Color x:Key="SuccessText">#005137</Color>

    <Color x:Key="Warning">#B45309</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>
    <Color x:Key="WarningText">#92400E</Color>

    <Color x:Key="Error">#BA1A1A</Color>
    <Color x:Key="ErrorLight">#FFDAD6</Color>
    <Color x:Key="ErrorText">#93000A</Color>

    <!-- KPI card solid colors -->
    <Color x:Key="KpiAmber">#F59E0B</Color>
    <Color x:Key="KpiBlue">#0284C7</Color>

    <!-- Legacy aliases kept for backward compat -->
    <Color x:Key="Purple">#006A63</Color>
    <Color x:Key="PurpleLight">#99EFE5</Color>
    <Color x:Key="OnPrimary">White</Color>
    <Color x:Key="PrimaryContainer2">#EEF1FE</Color>
    <Color x:Key="PrimaryFixed2">#EEF1FE</Color>
    <Color x:Key="SecondaryContainer2">#EEF1FE</Color>
    <Color x:Key="OnSecondaryContainer2">#006948</Color>
    <Color x:Key="ErrorContainer">#FFDAD6</Color>
    <Color x:Key="OnErrorContainer">#93000A</Color>
    <Color x:Key="SuccessContainer">#D1FAE5</Color>

    <!-- ── Dark mode — Deep Forest palette ───────────────────── -->
    <Color x:Key="DarkBackground">#0D1510</Color>
    <Color x:Key="DarkSurface">#162019</Color>
    <Color x:Key="DarkSurfaceContainerLowest">#0D1510</Color>
    <Color x:Key="DarkSurfaceContainerLow">#1A261D</Color>
    <Color x:Key="DarkSurfaceContainer">#1F2C22</Color>
    <Color x:Key="DarkSurfaceContainerHigh">#273529</Color>
    <Color x:Key="DarkSurfaceVariant">#1F2C22</Color>
    <Color x:Key="DarkOnBackground">#E2F0E6</Color>
    <Color x:Key="DarkOnSurfaceVariant">#A3B5A8</Color>
    <Color x:Key="DarkOutline">#7D8F83</Color>
    <Color x:Key="DarkOutlineVariant">#3A4D41</Color>
    <Color x:Key="DarkPrimary">#68DBA9</Color>
    <Color x:Key="DarkPrimaryContainer">#004D34</Color>
    <Color x:Key="DarkHeaderGradientStart">#0D2218</Color>
    <Color x:Key="DarkHeaderGradientEnd">#103529</Color>

    <!-- ── it-22 design system aliases ─────────────────────────── -->
    <!-- Light -->
    <Color x:Key="Bg">#F5FBF5</Color>
    <Color x:Key="TextPrimary">#171D19</Color>
    <Color x:Key="TextSecondary">#3D4A42</Color>
    <Color x:Key="Border">#6D7A72</Color>
    <Color x:Key="BorderSoft">#BCCAC0</Color>
    <Color x:Key="SurfaceLow">#EFF5EF</Color>
    <Color x:Key="PrimaryText">#FFFFFF</Color>
    <Color x:Key="SuccessBg">#D1FAE5</Color>
    <Color x:Key="WarningBg">#FEF3C7</Color>
    <Color x:Key="ErrorBg">#FFDAD6</Color>
    <Color x:Key="Danger">#BA1A1A</Color>
    <Color x:Key="KpiBlueBg">#EFF6FF</Color>
    <Color x:Key="KpiAmberBg">#FFFBEB</Color>
    <Color x:Key="KpiDangerBg">#FEF2F2</Color>
    <!-- Dark -->
    <Color x:Key="BgDark">#0D1510</Color>
    <Color x:Key="SurfaceDark">#162019</Color>
    <Color x:Key="TextPrimaryDark">#E2F0E6</Color>
    <Color x:Key="TextSecondaryDark">#A3B5A8</Color>
    <Color x:Key="BorderDark">#7D8F83</Color>
    <Color x:Key="BorderSoftDark">#3A4D41</Color>
    <Color x:Key="SurfaceLowDark">#1A261D</Color>
    <Color x:Key="PrimaryTextDark">#FFFFFF</Color>
    <Color x:Key="PrimaryLightDark">#1A4D35</Color>
    <Color x:Key="SuccessBgDark">#0D3320</Color>
    <Color x:Key="SuccessTextDark">#4ADE80</Color>
    <Color x:Key="WarningBgDark">#3D2900</Color>
    <Color x:Key="WarningTextDark">#FBBF24</Color>
    <Color x:Key="ErrorBgDark">#3D0D0D</Color>
    <Color x:Key="ErrorTextDark">#F87171</Color>
    <Color x:Key="DangerDark">#F87171</Color>
    <Color x:Key="KpiBlueDark">#60A5FA</Color>
    <Color x:Key="KpiBlueBgDark">#1E3A5F</Color>
    <Color x:Key="KpiAmberDark">#FBBF24</Color>
    <Color x:Key="KpiAmberBgDark">#3D2900</Color>
    <Color x:Key="KpiDangerBgDark">#3D0D0D</Color>

    <!-- ── Global styles ─────────────────────────────────────── -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource DarkBackground}}"/>
    </Style>

    <Style x:Key="FieldBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceContainerLow}, Dark={StaticResource DarkSurfaceContainerLow}}"/>
        <Setter Property="Stroke" Value="{AppThemeBinding Light=#A7F3D0, Dark=#2A5040}"/>
        <Setter Property="StrokeThickness" Value="1.5"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 13"/>
    </Style>

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"/>
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 18"/>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark=#0D1510}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="BorderColor" Value="{StaticResource Error}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="TextColor" Value="{StaticResource Error}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HeightRequest" Value="52"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource DarkOutlineVariant}}"/>
        <Setter Property="BorderWidth" Value="1.5"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnSurfaceVariant}, Dark={StaticResource DarkOnSurfaceVariant}}"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="HeightRequest" Value="48"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="FieldEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"/>
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource DarkOutline}}"/>
        <Setter Property="HeightRequest" Value="50"/>
        <Setter Property="Margin" Value="16,0"/>
        <Setter Property="FontFamily" Value="PJSReg"/>
        <Setter Property="FontSize" Value="15"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}"/>
        <Setter Property="CharacterSpacing" Value="1.2"/>
        <Setter Property="FontFamily" Value="PJSBold"/>
    </Style>

    <Style x:Key="HeadingLabel" TargetType="Label">
        <Setter Property="FontSize" Value="26"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource OnBackground}, Dark={StaticResource DarkOnBackground}}"/>
        <Setter Property="CharacterSpacing" Value="-0.5"/>
        <Setter Property="FontFamily" Value="PJSXBold"/>
    </Style>

</ResourceDictionary>
