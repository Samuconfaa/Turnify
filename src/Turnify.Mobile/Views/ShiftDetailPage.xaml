<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Turnify.Mobile.ViewModels"
             x:Class="Turnify.Mobile.Views.ShiftDetailPage"
             x:DataType="vm:ShiftDetailViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <!-- Bottom sheet overlay -->
    <Grid>
        <BoxView BackgroundColor="Black" Opacity="0.4"/>
        <Border VerticalOptions="End"
                StrokeShape="RoundRectangle CornerRadius='28,28,0,0'"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Sheet header -->
                <VerticalStackLayout Grid.Row="0" Spacing="0">
                    <BoxView WidthRequest="32" HeightRequest="4" CornerRadius="2"
                             HorizontalOptions="Center" Margin="0,10,0,6"
                             BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"/>
                    <Grid ColumnDefinitions="*,Auto" Padding="20,0,20,8">
                        <Label Grid.Column="0" Text="{Binding Title}"
                               FontSize="18" FontFamily="PJSBold"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                               CharacterSpacing="-0.3" VerticalOptions="Center"/>
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle CornerRadius='10'"
                                StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                            <Label Text="✕" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Sheet content -->
                <ScrollView Grid.Row="1" MaximumHeightRequest="520">
                    <VerticalStackLayout Padding="20,12,20,20" Spacing="14">

                        <!-- Recurring banner (edit mode only) -->
                        <Border StrokeShape="RoundRectangle CornerRadius='10'"
                                StrokeThickness="0" Padding="12"
                                BackgroundColor="{AppThemeBinding Light={StaticResource WarningBg}, Dark={StaticResource WarningBgDark}}"
                                IsVisible="{Binding IsRecurring}">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="✦" FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"
                                       VerticalOptions="Center"/>
                                <Label Text="Turno ricorrente"
                                       FontSize="12" FontFamily="PJSSemi"
                                       TextColor="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- No employees warning -->
                        <Border StrokeShape="RoundRectangle CornerRadius='10'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"
                                Padding="12,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource WarningBg}, Dark={StaticResource WarningBgDark}}"
                                IsVisible="{Binding Employees.Count, Converter={StaticResource IntIsZeroConverter}}">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Nessun dipendente disponibile."
                                       FontSize="14" FontFamily="PJSBold"
                                       TextColor="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"/>
                                <Label Text="Aggiungi prima un dipendente dalla sezione Team."
                                       FontSize="13" FontFamily="PJSReg"
                                       TextColor="{AppThemeBinding Light={StaticResource WarningText}, Dark={StaticResource WarningTextDark}}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- DIPENDENTE section -->
                        <Label Text="DIPENDENTE" FontSize="11" FontFamily="PJSSemi"
                               CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,4,0,0"/>
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="10,4,14,4"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Picker ItemsSource="{Binding Employees}"
                                    ItemDisplayBinding="{Binding FullName}"
                                    SelectedItem="{Binding SelectedEmployee}"
                                    Title="Seleziona dipendente"
                                    FontFamily="PJSReg" FontSize="14"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    TitleColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                    Margin="4,0"/>
                        </Border>

                        <!-- ORARI section -->
                        <Label Text="ORARI" FontSize="11" FontFamily="PJSSemi"
                               CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,6,0,0"/>

                        <!-- Data -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                StrokeThickness="2" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="13,0">
                                <Label Text="📅" FontSize="18" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>
                                <DatePicker Date="{Binding ShiftDate}"
                                            Format="dddd dd MMMM yyyy"
                                            MinimumDate="2020-01-01"
                                            FontFamily="PJSReg" FontSize="15"
                                            TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                            HorizontalOptions="FillAndExpand"
                                            BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Ora inizio + fine -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Label Text="⏱" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <TimePicker Time="{Binding StartTime}" Format="HH:mm"
                                                FontFamily="PJSReg" FontSize="15"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                HorizontalOptions="FillAndExpand"
                                                BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle CornerRadius='12'"
                                    Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                    StrokeThickness="1" HeightRequest="50"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                                <HorizontalStackLayout Spacing="10" Padding="14,0">
                                    <Label Text="⏱" FontSize="18" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                    <TimePicker Time="{Binding EndTime}" Format="HH:mm"
                                                FontFamily="PJSReg" FontSize="15"
                                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                                HorizontalOptions="FillAndExpand"
                                                BackgroundColor="Transparent"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Etichetta -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1" HeightRequest="50"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <HorizontalStackLayout Spacing="10" Padding="14,0">
                                <Entry Text="{Binding Label}" Placeholder="Es. Apertura, Turno pranzo…"
                                       FontFamily="PJSReg" FontSize="15"
                                       HorizontalOptions="FillAndExpand" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                       PlaceholderColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                       BackgroundColor="Transparent"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Note -->
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}">
                            <Editor Text="{Binding Note}" Placeholder="Es. Copertura per Mario assente…"
                                    FontFamily="PJSReg" FontSize="14"
                                    PlaceholderColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                                    TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                    HeightRequest="80" Margin="14,8"
                                    BackgroundColor="Transparent"/>
                        </Border>

                        <!-- RIPETI section (create mode only) -->
                        <Label Text="RIPETI" FontSize="11" FontFamily="PJSSemi"
                               CharacterSpacing="0.8"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"
                               Margin="0,6,0,0"
                               IsVisible="{Binding IsCreateMode}"/>
                        <Border StrokeShape="RoundRectangle CornerRadius='12'"
                                StrokeThickness="1"
                                Stroke="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                Padding="14"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource SurfaceDark}}"
                                IsVisible="{Binding IsCreateMode}">
                            <HorizontalStackLayout Spacing="14">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                    <Label Text="{Binding RepeatLabel}" FontSize="14" FontFamily="PJSSemi"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"/>
                                    <Label Text="Stesso giorno della settimana" FontSize="12" FontFamily="PJSReg"
                                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}"/>
                                </VerticalStackLayout>
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Border StrokeShape="RoundRectangle CornerRadius='10'"
                                            StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLow}, Dark={StaticResource SurfaceLowDark}}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding DecrementRepeatWeeksCommand}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="−" FontSize="16" FontFamily="PJSSemi"
                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                    <Label Text="{Binding RepeatWeeks}" FontSize="16" FontFamily="PJSBold"
                                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                           WidthRequest="40" HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"/>
                                    <Border StrokeShape="RoundRectangle CornerRadius='10'"
                                            StrokeThickness="0" WidthRequest="32" HeightRequest="32"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding IncrementRepeatWeeksCommand}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="+" FontSize="16" FontFamily="PJSBold"
                                               TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Proponi scambio (employee, edit mode) -->
                        <Button Text="Proponi scambio turno"
                                Command="{Binding ProposeSwapCommand}"
                                IsVisible="{Binding CanProposeSwap}"
                                BackgroundColor="Transparent"
                                BorderColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                BorderWidth="1"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                                CornerRadius="12" HeightRequest="44"
                                FontFamily="PJSSemi" FontSize="14"/>

                        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                           HorizontalOptions="Center"
                                           Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"/>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Bottom buttons -->
                <Grid Grid.Row="2" Padding="20,0,20,20">
                    <!-- Edit mode buttons: Elimina + Salva -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10"
                          IsVisible="{Binding IsEditMode}">
                        <BoxView Grid.ColumnSpan="2" HeightRequest="1" VerticalOptions="Start"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                 Margin="0,0,0,0" Opacity="0.5"/>
                        <Button Grid.Column="0" Text="Elimina"
                                Command="{Binding DeleteCommand}"
                                BackgroundColor="Transparent"
                                BorderColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                BorderWidth="1.5"
                                TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"
                                Margin="0,12,0,0"/>
                        <Button Grid.Column="1" Text="Salva turno"
                                Command="{Binding SaveCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"
                                Margin="0,12,0,0"/>
                    </Grid>
                    <!-- Create mode button: Salva -->
                    <VerticalStackLayout IsVisible="{Binding IsCreateMode}" Spacing="0">
                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Border}, Dark={StaticResource BorderDark}}"
                                 Margin="0,0,0,12" Opacity="0.5"/>
                        <Button Text="Salva turno"
                                Command="{Binding SaveCommand}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                TextColor="{AppThemeBinding Light={StaticResource PrimaryText}, Dark={StaticResource PrimaryTextDark}}"
                                CornerRadius="12" HeightRequest="50"
                                FontFamily="PJSSemi" FontSize="15"/>
                    </VerticalStackLayout>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
